{"id":"c1ce276296aa97e85eded6362e0ad2b80973bc92228513facedd911006df8937","text":"来自 resultRGB 输出的 R 通道。"}
{"id":"2e12f103dc4a4b216b21cc6f017371b08507fc67f2a1ad9f133aa333afe0fc11","text":"resultG"}
{"id":"009cc7a7eb8d7664fe8e8a024e817626113dd5198fc3a164f5ec297f2fa68da3","text":"来自 resultRGB 输出的 G 通道。"}
