{"id":"ad869122eaf567102fc415d386a3a77227e3f6452d0c86aae6e93ebec58034c5","item_id":"d4a23e66c6:17","text":"5500 到 6000"}
{"id":"2a86ab841b48800d1013046c38dde517a38a86a18f743db66e308d1a28f7c826","item_id":"d4a23e66c6:18","text":"垂直日光、电子闪光"}
{"id":"ed8617bd4173e6cf220b13d9c36b1eb75379bf6628a75ad5a71d8b05f9d27df9","item_id":"d4a23e66c6:19","text":"氙短弧灯"}
{"id":"d2d15386559da323af53b97dee5f8432d95f5f2fbd4e69e5f88a831c1c836732","item_id":"d4a23e66c6:20","text":"日光、阴天"}
{"id":"3a9875129f8c0f623dc2ce46a070d65c28fab586995ce755c85ab6bf0f7aaee7","item_id":"d4a23e66c6:21","text":"6500 到 10500"}
{"id":"fef3191830b862d5d6067aa99738531d8d50b72ef4ed50448e0fb41ed4e726cc","item_id":"d4a23e66c6:22","text":"LCD 或 CRT 屏幕"}
{"id":"4a2b558169735aa8cd540480fd04c6a3b4d1e46284c5a3f7151fa96f223b66d2","item_id":"d4a23e66c6:23","text":"15000 到 27000"}
{"id":"efe60247101eaf5cc1a069055d1f2b1d260f68fb36420f67751a6a295aeb3ded","item_id":"d4a23e66c6:24","text":"晴朗蓝色极向天空"}
{"id":"a7efd3df130129ce58a44698cad3db8787dfed1d4b99580e7b826752aa7e04ba","item_id":"d4a23e66c6:25","text":"Physical Intensity（物理强度）"}
{"id":"754efef1d4b07612226af555fc8777a495810144511ca9869113f52f2b19a510","item_id":"d4a23e66c6:26","text":"设为 1 时，该颜色会发射正确数量的能量。警告：你的颜色会变得极其强烈。"}
{"id":"cc5454a4b7ce211370dcd2aa0ae58d6b564eee7940b42de516d05f5b269c414b","item_id":"d4a23e66c6:27","text":"Exposure（曝光）"}
{"id":"3d0e573365d562899bff876d52e265ce532d63127644868c003bdf89a3b40ecd","item_id":"d4a23e66c6:28","text":"使用 exposure（曝光）调整发射能量的数量。如果 Physical Intensity（物理强度）大于 0，这非常有用。"}
{"id":"8b76e2df9050f924b018cff8809cbc580f39a71664984ae54adf99defe9eaa2e","item_id":"d4a23e66c6:29","text":"Output Parameters（输出参数）"}
{"id":"d76cd2ea3537dbac1a9b90ba977fe5ad654d6f7f3c36b060963224d8b5611f99","item_id":"d4a23e66c6:30","text":"resultRGB"}
{"id":"09ef84bf4efcc02fe93fca7f96e1a716ab65c9672f2571764245caa9e255052f","item_id":"d4a23e66c6:31","text":"该黑体被加热到给定温度后发出的颜色。"}
