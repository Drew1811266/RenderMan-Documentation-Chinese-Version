{"id":"65f361ab8ee7b27c2d67ab75789aff3b05a94f107b20c13e6f03b8c31c2186ce","text":"PxrDirt"}
{"id":"a239be71d4ef6b2fb54b8cc4acce4e8b3de61fc2bc4092a1741589d669c6a5f2","text":"会渲染局部几何遮挡。这可用于将着色效果应用到凹角和缝隙。"}
{"id":"781a65294149a53ca2fd116f82fec6b6b9c58a43da634a54a09fdc7b7be92569","text":"传统的环境光遮蔽效果可以通过将被遮挡颜色设为黑色、将未遮挡颜色设为白色来实现。"}
{"id":"0d29fcd10b68293591fabc4e1acf5a332df8c973e2c9bd5f052d60787f4a9244","text":"Occluded and Unoccluded"}
{"id":"90c1958433bc7b512ff86ba5301b16bb4159f7cc71600320ce044e5271954ba8","text":"被遮挡和未遮挡着色的结果颜色。"}
{"id":"d27d4e8379966ccdb65e7b928a6243a45c699c0502c57cbd0442cade075c923a","text":"控制每个摄像机命中点的遮挡采样数量。更多采样可以降低噪声，但代价是增加渲染时间。"}
{"id":"dbf57e88bc46e89df1b98c8b947f1d129174a0ea5bdda9cee399736e65465ceb","text":"可用值为"}
{"id":"ac586213b5d95f50c0ad188adca1a533ecfa59e4688450311e2c8f37339c69b3","text":"光线在着色点上方的半球内不会在任何特定方向上加权。"}
{"id":"68c3f4a103ad6bbbd4035c57aa179762272b93e967e0e7dd402f9b10f887df28","text":"Cosine 分布通常用于渲染环境光遮蔽。"}
{"id":"72444602a3f625d9ef10b86a253758be07bb67873a5828b76b804ca5efbf3f77","text":"分布时的光线采样扩散。值 1.0 会给出完美的 Lambertian 分布。"}
{"id":"1a55e3920f4390895d14eaa7cb7a6fb8e91b31d95dfc0d86a4935c36542e39d6","text":"Falloff"}
{"id":"9c5c96a40c3dfd0c6f6d6e2d42b61d41c0fc1d81fb3f1af13f5d55fd7b1e9086","text":"Falloff 可用于控制遮挡效果的柔和度。"}
{"id":"e82a0f26bedfb104bffb68056d1b1ed5c1f8c8cda471f26c0d51f5fcb921ee06","text":"物体可能产生遮挡的最大距离。零表示 infinite（所有物体都会遮挡）。"}
{"id":"9c8a9579abe55bdc8a7b97031705e2738d912de38a35262863d8f47e05d3d641","text":"Direction"}
{"id":"31418e59cc51962d585f682b647ea705c1fac27923589452596326a2f2d5ba44","text":"沿表面法线方向追踪光线（"}
{"id":"31207a2065f46a5b948fce6fe5c13e85abaf5631e2f894b47dcd4fce14f6c57b","text":"outside"}
{"id":"8aa3a7d6a8de2adf92e47616a65dab5d11e0232887b2390aaba0cae01a8cd8ed","text":"），沿法线反方向（"}
{"id":"106b086224a4d945eae25f7be3805a931a873270326dd868b0e41f71ee9fff72","text":"inside"}
{"id":"e27aa17a39734bd80fea83d7b6ad8e84c4a8ab7742b94f76b2ca0a012939efc4","text":"），或沿"}
{"id":"ff7772053abf7d817d6eec229a09e14f0d1552f1cb0aeedb2ac73784ac2d2e39","text":"both"}
{"id":"fe8929f4ba151cb644b23a85abcc10e5924053cba95b08603db95b3267596934","text":"方向。"}
{"id":"7a2850c07a442172dc057bfd58c73ea5d261c1dffc1f130ba5242112dcc7785b","text":"Bias Direction"}
{"id":"a2a42295760196b0a27d38619b300048b4b3eb43271fa48eedeca4406296a648","text":"向法线向量添加方向偏置。值必须以 world space 指定。"}
{"id":"3c460e4745000235ded00e9d9448ff42f9b9f33c77eba25122cd5a8d2750833e","text":"Bias Co-ordinate System"}
{"id":"0d25dba752654e6745dd2f2017ae43a7b94f23f70886a6ee413a1dfb06ced533","text":"偏置方向坐标系统变换的名称，例如 object、world 或 camera"}
{"id":"027d1c0f0222254a0b2b1acf6a960c54f2e37abbb7be1a5510d1dbc6fa94ec09","text":"将光线追踪限制到由一个或多个 trace groups 定义的物体子集"}
