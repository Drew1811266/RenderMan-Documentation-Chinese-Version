  "items": [
    {
      "id": "b344d80e24a3679999fa964450b34bc24d1578a35509f934c1418b0a20d21a67",
      "text": "The"
    },
    {
      "id": "7e2e47a5e71a778914aa28299d480951aa2f10c7f9643f0bb87dc4fad2d4807d",
      "text": "Non-Commercial RenderMan"
    },
    {
      "id": "c44a1f778bf674737a4436851f7c8b4d4b07b1f9c219aac841ad13ead6648bc7",
      "text": "(NCR) is provided to artists wanting to experiment with or learn RenderMan in a bridge application."
    },
    {
      "id": "e22be650905d993ccb5502d5a35e7d315500e77227a7357e864f89c1647eed6d",
      "text": "These licenses are timed to expire every 120 days and can be renewed once the license expires."
    },
    {
      "id": "421fb94e90c876b91dfff41e487ac64916328e79e733967853438eaf2ae51c17",
      "text": "To renew your license, visit the"
    },
    {
      "id": "1242f11b91f19845dc84c787ce9608600dde1baccd39e821bf9c69546784a055",
      "text": "renewal page"
    },
    {
      "id": "a9ac1789358ee6f742d3f355a7bef73980f0bed382385b61dcb5bd1c1244b28b",
      "text": "and complete the survey as directed by the link in your LicenseApp."
    },
    {
      "id": "5533d4b455d1bffd8d3b1961d211fdfe34c65b076eab9f27ce2f7345a2656b34",
      "text": "Be sure you are logged into the forums before updating the license, this is how the system knows who you are and your available license options."
    },
    {
      "id": "295dc132151b03f06c419c8bee346aabb669348e4decaa5abda3b10c5b4fe02b",
      "text": "After completing the survey, you can re-open the"
    },
    {
      "id": "18e4691600e090447bf4f538c1d5c5842a18dc3747ff395eafaa02489f3a19da",
      "text": "licensing application"
    },
    {
      "id": "7930c38f700b89314291e0ed34da9270d31833ff82f70340bd2f3ff83c07101e",
      "text": "(as an Administrator or it cannot write the new license) in your bridge product to install the new license or"
    },
    {
      "id": "6c52e4d5ff0ddc86c88de876b58d9ccd34b20aec6bc8dbeaeef62059fee65b60",
      "text": "alternatively"
    },
    {
      "id": "e5a72b9845d7204dbb16beeade3c5dc2fee3ec582de345dbadaf0f9172943cfb",
      "text": "you can re-run the installer and upgrade to the latest version if you have not already with user permissions."
    }
  ]
}