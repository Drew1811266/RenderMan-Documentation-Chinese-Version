  "items": [
    {
      "id": "7b68fe5510851da3d89100c569d3265e044d8656d95750c376b7a0972dea7330",
      "text": "After"
    },
    {
      "id": "a1d1d163b52f00384c8404261916cdece4795fb3d87c4c7b7d8a566384399764",
      "text": "the new RenderMan has been installed, if a new license is needed, the new Pixar License App can now be used to download and easily upgrade to a new license file."
    },
    {
      "id": "d9ad6119601bd81acf8c47fb5db5afc8a92533b151b80f164728356967474e54",
      "text": "Updating Floating Licenses"
    },
    {
      "id": "967e2b1303c7875e9a8d051da10107d650c4a4781965e1ee2c6cf68425544d3f",
      "text": "To update an existing floating license, run the LicenseApp on the host that is running the license server."
    },
    {
      "id": "e5b86141ac6709a1bef4b18e6b93df1b979e985f18fbd63d2b4c5a75d17cab92",
      "text": "You should see the existing licenses that are currently being served:"
    },
    {
      "id": "714cca1f849a673594be8e8357f8015552f19e8a929d607b185123f9783e4e03",
      "text": "You can then select:"
    },
    {
      "id": "83733d7117701ae6423a3367eb99c33297cc0e533adb48be622ecfe7bfb90a5f",
      "text": "Get License"
    },
    {
      "id": "e4c73d00da274344523ca925326b50eb96126c472007328bbd65d3f661b87bf3",
      "text": "and a dialog will pop up asking for your forum id and password and the serial number for the license you wish to download."
    },
    {
      "id": "b4e69d018c6c673512de384f24b98a2d27b5cce4a03f7485d5cc7119ac1e6b56",
      "text": "Once that license is downloaded, it will not be actually be picked up by the running license server. You will need to stop and restart the license server in order for this change to take effect. You can either do this by rebooting your machine; assuming the license server is setup to start automatically when your machine boots up. Our you can manually start and stop the license server. This process is detailed per operating system:"
    },
    {
      "id": "4828e60247c1636f57b7446a314e7f599c12b53d40061cc851a1442004354fed",
      "text": "Linux"
    },
    {
      "id": "aed6b7aa2a0511a9bbcaae2a10127a3139fc6494c57769b31b1a694c14483ce7",
      "text": "macOS"
    },
    {
      "id": "d598026a9cbc60505f138ce53ac78088d582100c196d0f70c7e2538d4a8d7e10",
      "text": "Windows"
    },
    {
      "id": "a08741849d227d4eee503eada9b2d0c66d174aff76a6f144c17fe495fab7fac4",
      "text": "Running renders should not fail when the license server is restarted within a reasonably short amount of time. You will see warnings of the type:"
    },
    {
      "id": "938196528da0ee6145b9ea88c4081a52d878d8d2e6efeca265088ecd612a7587",
      "text": "R50004 {WARNING} License warning - code 10054: Connection lost to peer"
    },
    {
      "id": "0d48085669b3c91324caa77d67b6578b06654edd7347e985d9f1f6b665ad7312",
      "text": "R50004 {CONTINUED} license source: 9010@MYLICSERVER"
    },
    {
      "id": "b35a92b26400b77a2191a1805d9b35dc60d2a61846b47105157b54a3806a3c45",
      "text": "R50004 {WARNING} License warning - license server connection re-established"
    },
    {
      "id": "c3f112889cfae147c3d61a5c132e6d037e4873c9a66e4c695e4a95cb1ca87c6a",
      "text": "Updating Node-Locked Licenses"
    },
    {
      "id": "c9ff78347450f5f9db7641232c529ada83c649cfe4159992d92c173c624c544b",
      "text": "To update an existing node-locked license, run the LicenseApp on the host that has the node-locked license."
    },
    {
      "id": "f9b291a277a0758787164f4c2ec68ff08fb078780d5416ed52b7cd3214a8fcdf",
      "text": "You should see the existing licenses that are currently locked to that machine:"
    },
    {
      "id": "714cca1f849a673594be8e8357f8015552f19e8a929d607b185123f9783e4e03",
      "text": "You can then select:"
    },
    {
      "id": "83733d7117701ae6423a3367eb99c33297cc0e533adb48be622ecfe7bfb90a5f",
      "text": "Get License"
    },
    {
      "id": "e4c73d00da274344523ca925326b50eb96126c472007328bbd65d3f661b87bf3",
      "text": "and a dialog will pop up asking for your forum id and password and the serial number for the license you wish to download."
    },
    {
      "id": "d5cfe2f91653675c39ddee16fa6ce89cbf55a24a69e70d25892881ba69377da7",
      "text": "Once your new license is downloaded, feel free to simple close the LicenseApp, your applications should then run using the new license file."
    }
  ]
}