  "actionable_ascii_heavy_residuals": [],
  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "2a32e6b014:0",
      "text": "DemoSign_v01_h264.mov",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "2a32e6b014:1",
      "text": "上图是 Solaris scene graph，用于对我们场景中的所有 lights 进行 randomization。",
      "ascii_letters": 36,
      "cjk_chars": 16
    },
    {
      "item_id": "2a32e6b014:3",
      "text": "attributewrangle",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "2a32e6b014:5",
      "text": "我们先看看 meshlight Neon tubes：",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "2a32e6b014:6",
      "text": "Letters - D - M - O - Neon Tubes（字母 D/M/O 的霓虹管）",
      "ascii_letters": 22,
      "cjk_chars": 6
    },
    {
      "item_id": "2a32e6b014:8",
      "text": "attributewrangle",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "2a32e6b014:9",
      "text": "node，并在 Primitives 下选择我们希望该 node 控制的 neon tube meshlights。",
      "ascii_letters": 36,
      "cjk_chars": 13
    },
    {
      "item_id": "2a32e6b014:10",
      "text": "下面是用于设置 parameters 的 VEX code。",
      "ascii_letters": 17,
      "cjk_chars": 8
    },
    {
      "item_id": "2a32e6b014:11",
      "text": "现在我们有了一组 parameters，可用于控制 prims 的 randomisation。",
      "ascii_letters": 28,
      "cjk_chars": 14
    },
    {
      "item_id": "2a32e6b014:13",
      "text": "neons 处于 switched off 状态的 frames 数量。",
      "ascii_letters": 22,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:15",
      "text": "neons 处于 switched on 状态的 frames 数量。",
      "ascii_letters": 21,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:16",
      "text": "过渡帧数参数（Transition）",
      "ascii_letters": 10,
      "cjk_chars": 6
    },
    {
      "item_id": "2a32e6b014:17",
      "text": "在 OFF 和 ON states 之间 transition 所需的 frames 数量。",
      "ascii_letters": 27,
      "cjk_chars": 9
    },
    {
      "item_id": "2a32e6b014:18",
      "text": "帧偏移参数（FrameOffset）",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "2a32e6b014:20",
      "text": "强度参数（Intensity）",
      "ascii_letters": 9,
      "cjk_chars": 4
    },
    {
      "item_id": "2a32e6b014:21",
      "text": "设置并 override（覆盖）lights 的 intensity（强度）。",
      "ascii_letters": 23,
      "cjk_chars": 8
    },
    {
      "item_id": "2a32e6b014:22",
      "text": "Letter - E - Globe Bulbs（字母 E 的球形灯泡）",
      "ascii_letters": 18,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:23",
      "text": "这个 wrangler 允许我们控制在 Globe bulb USD asset 中设置的两个 primvars 的 value。",
      "ascii_letters": 38,
      "cjk_chars": 16
    },
    {
      "item_id": "2a32e6b014:24",
      "text": "记住，它们名为 Bulb_COL 和 Bulb_INT。",
      "ascii_letters": 14,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:26",
      "text": "，它会创建这一组 parameters。",
      "ascii_letters": 10,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:27",
      "text": "强度最小值与最大值（Intensity Min + Max）",
      "ascii_letters": 15,
      "cjk_chars": 9
    },
    {
      "item_id": "2a32e6b014:28",
      "text": "将为 bulb intensity (Bulb_INT) 随机创建的 min 和 max intensity values。",
      "ascii_letters": 41,
      "cjk_chars": 8
    },
    {
      "item_id": "2a32e6b014:30",
      "text": "控制每个 bulb hue (Bulb_COL) 的 randomize 程度。",
      "ascii_letters": 23,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:31",
      "text": "饱和度最小值与最大值（Saturation Min + Max）",
      "ascii_letters": 16,
      "cjk_chars": 10
    },
    {
      "item_id": "2a32e6b014:32",
      "text": "bulb color (Bulb_COL) 的 minimum 和 maximum random saturation values。",
      "ascii_letters": 52,
      "cjk_chars": 2
    },
    {
      "item_id": "2a32e6b014:34",
      "text": "bulb color (Bulb_COL) 的 minimum 和 maximum random values。",
      "ascii_letters": 42,
      "cjk_chars": 2
    },
    {
      "item_id": "2a32e6b014:36",
      "text": "允许你控制 bulbs flashing 的 speed。",
      "ascii_letters": 18,
      "cjk_chars": 6
    },
    {
      "item_id": "2a32e6b014:37",
      "text": "如果保留为 single frame，bulbs 将不会 animate。不过，使用 $FF expression 会让 seed 每 frame 改变，从而让 bulbs 产生 animation。",
      "ascii_letters": 58,
      "cjk_chars": 22
    },
    {
      "item_id": "2a32e6b014:38",
      "text": "朝向比率参数（Facing Ratio）",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "2a32e6b014:39",
      "text": "允许你控制 bulbs 的 facing ratio。",
      "ascii_letters": 16,
      "cjk_chars": 6
    },
    {
      "item_id": "2a32e6b014:40",
      "text": "Letter - S - Fairground Bulbs（字母 S 的游乐场灯泡）",
      "ascii_letters": 23,
      "cjk_chars": 8
    },
    {
      "item_id": "2a32e6b014:41",
      "text": "这个 wrangler 允许我们控制 glass fairground bulbs 内部 tiny sphere light 的 intensity 和 color values。",
      "ascii_letters": 63,
      "cjk_chars": 12
    },
    {
      "item_id": "2a32e6b014:42",
      "text": "同样，创建这一组 parameters。",
      "ascii_letters": 10,
      "cjk_chars": 7
    },
    {
      "item_id": "2a32e6b014:45",
      "text": "通过这一组 wrangles，我们可以随机闪烁并控制 meshlights、Glow intensity，以及 PxrSurface 和 analytic USD lights 的 color。",
      "ascii_letters": 63,
      "cjk_chars": 20
    },
    {
      "item_id": "2a32e6b014:46",
      "text": "如果你的 scenes 需要创建 lights 和 shaders 的 randomisation，可以自由使用这些 code snippets。",
      "ascii_letters": 44,
      "cjk_chars": 18
    }
  ],
