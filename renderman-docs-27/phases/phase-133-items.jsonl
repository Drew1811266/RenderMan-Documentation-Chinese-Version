{"id": "1fec5729787618070e76085994ba37d31e209df95b11540351627ab011498d63", "item_id": "3456605a4f:0", "text": "This pattern is intended to be used with homogeneous volumes and provides a simple way to create volume falloff effects."}
{"id": "6fe0661c82d10d34d342a2db6cf48e6903215f3e296d0dc8038ab44fcb48a0ce", "item_id": "3456605a4f:1", "text": "Radius"}
{"id": "47d0c7c603b717061564dbf1700f0846afefdf01f69c64f459b75b9cf5c0c37c", "item_id": "3456605a4f:2", "text": "The radius of the gradient"}
{"id": "34918c7e3b40652acc13a03f706ab9afa94851cb29ab5165423ccda7d2bc2279", "item_id": "3456605a4f:4", "text": "The maximum density of the gradient"}
{"id": "bb2e0909268033a9ace6df98ab24849d44ccbd11c66e054625f62b8b3ecf74ea", "item_id": "3456605a4f:5", "text": "Exponent"}
{"id": "ea87d1176f34e28e42ce1d45898249630bd603ce88cca7b8fe2343153f811ed7", "item_id": "3456605a4f:6", "text": "Controls the shape of the transition from max to min density"}
{"id": "e4bb9f1ece9af9264a3b9e3913bbdb2cf497457167b14ced5f85688bfde74644", "item_id": "3456605a4f:7", "text": "Start"}
{"id": "954a412ff613dc5ff3925946b565541fd332e422bbcd843ed11a55fc0970eca2", "item_id": "3456605a4f:8", "text": "The start position of the gradient. 0 is the center"}
{"id": "cae7d57bc067a514b8e34c9589631a95c7dc051638ddd2a190773269279a99df", "item_id": "3456605a4f:9", "text": "Stop"}
{"id": "f6006b36e37350235f2368ab86995400e340edbfc3f4c8f2188b2c4ca7312357", "item_id": "3456605a4f:10", "text": "The stop position of the gradient.  1 is the edge  / radius"}
{"id": "b514ebf73921fea11670ca9640e96c27bc4e980867839d368eca5bd872bd174f", "item_id": "3456605a4f:11", "text": "Coordinate System"}
{"id": "ed3b1d3db0fbc010530b307637403144ff5a274e803a798eff9323f5681ef458", "item_id": "3456605a4f:12", "text": "Default to the center of your object's bounding box"}
