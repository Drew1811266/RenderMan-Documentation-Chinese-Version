      "cjk_chars": 41
    },
    {
      "item_id": "34f70bdcf7:145",
      "text": "该 job 所有 command 中最高的 command id，包括 detached task 中的 command。engine 使用它管理从 expand task 新创建的 command 的 command id 分配。",
      "ascii_letters": 70,
      "cjk_chars": 24
    },
