{"id": "046a6e3b3be4bf5c0d97d3b86ab62523c7369b8c81508274b5ba1fa6c0033cfc", "item_id": "24ffd9e7e8:0", "text": "RenderMan has the possibility to modify the contents of an existing Alembic archive as its contents is delivered to the renderer."}
{"id": "9c2a2d6e3a0ce62378f4e3feacdd87cde0f69b380f05ac4c9fe7b479ddb79635", "item_id": "24ffd9e7e8:1", "text": "Supported edits"}
{"id": "74430b7eeabe39d5d542484b765d0a519104d2ad38f50a8d1aef699f43bba26a", "item_id": "24ffd9e7e8:2", "text": "Convert a polygonal mesh to a subdivision surface."}
{"id": "4517e8324b36a3749dc914398d68228c413bff458d8b345461bb6765f118d107", "item_id": "24ffd9e7e8:3", "text": "Convert a subdivision surface to a polygonal mesh."}
{"id": "0474f00a69a3a7883967ee819b351f6c8fee4656ebd991ae1f7d310a10ade9ab", "item_id": "24ffd9e7e8:4", "text": "Set the mesh normals to fully smooth or fully hard."}
{"id": "c858c7973676d2cb8d3f327bd76366ae95a3a0e2c0528cc4a214c816262c634d", "item_id": "24ffd9e7e8:5", "text": "Set or override the following subdivision surface properties:"}
{"id": "312969445b15f065c865117f110aedf26d09347bdcde28de82e27020478e3d00", "item_id": "24ffd9e7e8:6", "text": "basis: catmull-clark, loop or bilinear."}
{"id": "d6d3ffd10461c21fed41ee66b5fdb8e232f186857e144efbfde0dcdadc4b7b81", "item_id": "24ffd9e7e8:7", "text": "interpolate boundary."}
{"id": "b916a684cd2fd49920a3ca21a2db54f08fdacbc7b04d549eec0285504a070e92", "item_id": "24ffd9e7e8:8", "text": "Hide (do not emit) any primitive."}
{"id": "0f4329bb4a3eae299f62143a2ef5bca7e0e3efc446cffbe61343c6da19822bf5", "item_id": "24ffd9e7e8:9", "text": "The Shape editor"}
{"id": "c96b4f3364d1870ec0f854ce9f664eb79c42540dedc1a9faf295dcaec6ee4191", "item_id": "24ffd9e7e8:10", "text": "Click the"}
{"id": "c6b673c94987a448f0e03fc176d334ed251c38435b17ac4140eccf0e42e2344b", "item_id": "24ffd9e7e8:11", "text": "Edit Objects"}
{"id": "4c924f2ead50febec75a46a11cfae32fe7556d85e5478ece188ba6b7591f1cc2", "item_id": "24ffd9e7e8:12", "text": "button to open the editor."}
{"id": "2fb45454f76db5795cbb83aeab17a1d0d406f552c560c9e501a2f43cc2b8eab9", "item_id": "24ffd9e7e8:13", "text": "The shape editor uses the same logic as the RLF Editor: create rules to modify any nodes matched by an expression."}
{"id": "51b648046975d622625d9c73bcc2a4bf588dec5f54003b90f953732049fb9d33", "item_id": "24ffd9e7e8:14", "text": "Shape Edits"}
{"id": "36f727ce4136bceda2e78158169e046b83acd8cff9f9528aeba49e7bcb28ebd0", "item_id": "24ffd9e7e8:15", "text": "To create an edit, right-click in the edit field (teapot icon) and select the required options. The edit will appear in the field in plain English."}
{"id": "685c48f95dd0f868427d39b2c76dc9854ba01d1a1b7c4e776c3d44cdf75a4cd4", "item_id": "24ffd9e7e8:16", "text": "Relaunch the render to see your changes."}
{"id": "d15c1af7adb4f044cb586c96462116fd396f4848aae32587fcdca723d41c703b", "item_id": "24ffd9e7e8:17", "text": "When a parameter is set to default, it means that it will be omitted and the renderer's default value will be used. Some defaults may change based on your rendermn.ini settings. See docs for more details."}
{"id": "09403682969c8260e1656bf3cf34320cf13a421f24046685de6e384939f09f72", "item_id": "24ffd9e7e8:18", "text": "Match Type"}
{"id": "cac6c052618218859e9487b700c9a3e22ef6f23546647244ba43be0cde85d04a", "item_id": "24ffd9e7e8:19", "text": "There are 3 matching engines:"}
{"id": "fa79d4746c21cd960a17b92db8976ddef95a7e20b590721f8e0fa7847a05e486", "item_id": "24ffd9e7e8:20", "text": "exact"}
{"id": "f3d0a2552bb3a78e38b8da57d490f485b1ca5779f593661ee025f5f6bfb4c6d4", "item_id": "24ffd9e7e8:21", "text": ": this is the fastest and will only match a full path."}
{"id": "28c2dec15a9bd200bf93582445f1b3657c47ce68a7a50bd4acb6d8cdd88c6294", "item_id": "24ffd9e7e8:22", "text": "glob"}
{"id": "50ba504f3dd3f8fd41e13f162bb8f7aa6879e94767c7b732d9ec6e8452546325", "item_id": "24ffd9e7e8:23", "text": ": based on glob matching with the following tokens:"}
{"id": "dc47334e3f71b6369093aab05a9a6374659068514f9cd1606b331274f87667f3", "item_id": "24ffd9e7e8:24", "text": "* : any number of character"}
{"id": "4e42b87037f3d28605e96471accca54cc1cc5cc0b8eeff745b3e7c8d195a7376", "item_id": "24ffd9e7e8:25", "text": "? : a single character"}
{"id": "7ab7967d359033619271e6b7282b33a0c10ed812a4a0c3571a5d0483a6023fce", "item_id": "24ffd9e7e8:26", "text": "** : any depth in the hierarchy"}
{"id": "3ac1ecbd2220c6757eb9f289fee88c4068c6791c5b0affef7644e77adfc97b45", "item_id": "24ffd9e7e8:27", "text": "re"}
{"id": "d8f3c4be1310cf4a42c5f905177abfcedfe202d22ed8a09e1e5390bb95681cfb", "item_id": "24ffd9e7e8:29", "text": "re2"}
{"id": "6bf410059c78e2b69f340f70eadfb69acbfa0f55b197160b5385e5d75335716d", "item_id": "24ffd9e7e8:30", "text": "regular expression. The most sophisticated, complex and potentially slow matching method."}
{"id": "a7cebd5c9899ef12d2a57a473c35eca9b29b43e8fe8481abf05382731cab740a", "item_id": "24ffd9e7e8:31", "text": "Rules are evaluated in the editor's order."}
{"id": "da7f9c9f346a287d7cbd38647616ac41ff3486d8985a00a373e9fad098d88347", "item_id": "24ffd9e7e8:32", "text": "Because matching can be slow in large archives, the first matching rule will win and stop the process."}
{"id": "f88cc7d99a0b52a4b2824a68292c5aae122c66aed16de1a883de9b746e46813e", "item_id": "24ffd9e7e8:33", "text": "Path Expression"}
{"id": "e4d73984e9a8f3d918274870c9430acb76fd2ef8f564b59cc331761910f8c542", "item_id": "24ffd9e7e8:34", "text": "You can either double-click in the field to type your expression or drag and drop from the alembic node list."}
{"id": "76084c25e54698c802c574eba23b51f5c5cb03de00eeb1ece7f8b1d0cea60c80", "item_id": "24ffd9e7e8:35", "text": "To drag and drop, you must first select the node in the alembic node list."}
{"id": "d252559b015b48a03e9aed0d06a9a0c7ef287f8296bcac185fa0588a0bd5ebcb", "item_id": "24ffd9e7e8:36", "text": "Convert a mesh to a subdivision surface"}
{"id": "3c35c68bd053df5367f92b13030cf97a9fa4b47d6ed53fd45cbe21f825085bd9", "item_id": "24ffd9e7e8:37", "text": "The chosen subdivision basis and interpolate boundary settings will define the shape's look."}
{"id": "d30ca7a7a32bf5772dc5eb2a2e7bd35737eff795ad74f2479b359716b59abdfa", "item_id": "24ffd9e7e8:38", "text": "mesh"}
{"id": "3fa87c4f2e3153eea49f4fdb7cbb80203e462d2fdbaf2c2766986e465c974c6a", "item_id": "24ffd9e7e8:39", "text": "catmull-clark"}
{"id": "254637f72efcddb6a545bccbd0c3bb84e6393647deb5fd344de6584ccc1e743c", "item_id": "24ffd9e7e8:40", "text": "loop"}
{"id": "2647784c9df98b4631d887abf145d46d4b22b177b55675dc47e6dafe619a601a", "item_id": "24ffd9e7e8:41", "text": "bilinear"}
{"id": "0fcba107d0ea511673ac752bef8352a9444cb07261879be40caeb844c2341043", "item_id": "24ffd9e7e8:45", "text": "Interpolate"}
{"id": "fcf4b1a7548cea9954f3512bb8d45940d0555a8dd079b6e251ad419b467c7688", "item_id": "24ffd9e7e8:46", "text": "Boundary"}
{"id": "b4dc66dde806261bdda8607d8707aa727d308cd80272381a5583f63899918467", "item_id": "24ffd9e7e8:44", "text": "off"}
{"id": "e8a01133b1351e5fa434167135400d1998d3daa8ce74e3dd9bb57582fa4d7b97", "item_id": "24ffd9e7e8:47", "text": "ON"}
{"id": "ff1907f1c0fbcb12eae7b2565bd5d88776fe73056f9963d4184781a4d67b22fd", "item_id": "24ffd9e7e8:48", "text": "Convert a subdivision surface to a polygonal mesh"}
{"id": "bb6325896ce70fb37098c92bfbfcd7c8eb920aab1809bfd82207e36c31fd7d7b", "item_id": "24ffd9e7e8:49", "text": "Subdivision surfaces typically don't have normals because they are automatically computed from the surface. When you convert them to polygons, you take the subdiv's control mesh and turn it into a poly mesh. By default, RenderMan will detect the absence of normals and create smooth normal (this default can be changed in rendermn.ini). But you can force a hard-normals render too."}
{"id": "c4d7625e23ca093941a963a2a551040f64ec7f06b5eeae82c911bed9bf33ff95", "item_id": "24ffd9e7e8:50", "text": "subdiv"}
{"id": "d5e65fb4bf7179edd299bad24617d4c65a06b6c86684342815aaca2a2ce3bec5", "item_id": "24ffd9e7e8:51", "text": "polymesh smooth"}
{"id": "32998e48511a407827ff10e8b8ac5c0c12d0c18f6bb754a510b50151ca959e31", "item_id": "24ffd9e7e8:52", "text": "polymesh hard"}
