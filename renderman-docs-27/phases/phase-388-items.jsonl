{"id": "f60f1d1c8a9ba017b65b062c1704b4f4a12732f48411ace1c9e971fd74da45d1", "item_id": "ff208ff64e:0", "text": "Welcome to RenderMan for Houdini"}
{"id": "7e043848ae8027578354da18b6d559414b46f9bed837abbbfe7c2fa07a800ca4", "item_id": "ff208ff64e:1", "text": "RenderMan for Houdini (RfH) continues to provide full support for the latest RenderMan.  See the"}
{"id": "41eae64542eb6f74579ba5e27546d8cdd02d5bcdd620acbcb7df15d4963f0bc1", "item_id": "ff208ff64e:2", "text": "RenderMan Release Notes"}
{"id": "1db5bfcfb43e6e705bbea63db8048365b81c341a1b0ed35e06502b867a8bf2c7", "item_id": "ff208ff64e:3", "text": "for more details."}
{"id": "9f2a0f5e1ab903c340004c1c2626e76e044fe71ef6b15648ca0d4eed4d953279", "item_id": "ff208ff64e:4", "text": "This current release offers support for:"}
{"id": "c3025640f6540d3331924b8b70ccedbf7c60ce9f84b8ac64d737b3d8c4c81d0c", "item_id": "ff208ff64e:5", "text": "Houdini 21.0"}
{"id": "af69f81b4b810db59448c5919742f110df5895d67d572a68ecab4ce887bd778e", "item_id": "ff208ff64e:6", "text": "Houdini 20.5"}
{"id": "ffd8242719ebd2e096f11d8a61ac10dd8ac639b9b1f7ab29ece544c93ed80048", "item_id": "ff208ff64e:7", "text": "Houdini 20.0"}
{"id": "c1c9d2cd2f8c10e3da43701f19fe3ac246c6ae1e7ef1b92ba4566cc9074a05c9", "item_id": "ff208ff64e:8", "text": "Please see the release notes below for all the new capabilities and known issues.  See the"}
{"id": "0a0ebfc01c3c7a39415426acdddcb870766fc4a13ea3e71ee42f18633e179757", "item_id": "ff208ff64e:9", "text": "Installation of RenderMan for Houdini"}
{"id": "13ed51909797f05ea0290912defd3c5779fae66aa8cfd45a0de70e24bc1a0bbb", "item_id": "ff208ff64e:10", "text": "page for the list of specific production builds RfH works with."}
{"id": "b1336ccb08e524cc4d79fee625d3a9bdac9ffe31330cd22ef6a82a9db18a53a7", "item_id": "ff208ff64e:11", "text": "Rendering with RenderMan will not operate on Houdini Apprentice editions. See SideFX's website for options that allow Third Party Rendering"}
{"id": "0ddc89a547b680db1cc1c539db9e03ff23f7fea8700f6f68e6c94c5a94f33132", "item_id": "ff208ff64e:12", "text": "Known Limitations"}
{"id": "98dc766e32c38c402a4f8943d7a37e3adb8e1bb7ca722a1e66fe93275a8bc1b4", "item_id": "ff208ff64e:13", "text": "Solaris"}
{"id": "c9812af07428b83e0038f8dca5226b1258dbac3992e47f74a27f24cd935535ae", "item_id": "ff208ff64e:14", "text": "Due to a SideFx limitation, there are some shading network circumstances where the visualizer node doesn't solo networks correctly"}
{"id": "7c18b2214d97ef7458b3ebb76731e758dfc77c1c5b2f254e019754aa848d2b67", "item_id": "ff208ff64e:15", "text": "MaterialX Lama"}
{"id": "8395d532406dc736a16fd8f8d16b612bb6811c1942c8fcddbd997ea8fb5a5dd2", "item_id": "ff208ff64e:16", "text": "Soloing complex MaterialX Lama shading networks."}
{"id": "e07f746a83558316a75836737cc6be183e237ea3a06abb213821495e819b5be2", "item_id": "ff208ff64e:17", "text": "XPU"}
{"id": "cb235046e5a9e64b56a64b822c005d6ced3f48c25b9cb3a7cde2084541c09470", "item_id": "ff208ff64e:18", "text": "CUDA device is saved in the scene rather than as a preference."}
{"id": "c910d474dcd724bff83ddedeb06bf1eceaf9fb3af7c76bb282be057f36e6dffa", "item_id": "ff208ff64e:19", "text": "General"}
{"id": "ec85355dfc5b5228ff94434356aa29798ead567a295c24dc259a7b3aa1a1fcdd", "item_id": "ff208ff64e:20", "text": "Rendering to IT with ACES currently needs the env variable"}
{"id": "84324b2cf5b2ab6b70305c9a78918e7b7d82c2883372612191d7ed6d23f38f13", "item_id": "ff208ff64e:21", "text": "IT_OCIOV1"}
{"id": "d08431b4e5807c7777beb67c521900f9a62e1ee3417eddb8b00d3189cae34074", "item_id": "ff208ff64e:22", "text": "to be set to your ACES config.ocio"}
{"id": "92701db73636a1c774919f7bd73ad2ae6ff221d58a9f7c9df1ae6cdba8ad2ed8", "item_id": "ff208ff64e:23", "text": "Render with Takes is not supported."}
{"id": "925efa7ee82f4d137e2be5d1132fa69f3887dc9ea7b9b6383d822f6339bb4834", "item_id": "ff208ff64e:24", "text": "Rendering with Mantra lights or VOPs is not possible"}
{"id": "7fa3d4c733d2763882b161cf081bd7d7e45e96bdbc182e3a736391821d229c35", "item_id": "ff208ff64e:25", "text": "Bypassing shader nodes"}
{"id": "158f308493325ad67c065bc5784cc6328e566296051a5b759e2b30810f148c94", "item_id": "ff208ff64e:26", "text": "Auto camera creation for IPR"}
{"id": "089983d58381f6fa6cecc95d13e20b1fbbe9dc735df8bd32ce6681dca54b5725", "item_id": "ff208ff64e:27", "text": "RenderMan clipping planes"}
{"id": "b859e2f550cfafc465c9ce4906745fa105be62458bb995ba490cd4d3f9dce0b0", "item_id": "ff208ff64e:28", "text": "Display edits cannot changed from the image tool to mplay"}
{"id": "aa4a41639bd334cb59f278a574422f79e17831a26c7906b2347dfe92d70a925a", "item_id": "ff208ff64e:29", "text": "Cross-frame denoising PDG support."}
{"id": "fdc08abc03c351157340652dcdda270f59206720e8892c331af96df19001f304", "item_id": "ff208ff64e:30", "text": "Applying undo of deleted nodes or collapsing to subnet may not work as expected"}
{"id": "6f4e37c906bb87dbbc4e15a8ad5eed19700a9a170dafa3d1c2d425aaa7642412", "item_id": "ff208ff64e:31", "text": "Rewiring subnet indirect inputs"}
{"id": "34385f8d737e62cb4d55db65b4cad92931ff1f7111313d6a4b30e56861385347", "item_id": "ff208ff64e:32", "text": "Inside Out 2 © Disney/Pixar"}
