{"id": "6d89eb7d0938564938636b4a5ee73c09e55c2e6e5aaa9e3016781bf54805e8d3", "item_id": "265ece5759:0", "text": "Render"}
{"id": "3e42e385075b9b569620eb6d652cff77b19eab567ee2927d6e1bf901f51d8246", "item_id": "265ece5759:1", "text": "Threads"}
{"id": "dfbdf94f0fbb18d153964d204020fa0b2357cf93634052ade42c4d24452cb3bf", "item_id": "265ece5759:2", "text": "Rendering Threads"}
{"id": "ebd9ce203d2d518ad281c1024ac96ed32f432919c8d263292d63a6a8d13a4a01", "item_id": "265ece5759:3", "text": "The number of threads to use for preview or IPR renders. A value of 0 indicates that all processors will be used. Negative values indicate all processors minus the specified number will be used. The default of -2 allows the user interface to remain responsive during continuous rendering."}
{"id": "8279c687425829f88fca3827af3d7d4174648f28caa923dffe2cfa8ce23d2699", "item_id": "265ece5759:4", "text": "Batch Threads"}
{"id": "5ce1ac4c536a3612bb38d398ee2eae26818951b0d22d5086b005b61b801b4c67", "item_id": "265ece5759:5", "text": "The number of threads to use for batch renders."}
{"id": "027893b8b7ed8db150123f62399f1e4bc5b7022cc8252b05ca8748b0e610f469", "item_id": "265ece5759:6", "text": "IPR Display"}
{"id": "8520f0c9e60355619163772a9ef67eafd897969a6ccea32a6538db10344d2fdf", "item_id": "265ece5759:7", "text": "Render To"}
{"id": "01dad13ba79c0a00010f38350efc34ea0a7c86552c6b66782f25766c29572455", "item_id": "265ece5759:8", "text": "The display to use for IPR renders. Choose \"It\" or Render View."}
{"id": "c833cb13ae6824440a0bf934cc75285406f61563ce5e524d1d76852dcb2d35a9", "item_id": "265ece5759:9", "text": "Output AOVs"}
{"id": "aa74e2577d481204800c5e8afd2cdc6eb0cb1c13f59778011c8abb446a31add5", "item_id": "265ece5759:10", "text": "Write out AOVs/LPE during interactive sessions. This is off by default to improve performance."}
{"id": "a5271d4fd1a1ac125460b8318dd54a198d1d6a526a898edd5497c3d28260a787", "item_id": "265ece5759:11", "text": "Prune Invisible Nodes"}
{"id": "94abb85054d319d85b1ca39de06006005927545eb9a0a711627c859117efef98", "item_id": "265ece5759:12", "text": "During IPR we only prune templated nodes, allowing other objects to be interactively hidden/unhidden. However, to save translation time you can tell RfM to also prune hidden nodes during IPR."}
{"id": "9ae1e953ace4209cc896c5b2bf52118496d74e3d4b8f470a8eed2412663757df", "item_id": "265ece5759:13", "text": "Batch Render"}
{"id": "81a427d435a5a3457b2968c3ff9e56a62fb7be5ba637d2441627c6dbeb87cfcc", "item_id": "265ece5759:14", "text": "Chose between LocalQueue and"}
{"id": "b797c4277fd8a0d29bf8ac18d51a36bf823ae9c07e0d4c40a6e5ae317667efd1", "item_id": "265ece5759:30", "text": "Tractor"}
{"id": "01fda40b5f826bbec137b9bb166495a52da979f4f5a31455dc3c74ace5c4db1b", "item_id": "265ece5759:16", "text": ". There is a separate section below for Tractor queuing settings."}
{"id": "7f43cf280277a14167a5a80fc28b0006ea2504f489257b81b735972c135b364b", "item_id": "265ece5759:17", "text": "Spool To"}
{"id": "7329c3e784ad36de9e03c66433acf0b5567b7a56ae17afa391713deb6719774c", "item_id": "265ece5759:18", "text": "Choose LocalQueue or Tractor"}
{"id": "c6fee0242e194dee81f432716081adadecf46393136f8185fc91f4fe2aaa445d", "item_id": "265ece5759:19", "text": "Spool Style"}
{"id": "d590cf961e0d91b8365ca3e197c1049c27ac403ce0a7a6f30244cec018164a16", "item_id": "265ece5759:20", "text": "Render from Maya Batch immediately, or generate RIB files locally for distribution to farm nodes."}
{"id": "fd8add6adfa5977f135c123bdfc7ef3b6317ff50415c3a9ba57112d3b9d02d99", "item_id": "265ece5759:21", "text": "Frames Per Server"}
{"id": "684d03c4ab33b73cf4a618386050a6770969c4734e342224e00d7ba1df935e03", "item_id": "265ece5759:22", "text": "How many frames in a chunk/at a time in sequence on a remote server. The default is 5."}
{"id": "ee325afd9b4e907b3c521293ce4c841c990f124a10192bcba8ec7cc6bf005090", "item_id": "265ece5759:23", "text": "Checkpoint"}
{"id": "38831731063358ffd6c381aa2d923ddb1227a81b82c1a4000dbaf9efabb2ea6d", "item_id": "265ece5759:24", "text": "Use checkpointing in a batch render, choosing the number of minutes or iterations before a checkpoint is written. You can control this option using the same syntax found in the Checkpointing Document under"}
{"id": "cfdd428fbed7718bfbd60cfb882eabd3a228e880f3f38d394646abd6640a0a99", "item_id": "265ece5759:25", "text": "\"How to Specify\""}
{"id": "e3fc8048e4be5c428b7214618bf02a98dacf7bf16804db472c2b0aa558ba3abf", "item_id": "265ece5759:26", "text": ". You may specify anything from individual render increments to seconds, minutes, hours, and days. As well as specify an exit time after a checkpoint time or an exit alone without the checkpointing at a given time. The help text popup over the field provides examples, such as:"}
{"id": "0a26f5620c3fafd3c93f1c3a0f0d5d9f3c29a72dba9c17f7a7dfedde315c4185", "item_id": "265ece5759:27", "text": "says create a checkpoint every 5 minutes and exit at 1hour, writing the final result."}
{"id": "d6ca8e0b75e55d5d2af294003d9d4418e969a86bbea965d0b49e70b716ef9ac4", "item_id": "265ece5759:28", "text": "Launch Denoiser"}
{"id": "2d8bc7a9cd759c3d15a6570deb6a672eb9ae7092391190229ea127206c1d7264", "item_id": "265ece5759:29", "text": "If deselected, the denoise operation will not launch, you can run the denoiser tool after the image is written manually. Note the display driver in the render settings must be set for denoising."}
{"id": "d1e4a7318ceee970e82e3b625ff5edbff3b8925cfe3e933b3d3d2d5967af7197", "item_id": "265ece5759:31", "text": "Remote queuing settings only apply to Tractor, for LocalQueue all settings are applied locally."}
{"id": "86dc8e99cda00b7b3fff38c370c73fa6d69c955d41ce36e07015600abbe74217", "item_id": "265ece5759:32", "text": "Start Paused"}
{"id": "51675d6df82ac178094953ba93d15df8a33bc197fdacb4fad0d3db5ea7e482bf", "item_id": "265ece5759:33", "text": "Send the job to Tractor but do not begin the job immediately. Requires manual or scripted start."}
{"id": "d60dbba079223254d4c49c230a515bc107a997e69f811365da2387f8557b9cec", "item_id": "265ece5759:34", "text": "Priority"}
{"id": "1de650a35879d41a78eaf936a5a00765bf0329ddc033fd009f20af62cfb250ef", "item_id": "265ece5759:35", "text": "This affects how active jobs are assigned to remote servers. It doesn't affect position in the dispatcher queue."}
{"id": "d677190e0a9990e7d5fa9e4c1bbde44271fb8959c4acb6d43e02ed991128b4bf", "item_id": "265ece5759:36", "text": "Service"}
{"id": "1e657ebb0fd60c8887fc84f3b1005f5d771ba433a5f121d7abb90142e1d1e81a", "item_id": "265ece5759:37", "text": "Additional service selectors for the job"}
{"id": "0a4679ac1177b0e9bdd1cd17fdf93eb6ef15bb8ecbd7d1d63f342c74946d216d", "item_id": "265ece5759:38", "text": "Env Keys"}
{"id": "4a456b78959ba17f54f6c627bf22ef9d1ab5919c0a6a5ab07584add95d4fff62", "item_id": "265ece5759:39", "text": "Switch between preset configurations. The JSON pref called DefaultEnvKey specifies the default value seen here. Multiple keys can be specified and should be space separated."}
{"id": "fa12e8e1caf464883d3e0630a31fbd5cbda889defc73243bde5b9f90430c1657", "item_id": "265ece5759:40", "text": "These environment keys are recognized by LocalQueue and Tractor:"}
{"id": "0d0b4cd6da15265cd2c392db66d36632adadb77dd1691c5a364151167762aed8", "item_id": "265ece5759:41", "text": "rfm-*"}
{"id": "468f1ffdf8dc9aec1d7a15cb75d3d2d35b1ecdc4904ad3a7249a8b472bb5a042", "item_id": "265ece5759:42", "text": "(eg. rfm-22.0)"}
{"id": "b5dd135c8603ade06da47eade842a78785463ff40fbbed6c826972485c9b7b6b", "item_id": "265ece5759:43", "text": "maya-*"}
{"id": "ac039330429550dd80efeb7a6a6453d330e05ff61302a1f7b1eaf57d37fb8d3d", "item_id": "265ece5759:44", "text": "(eg. maya-2017)"}
{"id": "4b6f318e4bf3882eda670a699342d02dcff9e48e5059f4d7678c274fe5c7f47a", "item_id": "265ece5759:45", "text": "rmantree=*"}
{"id": "840f4d18df9f4b81f5293f159622e5029ae706346af6e6ddf09d2aaebb9cc478", "item_id": "265ece5759:46", "text": "(eg. rmantree=$RMANTREE)"}
{"id": "c2b4105c61d8257d8f41b3f49f441acd38ba630b20944987259998f0321f03b6", "item_id": "265ece5759:47", "text": "rfmtree=*"}
{"id": "6c94922d81f579d144927ada447931151fa67e049fbc17d0d0d84e8d2049c1b5", "item_id": "265ece5759:48", "text": "(eg. rfmtree=$RFMTREE)"}
{"id": "1e307119245199bd4d539ba26eb8975cff3cecc432ef30e13faf619fd4ba9a11", "item_id": "265ece5759:50", "text": "Begin job processing after this date and time. Novemebr 24th at 1:45pm would be example: 11/24 13:45"}
{"id": "c1f4e23e514e1afba0ed7746b72053757d252f5ae10bb788c476aa42ad25149a", "item_id": "265ece5759:51", "text": "Crews"}
{"id": "c88342be741102621eb5dfb24561b33adb9d794c661f32781836da2a8c12559d", "item_id": "265ece5759:52", "text": "Specifies the list of crews to be used when determining remote server access."}
{"id": "cb9e8664edea8cf5965fb4d4d013974ef10caeaad734702b19617210828cd7ab", "item_id": "265ece5759:53", "text": "Tier"}
{"id": "2c370bb8f501420343e161b3940d3bd5012c610b54758e60cb1d3fb24773c6a0", "item_id": "265ece5759:55", "text": "Scheduling Modes"}
{"id": "8bf344c0d82b1a8981be95baebb75479dbdd9c9e15c5910dd29e8a039b0ac884", "item_id": "265ece5759:60", "text": "in Tractor"}
{"id": "04e2a9728af7584043c5d58ae29e7cd811883e8dab15fc6287675270669a3ada", "item_id": "265ece5759:57", "text": "Projects"}
{"id": "a9f1a8d3bf87f3ba7cba284f7af61283ca469a88095a61cc1d5ad058a1991d62", "item_id": "265ece5759:59", "text": "Limits Configuration"}
{"id": "355f79f29d7d3c2df917ad07f7441e3ce4b0ac48892b778076dbdca401851712", "item_id": "265ece5759:61", "text": "Comments"}
{"id": "bcb2651f5f7cd088d18b2b2afaca4ff3c215e373063cb8b1eef93705eb75cf8c", "item_id": "265ece5759:62", "text": "Additional job comments from the user"}
{"id": "9eddf573cb509f1f62df633e25c052ac1b2a0ff9241e70223c77c73e834c0045", "item_id": "265ece5759:63", "text": "Metadata"}
{"id": "2cdc0194f11a78a7dbe616ff5afddb1f9a314b615894a18912d196c2db3a9cbc", "item_id": "265ece5759:64", "text": "Data added to the job for your pipeline processing."}
{"id": "ccbc80079f0506a09187d4e79cd9260723dc91a36a35789b7d5dfbe574592f7a", "item_id": "265ece5759:65", "text": "When Done"}
{"id": "6a0b514e57b60477cc35db44c6fe955a788f2adbd4d63dd5ef438216f5894448", "item_id": "265ece5759:66", "text": "A command that should be executed when the job is finished"}
{"id": "d168e1a590709f5550ef3064345b0162b9f69f48d1b3edc6bb1387773a884adb", "item_id": "265ece5759:67", "text": "Example: /usr/sbin/Mail -s 'Job done: %j' %u < %f (%j = job title, %t = task title, %u = user, %f = temporary status file)"}
{"id": "56b02fed6b750ff8b53f92119f49988a69eedd2ae25724a1fcb7ea0dcf4d1ba9", "item_id": "265ece5759:68", "text": "When Error"}
{"id": "f13418b4131530d986e15a569220ac021492d96b48d41e8fb0ec552a5bcaba58", "item_id": "265ece5759:69", "text": "A command that should be executed if the job had an error"}
{"id": "f73b6650ce95a937803c0ea84ecec0b03f44038d0fc7eb666ed8ee3db25f0668", "item_id": "265ece5759:73", "text": "Example: /usr/sbin/Mail -s 'Job error: %j' %u < %f (%j = job title, %t = task title, %u = user, %f = temporary status file)"}
{"id": "b13aec42e1676272d3d54e65e429908f832990b582fbbc17ed8f9ad16dd7a62f", "item_id": "265ece5759:71", "text": "When Always"}
{"id": "8f88f5ea2c1840e0db448730ae8534203222f679756e099ef99918d766184f36", "item_id": "265ece5759:72", "text": "A command that should be executed regardless of job error status"}
{"id": "e07f746a83558316a75836737cc6be183e237ea3a06abb213821495e819b5be2", "item_id": "265ece5759:74", "text": "XPU"}
{"id": "d2bd9cb5e2e3d27fe192661cf6c0b9f5c77d65e03a4fd2810e75ed0eff2cad8a", "item_id": "265ece5759:75", "text": "Choose devices to be used by used XPU"}
{"id": "ec83c6ad191cfd06bd60e2de67611d7d253276d23b688761fe69baa7e3a4f5f6", "item_id": "265ece5759:76", "text": "Texture Manager"}
{"id": "b4f9720da2ea808733b000d0595b6065a04bdc04e85ad4a250c528c28f3bd7b8", "item_id": "265ece5759:77", "text": "Number of Processes"}
{"id": "1e044ee4878781826b93111ee3dd072a5ea7c039466dd1a3ea930c53f426d4b3", "item_id": "265ece5759:78", "text": "The number of parallel processes txmake uses to process texture files. The default is 2. We suggest leaving the default unless you have more than 8 physical cores available on your CPU configuration."}
{"id": "9e36bc025e5505a424842c9c7a87b6676f84e78cc865a8c6ed9458f32ac0a7b5", "item_id": "265ece5759:79", "text": "Fallback Texture Path"}
{"id": "e27c315c503ba688885b54ca378cbd6248d3981bf53b7631a26cc61288ac71ed", "item_id": "265ece5759:80", "text": "By default we write .tex files to the Images project directory. If this fails (it doesn't exist or there are permissions issues) use the specified folder here. Do not use spaces or diacritics in your path text."}
{"id": "1b61928ff29758ba9d161c58f693d84616c7e35dde0f90e7454a7da0f4c7448b", "item_id": "265ece5759:81", "text": "Show Advanced Options"}
{"id": "d51f786a93d84297086b91eadc2f467e87deff8f0fb3f3a6ea73632814357726", "item_id": "265ece5759:82", "text": "Show more options for .tex conversion"}
{"id": "9c67dd99b73cb21e324dfce0d9987e48032a6cfe473fa34fbb13418b57b6b8a1", "item_id": "265ece5759:83", "text": "Texture Extensions"}
{"id": "639f1bf0610bd4a740fa54b8450094f2b251b3835910d8e460553c9840203539", "item_id": "265ece5759:84", "text": "The recognized file type extensions for textures"}
