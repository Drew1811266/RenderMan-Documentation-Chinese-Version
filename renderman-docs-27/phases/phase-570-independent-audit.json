    },
    {
      "item_id": "e4d3aee8c9:3",
      "text": "：Eugene Riecansky",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "e4d3aee8c9:4",
      "text": "我制作这张 image 是为了作为最新 RenderMan Art Challenge 的 launch teaser，并给自己从开始到完成三周时间。",
      "ascii_letters": 38,
      "cjk_chars": 27
    },
    {
      "item_id": "e4d3aee8c9:5",
      "text": "请欣赏这个 breakdown：从我如何提出最初的 story 和 concept，到 texturing、lighting，再到 compositing final render。",
      "ascii_letters": 60,
      "cjk_chars": 18
    },
    {
      "item_id": "e4d3aee8c9:6",
      "text": "Story, Story & Story（故事、故事，还是故事）",
      "ascii_letters": 15,
      "cjk_chars": 8
    },
    {
      "item_id": "e4d3aee8c9:8",
      "text": "Gathering References（收集参考资料）",
      "ascii_letters": 19,
      "cjk_chars": 6
    },
    {
      "item_id": "e4d3aee8c9:10",
      "text": "Making The Van（制作面包车）",
      "ascii_letters": 12,
      "cjk_chars": 5
    },
    {
      "item_id": "e4d3aee8c9:11",
      "text": "创建这个 UFO-hunting van character（UFO 猎手面包车角色）",
      "ascii_letters": 25,
      "cjk_chars": 11
    },
    {
      "item_id": "e4d3aee8c9:12",
      "text": "Texturing（纹理制作阶段）",
      "ascii_letters": 9,
      "cjk_chars": 6
    },
    {
      "item_id": "e4d3aee8c9:13",
      "text": "使用 textures 来强化 character 和 story",
      "ascii_letters": 22,
      "cjk_chars": 6
    },
    {
      "item_id": "e4d3aee8c9:14",
      "text": "USD Assets（USD 资产）",
      "ascii_letters": 12,
      "cjk_chars": 2
    },
    {
      "item_id": "e4d3aee8c9:17",
      "text": "USD + XPU 非常适合 layout 和 scene creation。",
      "ascii_letters": 25,
      "cjk_chars": 5
    },
    {
      "item_id": "e4d3aee8c9:19",
      "text": "Sky、UFO 和 van lighting 都是关键",
      "ascii_letters": 17,
      "cjk_chars": 5
    },
    {
