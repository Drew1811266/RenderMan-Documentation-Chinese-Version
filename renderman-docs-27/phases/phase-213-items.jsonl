{"id": "5e3dfb4fb4da9430108044fdee361d1590458b0f2d7b83c1e49ef09e6e47e1a1", "item_id": "f751883493:0", "text": "RenderMan for Blender can substitute a number of predefined tokens in string parameters."}
{"id": "63a9558ba3b3616a11293ea6739e2d236107e3906da324b9f88667d80f5e42a6", "item_id": "f751883493:1", "text": "They can be used for animated texture sequences, referencing specific storage locations, etc. Each token should be wrapped inside two angle brackets."}
{"id": "764de6f0e89afc70ddb4e08affe5a9eeb65d2966f291122dc1c8f4d194965419", "item_id": "f751883493:2", "text": "Below is a list of default tokens."}
{"id": "d2089be672953d1136faa84079af1b6f3967fed8932dabffba3032d30e3c0618", "item_id": "f751883493:3", "text": "Token"}
{"id": "1f5d64b92820f8238635b90ae69a38c12661a7b03c6d0d7f689711f12af7b7f9", "item_id": "f751883493:4", "text": "Meaning"}
{"id": "61414709a09ce5fc7b8ddeeb9aaf659ca9999953551b858a73cf742878506cf3", "item_id": "f751883493:5", "text": "<TEMP>"}
{"id": "d23e221c2c408f928ae104ce4cdef283d5b98e2fade1e808457204ad52c79421", "item_id": "f751883493:6", "text": "Temporary directory. On linux and macOS this is set to /tmp. On Windows, C:/tmp."}
{"id": "4b67c579936959cbac34893cab67e1f2dac9e22e64132e71728085e1134872b2", "item_id": "f751883493:7", "text": "<OUT>"}
{"id": "f39c3fc220eb01afe333b7a360afb09e328a42bda80aa3d70e631568b6c59f01", "item_id": "f751883493:8", "text": "The main root output directory for all generated files for the scene. Can be set in Workspace Editor."}
{"id": "5cd8f7c747be1d94026a70fedd5351a1f1a9cdfcfea0fe0678a0a606345e4a03", "item_id": "f751883493:9", "text": "<blend>"}
{"id": "25c703ae81fecf14c332d4370e16dc232f4d999e466ee7cf78df825a644df0b4", "item_id": "f751883493:10", "text": "The current blend filename. Set to UNTITLED if the current scene has not been saved."}
{"id": "b7ce0978068252b1d16af5ef98e10866c3a6a7f3f1467109aeadd99be033f358", "item_id": "f751883493:11", "text": "<blend_dir>"}
{"id": "3e51daff405c020b3ab3239dc028bc4a171f50b64d4f3d285007b42a8afe8702", "item_id": "f751883493:12", "text": "The directory where the current blend file is in."}
{"id": "dcbffe8bd88cf843b1717f9a0e2d51f7a83fcc028e7acdeb56aa35e6a7887067", "item_id": "f751883493:13", "text": "<scene>"}
{"id": "293d37613961656e224ddccec4e91bed217d506edc4665b632d4db2a04249168", "item_id": "f751883493:14", "text": "The name of the current scene being rendered."}
{"id": "2cfeceb94005e12c68cd0c5b733ded0c108685fe9dfa25d6ff089aa8685b4819", "item_id": "f751883493:15", "text": "<layer>"}
{"id": "02e8cff060dc846c600c2d85933c96e0cf98cb694223d31e46f24ee3ecd5dff2", "item_id": "f751883493:16", "text": "The current view layer being rendered"}
{"id": "3b6875920a36b444a9a8c7196087ec60fb5488744bb2234403227bf3bfa0e48b", "item_id": "f751883493:17", "text": "<aov>"}
{"id": "6751800f2b3cdc52e7f79a431fd7bc78a0a40ad3ec8347562d040a91c4b60ca4", "item_id": "f751883493:18", "text": "AOV name"}
{"id": "a1b0641066c89bd60eb5674c47cbdd7bc63c9abab46316a71f8ab0cedd09bde7", "item_id": "f751883493:19", "text": "<f4>"}
{"id": "bb972731c01e3739cfb50ffe8837bffcabcae4443806e92cc6292531966744b9", "item_id": "f751883493:20", "text": "Frame padding, 4 in this case, can be omitted for no padding or use lower numbers. Both capital and lowercased 'f' is recognized."}
{"id": "3d86ebe97130186c673df02b52d2f6fec0c676ae548cb5a92ebcbd87b9ba8e06", "item_id": "f751883493:21", "text": "<ext>"}
{"id": "26eafba06a73a8324431bc52a96223f68d91bcf332ae067a5b502e24a31565de", "item_id": "f751883493:22", "text": "File type extension"}
{"id": "d5a7c9c99679aea62d365254dcdbe63bb27f37c775cdb2ad6af8241ce201731b", "item_id": "f751883493:23", "text": "<file>"}
{"id": "6a7d6d9152a5a7834eb471f5b057055fdc6c8096afee92d9aa1ac9cba8245698", "item_id": "f751883493:24", "text": "This is the same as <blend> as above"}
{"id": "644675e584d12c440b4fba83b25ede56ef7d13d0a0999d1b19a7899d53cd80b2", "item_id": "f751883493:25", "text": "<version>"}
{"id": "99c5f19c5fa2fab9af8cd0450cad7dc46c55425f1a194d2a423067326ac02364", "item_id": "f751883493:26", "text": "Inserts the version number specified in the Workspace Editor"}
{"id": "ccb4e57cf6752637e4ecdca2068aea359ad13ecee71dad0adaa66ad50168f5d3", "item_id": "f751883493:27", "text": "<take>"}
{"id": "c8405319f3abc23cae93f2cda10545ca66bc3a1421be13f2b3e870a7d8b51338", "item_id": "f751883493:28", "text": "Inserts the take number specified in the Workspace Editor"}
{"id": "b2fae905cd7d2c75a03e83b51fe0544a300dbabcb343761ce224554cb3f54d68", "item_id": "f751883493:29", "text": "<date>"}
{"id": "88d4758c212fc3ed328a188df55e2c413f30ac6afa6aa37567310eeda7643276", "item_id": "f751883493:30", "text": "Current date"}
{"id": "44e11b133d51cc80851cf1e7c267e8226f210bfa7a827bb164501980ee9279b4", "item_id": "f751883493:31", "text": "<frame>"}
{"id": "197de756ca88eaee6e597fc9c8f7dda7f2fb39241e48eebb085dba13c8b32cbb", "item_id": "f751883493:32", "text": "Decimal frame number"}
{"id": "b930457b07ef98dd404b1e87bc0da7ee298f3d8207a8d9f8067c212cd94815e4", "item_id": "f751883493:33", "text": "<jobid>"}
{"id": "f93d3d62510100424b0f71d5747daa412fbaaeaaf7e352620eac773c967cc3b3", "item_id": "f751883493:34", "text": "Unique job identifier"}
{"id": "26c0d874961ff4a7350ffee0208d9c8bc7ac4d4f3b8102184180b6f08aca2778", "item_id": "f751883493:35", "text": "<time>"}
{"id": "06dafda7802b6be989948770b31c934bf86812482333e3d84d57855a7b6cd17e", "item_id": "f751883493:36", "text": "Current time"}
{"id": "8d81c90dd65238128850c57c58a3c0d015228359c279a7b2dce19fecb1b1fc45", "item_id": "f751883493:37", "text": "<ws>"}
{"id": "372e94560593a1e0828af5ad16d2a254ef36ababb537c5a0c4e10260531a5fcd", "item_id": "f751883493:38", "text": "The same as <OUT> as above"}
{"id": "0f261ea90e76a50afe1055c8d90f6bc0f3fdf94ce64cea5d08685df0f6f58a87", "item_id": "f751883493:39", "text": "Custom user tokens can also be added (see"}
{"id": "7ae87d3e6c79a34e79a4bbab4dac530ceecc2f9220c37666ebe75a1ef22213ba", "item_id": "f751883493:40", "text": "Workspace Editor"}
