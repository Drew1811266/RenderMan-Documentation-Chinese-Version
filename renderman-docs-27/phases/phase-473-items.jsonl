{"id": "6a654d0744a697e044c03cdbd7a6df943edcb61232a2d01739daf1691f084b2e", "item_id": "95e92aae90:0", "text": "Real Time"}
{"id": "6259b3943dfff5603e1cb7b074bf36e9703f7022542aa1c24fecbe65be898381", "item_id": "95e92aae90:1", "text": "Default Lights Shading"}
{"id": "18645d757ae4705f0097e5b45f315cd6699c08e55a3ff5ecf020b3fe30f653fb", "item_id": "95e92aae90:2", "text": "Default mode for light creation, wireframe or shaded."}
{"id": "02df09742e77a303347fd197c464d9a02d718d8e49cadfa76f0bed509c4d0342", "item_id": "95e92aae90:3", "text": "Texture File Extensions"}
{"id": "50b6149f572dcb1b9ce63e64b425d41df3036221ef9e6a193c7236f96b7c897c", "item_id": "95e92aae90:4", "text": "The extensions used to identify the displayed texture files. We default to RenderMan compliant types."}
{"id": "608ce315a9d2affbb64c5c8701829131276ae7a3d242ccc49b4c652d6313d8a5", "item_id": "95e92aae90:5", "text": "Display R in lights"}
{"id": "74e35cdd9a2a7b936083960bc23f4fe98130d51097958f956ef6bc7fd0740195", "item_id": "95e92aae90:6", "text": "Toggle for displaying the R logo on RenderMan lights."}
{"id": "e977246431b4e43437a35ba9134a47f6db0265791ecff33db898de9a530b5414", "item_id": "95e92aae90:7", "text": "Lights Wire Color"}
{"id": "18d595f717d9070ba1ec9bcde1803eba84987c9ebc336bb50466ec5fa9a18d35", "item_id": "95e92aae90:10", "text": "The color of the lines used to display these objects in the Viewport"}
{"id": "6187be16a22ab0b310c8d7e3cb16e1d871a83d884a7ec14a160c75b120f5411c", "item_id": "95e92aae90:9", "text": "Light Filters Wire Color"}
{"id": "83c5164cbce1de4d0478319fa276bd571902a7a7ab591fe8de07275f7ae99de6", "item_id": "95e92aae90:11", "text": "Max Texture Resolution"}
{"id": "124c88c38c9f7f70ca1e6f54236d3033887a1b329455730b00e9f62a9bd43339", "item_id": "95e92aae90:12", "text": "The maximum resolution of displayed textures in the Viewport. Higher resolutions will impact performance, especially if many are to be displayed. This does not affect IPR rendering to the Viewport."}
{"id": "6fb6fcd537f11ce58fd51d590aebf3c96d387c1137c2561c61c3f95961598031", "item_id": "95e92aae90:21", "text": "Viewport Controls"}
{"id": "8284697e2e8552682da95c7cc92d83d3f1f1d3351d5a5fff57bfba0a61083d76", "item_id": "95e92aae90:14", "text": "Show the controls for rendering to VIewport 2.0 in the icon bar of the panel."}
{"id": "54d22c81066797611dbaa6b159a1302af2bb041e965786f1318e4460fe77a874", "item_id": "95e92aae90:15", "text": "Playblast"}
{"id": "b45200c90d57a7309cd486c575240c9fff72f821627dd3f2f415c0af0c514ccf", "item_id": "95e92aae90:16", "text": "Playblast Viewer Command"}
{"id": "7706dede69e6619efb15b028926127f2d84ec1a86200fbaa8dfdbd9437f38012", "item_id": "95e92aae90:17", "text": "Select an executable and use # to denote frame numbers and padding to pass along."}
{"id": "6b6f44c50d93c59d9c56dce2d44335706fc24ecf4e926d7eabbb6e34c226ae47", "item_id": "95e92aae90:18", "text": "Show Command Output"}
{"id": "de08e1bce3879efdf1e4d525e7faacebc91990a4523b733b4c336af2773295b6", "item_id": "95e92aae90:19", "text": "Print the command into the script editor."}
{"id": "aa9f146c3d424a8c4b32f5ba83d79579f5d0892e81b6167e459582e2c1c8e4c4", "item_id": "95e92aae90:20", "text": "RenderMan"}
{"id": "5262d7d56ef42c18ee9bf61731e05bb62f2988f965242a665c043196acbc0a79", "item_id": "95e92aae90:22", "text": "Display the RenderMan control icons in the viewport panel."}
{"id": "c191e4cbe5c63d5b682aee39aec7a39f22dcd9bd7d8aeb7399236faeba545691", "item_id": "95e92aae90:23", "text": "Crop Window Color"}
{"id": "22316457e34fcb981460c41159b2fd2c2a5983343c3b3cd3e725b043611c3b2d", "item_id": "95e92aae90:24", "text": "Select your preferred color for drawing a crop window."}
{"id": "648e0be9062d7d8cc0c5277363d60503daa697d3d18ed3e8d00ad9aaec2217e7", "item_id": "95e92aae90:25", "text": "Max FPS"}
{"id": "c2c02f5bfe7b99fe722c406676209e24dedf17c41f9780141007023d79ecc5ec", "item_id": "95e92aae90:26", "text": "Limit the frame rate to avoid some issues with lag or phantom mouse."}
{"id": "051ebcdcc3a32a0c9e87a2b800940d194c09430b62c94180d9b73cc745b6fcec", "item_id": "95e92aae90:27", "text": "Progress Bar in Viewport"}
{"id": "a08d24539a4e76931bc1ef9e5f5e8dc945e79a967f067b4a5610ed7bfea11b8e", "item_id": "95e92aae90:28", "text": "A small bar will show frame progress at the bottom of the viewport and be disabled here."}
{"id": "eae59429d29f7db95fa1b3a3eed0b1b360361b1f6d5d2defabad7bed6f7fa73e", "item_id": "95e92aae90:29", "text": "Viewport Info String"}
{"id": "c8b938667ab506d74bb41352043bf323e64a42cd7224aeac532b7d95146e6f83", "item_id": "95e92aae90:30", "text": "You can display useful information in the viewport, you can choose this based on selections here using the tokens provided from the Workspace Render Tab. The default is the maximum amount based on space to fit the output"}
