  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "f4e152b5ea:0",
      "text": "Blade List pane 提供用于监控 server 及其 activity 的主要界面。与从 Engine 接收实时 update 的 Job List pane 不同，blade list 会以批量方式刷新，刷新可以手动触发，也可以由 Dashboard 管理的 timer 触发。在 toolbar 中选择 blade list 图标即可触发手动刷新。",
      "ascii_letters": 89,
      "cjk_chars": 61
    },
    {
      "item_id": "f4e152b5ea:3",
      "text": "Blade List pane 会响应多种 mouse 操作：",
      "ascii_letters": 18,
      "cjk_chars": 7
    },
    {
      "item_id": "f4e152b5ea:5",
      "text": "点击任意 row，会在 Blade List pane 下方的 Blade Info pane 中显示所选 blade 的信息。",
      "ascii_letters": 34,
      "cjk_chars": 17
    },
    {
      "item_id": "f4e152b5ea:7",
      "text": "Blade List pane 也响应标准的 multi-click control。这通常与 context sensitive menu 选择配合使用。",
      "ascii_letters": 50,
      "cjk_chars": 16
    },
    {
      "item_id": "f4e152b5ea:8",
      "text": "上下文菜单（Context-sensitive menu）",
      "ascii_letters": 20,
      "cjk_chars": 5
    },
    {
      "item_id": "f4e152b5ea:9",
      "text": "右键点击（或 Control-click）会打开 context sensitive menu，用于对所选 blade 执行操作。",
      "ascii_letters": 37,
      "cjk_chars": 17
    },
    {
      "item_id": "f4e152b5ea:10",
      "text": "清除较早的 Blade 数据（Clear Earlier Blade Data）",
      "ascii_letters": 26,
      "cjk_chars": 7
    },
    {
      "item_id": "f4e152b5ea:12",
      "text": "NIMBY 限制（On | Off）",
      "ascii_letters": 10,
      "cjk_chars": 2
    },
    {
      "item_id": "f4e152b5ea:13",
      "text": "向所选 blade 发送请求，设置其 NIMBY（Not-In-My-Backyard）mode。当 NIMBY 设置为 \"on\" 时，blade 只接受从该 host（通常是用户桌面）spool 出来的 job。NIMBY 为 \"off\" 时，任何匹配常规 profile criteria 的 job 都可被接受。注意，也可以通过发送到 blade 的 http directive，把该 mode 限制到特定用户。",
      "ascii_letters": 101,
      "cjk_chars": 64
    },
    {
      "item_id": "f4e152b5ea:14",
      "text": "Assignment Tracer",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "f4e152b5ea:15",
      "text": "assignment tracer 提供一种机制，用于在 blade 没有接收新 task 时辅助 debug。",
      "ascii_letters": 30,
      "cjk_chars": 17
    },
    {
      "item_id": "f4e152b5ea:16",
      "text": "选择一个 blade 并从 context menu 中选择 \"Assignment Tracer\" 后，会打开 tracer dialog。在所选 blade 向 engine 请求 job 之前，该 dialog 会保持空白。随后 engine 会记录它如何遍历现有 job，以判断是否向该 blade 分配 work。",
      "ascii_letters": 82,
      "cjk_chars": 48
    },
    {
      "item_id": "f4e152b5ea:18",
      "text": "键盘快捷键（Keyboard Shortcuts）",
      "ascii_letters": 17,
      "cjk_chars": 5
    },
    {
      "item_id": "f4e152b5ea:19",
      "text": "Blade List pane 中可使用以下 keyboard shortcut：",
      "ascii_letters": 29,
      "cjk_chars": 6
    },
    {
      "item_id": "f4e152b5ea:20",
      "text": "Control/Command-A 全选快捷键",
      "ascii_letters": 15,
      "cjk_chars": 5
    }
  ],
