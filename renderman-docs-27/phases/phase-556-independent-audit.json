  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "0f5e062827:0",
      "text": "RenderMan 附带一整套 analytic 和 photorealistic lights（解析型与写实灯光）。",
      "ascii_letters": 37,
      "cjk_chars": 14
    },
    {
      "item_id": "0f5e062827:2",
      "text": "RenderMan Light（RenderMan 灯光）",
      "ascii_letters": 23,
      "cjk_chars": 2
    },
    {
      "item_id": "0f5e062827:4",
      "text": "PxrDomeLight",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "0f5e062827:5",
      "text": "在大量 visual effects 和 animation 工作中，场景主要使用 High Dynamic Range Image (HDRI) 或手绘 sky ramp texture 来照明。",
      "ascii_letters": 61,
      "cjk_chars": 19
    },
    {
      "item_id": "0f5e062827:7",
      "text": "PxrRectLight",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "0f5e062827:10",
      "text": "为了获得真实的 reflections 和 light quality，可以给灯光应用一张 texture。",
      "ascii_letters": 30,
      "cjk_chars": 17
    },
    {
      "item_id": "0f5e062827:12",
      "text": "它也可用于从墙面或 bounce board geometry 添加 bounce lighting（反弹照明）。",
      "ascii_letters": 33,
      "cjk_chars": 15
    },
    {
      "item_id": "0f5e062827:13",
      "text": "PxrDiscLight",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "0f5e062827:14",
      "text": "与 PxrRectLight 相同，只是形状为 disc（圆盘）。",
      "ascii_letters": 16,
      "cjk_chars": 10
    },
    {
      "item_id": "0f5e062827:15",
      "text": "PxrDistantLight",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "0f5e062827:16",
      "text": "主要用于模拟 sunlight、moonlight，或非常遥远的 light source。",
      "ascii_letters": 28,
      "cjk_chars": 12
    },
    {
      "item_id": "0f5e062827:17",
      "text": "PxrSphereLight",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "0f5e062827:19",
      "text": "PxrCylinderLight",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "0f5e062827:20",
      "text": "非常适合室内 tube lighting、neons 和 light sabers（光剑）！",
      "ascii_letters": 28,
      "cjk_chars": 9
    },
    {
      "item_id": "0f5e062827:21",
