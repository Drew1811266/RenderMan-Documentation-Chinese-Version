  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "949f07587a:2",
      "text": "Captured by（HDRI 资源拍摄者）",
      "ascii_letters": 14,
      "cjk_chars": 5
    },
    {
      "item_id": "949f07587a:3",
      "text": "：Arkell Rasiah、Christophe Hery 和 Jean-Claude Kalache。",
      "ascii_letters": 43,
      "cjk_chars": 1
    },
    {
      "item_id": "949f07587a:5",
      "text": "：Attach this map to a PxrDomeLight（将此 map 连接到 PxrDomeLight）",
      "ascii_letters": 43,
      "cjk_chars": 5
    },
    {
      "item_id": "949f07587a:6",
      "text": "Overview（资源概览）",
      "ascii_letters": 8,
      "cjk_chars": 4
    },
    {
      "item_id": "949f07587a:7",
      "text": "这个 HDRI collection 拍摄于 California 的 Stinson Beach，那里也是 Pixar short film",
      "ascii_letters": 50,
      "cjk_chars": 10
    },
    {
      "item_id": "949f07587a:9",
      "text": "的 visual inspiration。这个 collection 曾用于开发该 film 的 look。",
      "ascii_letters": 35,
      "cjk_chars": 10
    },
    {
      "item_id": "949f07587a:11",
      "text": "Loren Carpenter",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "949f07587a:15",
      "text": "Materials",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "949f07587a:17",
      "text": "Asset Library > EnvironmentMaps",
      "ascii_letters": 27,
      "cjk_chars": 0
    },
    {
      "item_id": "949f07587a:18",
      "text": "folder。文件按 category 组织，可以在 preset browser 中轻松搜索。",
      "ascii_letters": 27,
      "cjk_chars": 13
    },
    {
      "item_id": "949f07587a:20",
      "text": "RenderManAssetLibrary",
      "ascii_letters": 21,
      "cjk_chars": 0
    },
    {
      "item_id": "949f07587a:21",
      "text": "folder 转移到具有 full writing privileges 的位置。",
      "ascii_letters": 27,
      "cjk_chars": 8
    },
    {
      "item_id": "949f07587a:22",
      "text": "当你转移 Materials folder 并把 Asset Library 移到其他位置后，重要的是通过 Maya preferences 告诉 Maya 使用新的 path。",
      "ascii_letters": 50,
      "cjk_chars": 25
    },
    {
      "item_id": "949f07587a:23",
      "text": "或者，你可以在 Maya.env file 中创建新的 environment variable，以确保始终指向正确的 folder：",
      "ascii_letters": 36,
      "cjk_chars": 21
    },
    {
      "item_id": "949f07587a:25",
      "text": "Stinson Beach HDRI files are licensed under a（Stinson Beach HDRI files 使用以下许可授权：）",
      "ascii_letters": 59,
      "cjk_chars": 8
    },
    {
      "item_id": "949f07587a:26",
      "text": "Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International License",
      "ascii_letters": 69,
      "cjk_chars": 0
    }
  ],
