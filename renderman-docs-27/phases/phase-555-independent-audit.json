  ],
  "actionable_ascii_heavy_residuals": [],
  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "5b07adadf8:5",
      "text": "现在开始把这些 textures 指定给我们的 floorboards。",
      "ascii_letters": 19,
      "cjk_chars": 13
    },
    {
      "item_id": "5b07adadf8:7",
      "text": "这里的技巧是结合使用 PxrMultiTexture node 来载入一组 10 张 textures，然后用 PxrRandomTextureManifold 对每张 texture 和 UV placement 的随机性进行艺术指导。",
      "ascii_letters": 69,
      "cjk_chars": 33
    },
    {
      "item_id": "5b07adadf8:10",
      "text": "PxrRandomTextureManifold 内部有几个关键参数",
      "ascii_letters": 24,
      "cjk_chars": 9
    },
    {
      "item_id": "5b07adadf8:11",
      "text": "Number of Textures（纹理数量）：",
      "ascii_letters": 16,
      "cjk_chars": 4
    },
    {
      "item_id": "5b07adadf8:12",
      "text": "这会决定从 PxrMultiTexture files 中使用多少张 textures",
      "ascii_letters": 28,
      "cjk_chars": 11
    },
    {
      "item_id": "5b07adadf8:13",
      "text": "Texture Order（纹理顺序）：",
      "ascii_letters": 12,
      "cjk_chars": 4
    },
    {
      "item_id": "5b07adadf8:14",
      "text": "这会控制 PxrMultiTexture files 中的 textures 如何被打乱顺序",
      "ascii_letters": 28,
      "cjk_chars": 13
    },
    {
      "item_id": "5b07adadf8:15",
      "text": "Random Source（随机来源）：",
      "ascii_letters": 12,
      "cjk_chars": 4
    },
    {
      "item_id": "5b07adadf8:16",
      "text": "这会控制 PxrRandomTextureManifold 使用哪个 geometry ID",
      "ascii_letters": 34,
      "cjk_chars": 8
    },
    {
      "item_id": "5b07adadf8:17",
      "text": "Pushing the Randomization（进一步推进随机化）",
      "ascii_letters": 23,
      "cjk_chars": 8
    },
    {
      "item_id": "5b07adadf8:20",
      "text": "diffuse textures 也被连接到 PxrBumpMixer，再连接到 diffuse bump，用来给 diffuse layer 添加轻微的 bump。",
      "ascii_letters": 54,
      "cjk_chars": 17
    },
    {
      "item_id": "5b07adadf8:21",
      "text": "diffuse texture 还被用来驱动 Primary Specular。",
      "ascii_letters": 29,
      "cjk_chars": 6
    },
    {
      "item_id": "5b07adadf8:23",
      "text": "幸运的是，PxrMultiTexture node 内部还有更多 randomization parameters。",
      "ascii_letters": 42,
      "cjk_chars": 10
    },
    {
      "item_id": "5b07adadf8:26",
      "text": "Adding Varnish（添加清漆与涂层）",
      "ascii_letters": 13,
      "cjk_chars": 7
    },
    {
      "item_id": "5b07adadf8:27",
      "text": "我们希望给 floorboards 增加一层额外 varnish（清漆），这可以通过 PxrSurface 中的 Clear Coat layer 轻松实现。如果使用 Lama，也可以把带 tint 的 LamaDielectric node 分层作为 base layer，然后调整 PxrLayer node 上的 Layer Thickness parameter 来完成。",
      "ascii_letters": 112,
      "cjk_chars": 47
    },
    {
      "item_id": "5b07adadf8:38",
      "text": "Further Refinements（进一步优化）",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "5b07adadf8:39",
      "text": "尝试使用 diffuse map（或 imperfection map）来驱动 Clear Coat layer 的 Layer Thickness。当你希望刮掉 varnish coating、露出下面的 raw wood 时，这可以用来增加额外真实感。",
      "ascii_letters": 74,
      "cjk_chars": 33
    },
    {
      "item_id": "5b07adadf8:40",
      "text": "给 Clear Coat layer 添加一张 bump texture，以加入更多 bumps 和瑕疵",
      "ascii_letters": 30,
      "cjk_chars": 13
    },
    {
      "item_id": "5b07adadf8:41",
      "text": "为你的 diffuse texture map(s) 制作一张 Bump2Roughness map。随后可以用它来驱动 floorboards 的 roughness、bump 和 anisotropy。",
      "ascii_letters": 68,
      "cjk_chars": 18
    },
    {
      "item_id": "5b07adadf8:43",
      "text": "在 Diffuse 或 Clear Coat 上方叠加一张 imperfection map，以增加更多损伤。",
      "ascii_letters": 31,
      "cjk_chars": 15
    }
  ],
