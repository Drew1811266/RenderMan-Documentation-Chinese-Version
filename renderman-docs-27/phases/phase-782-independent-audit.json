      "item_id": "a12b28a045:0",
      "text": "Tractor Engine",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "a12b28a045:4",
      "text": "C++、Python、Postgresql（bundled，随附）",
      "ascii_letters": 24,
      "cjk_chars": 2
    },
    {
      "item_id": "a12b28a045:5",
      "text": "兼容的操作系统（Compatible Operating Systems）：Linux 64-bit (gcc4.4)、macOS (12.x+)",
      "ascii_letters": 43,
      "cjk_chars": 7
    },
    {
      "item_id": "a12b28a045:6",
      "text": "Tractor Blade",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "a12b28a045:7",
      "text": "Task execution server（任务执行服务器），安装在 render farm hosts 上。",
      "ascii_letters": 34,
      "cjk_chars": 11
    },
    {
      "item_id": "a12b28a045:8",
      "text": "Stand-alone pure Python package，兼容 py2.7 和 py3.6+",
      "ascii_letters": 31,
      "cjk_chars": 3
    },
    {
      "item_id": "a12b28a045:9",
      "text": "仅使用 stock Python library modules。",
      "ascii_letters": 25,
      "cjk_chars": 3
    },
    {
      "item_id": "a12b28a045:10",
      "text": "使用本地 site-installed Python（或 venv）运行，可作为 zipapp 或 pip installed wheel。",
      "ascii_letters": 46,
      "cjk_chars": 11
    },
    {
      "item_id": "a12b28a045:11",
      "text": "也包含在使用 bundled python 的完整 Tractor installer 中。",
      "ascii_letters": 29,
      "cjk_chars": 10
    },
    {
      "item_id": "a12b28a045:12",
      "text": "兼容的操作系统（Compatible Operating Systems）：Linux-64、macOS 12.x+ 和 Windows 7+。",
      "ascii_letters": 44,
      "cjk_chars": 8
    },
    {
      "item_id": "a12b28a045:13",
      "text": "Tractor Dashboard",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "a12b28a045:14",
      "text": "基于 web-browser 的 user interface，用于 job 和 blade 信息与控制。",
      "ascii_letters": 31,
      "cjk_chars": 11
    },
    {
      "item_id": "a12b28a045:15",
      "text": "纯 JavaScript，由 tractor-engine 提供服务。不需要 platform-specific plugins。",
      "ascii_letters": 46,
      "cjk_chars": 9
    },
    {
      "item_id": "a12b28a045:16",
      "text": "兼容的 Web Browsers（Web 浏览器）：Chrome、Firefox、Safari 和 Edge。",
      "ascii_letters": 37,
      "cjk_chars": 7
    },
    {
      "item_id": "a12b28a045:17",
      "text": "Tractor Job Submission and Query",
      "ascii_letters": 28,
      "cjk_chars": 0
    },
    {
      "item_id": "a12b28a045:18",
      "text": "用户 workstations 上的高级 command line tools 和 scripting APIs。",
      "ascii_letters": 41,
      "cjk_chars": 7
    },
    {
      "item_id": "a12b28a045:19",
      "text": "用于 Job Authoring、Submission 和 Query 的 scripting APIs，可下载 wheels 并通过 pip install 安装到本地 Python 2.7 或 3.6+。",
      "ascii_letters": 62,
      "cjk_chars": 16
    },
    {
      "item_id": "a12b28a045:20",
      "text": "Command-line submission 和 alternate API installer 可下载为面向 Python 2.7 或 3.6+ 的 stand-alone zipapp。",
      "ascii_letters": 64,
      "cjk_chars": 9
    },
    {
      "item_id": "a12b28a045:21",
      "text": "仅使用 stock Python library modules。",
      "ascii_letters": 25,
      "cjk_chars": 3
    },
    {
      "item_id": "a12b28a045:22",
      "text": "也包含在使用 bundled python 的完整 Tractor installer 中。",
      "ascii_letters": 29,
      "cjk_chars": 10
    },
    {
      "item_id": "a12b28a045:23",
      "text": "兼容的操作系统（Compatible Operating Systems）：Linux-64、macOS 12.x+ 和 Windows 7+。",
      "ascii_letters": 44,
      "cjk_chars": 8
    },
    {
      "item_id": "a12b28a045:24",
      "text": "RenderMan DCC Integrations",
      "ascii_letters": 24,
      "cjk_chars": 0
    },
    {
      "item_id": "a12b28a045:25",
      "text": "面向受支持 RenderMan DCC integrations 的 Job Authoring and Submission。",
      "ascii_letters": 49,
      "cjk_chars": 6
    },
    {
      "item_id": "a12b28a045:26",
