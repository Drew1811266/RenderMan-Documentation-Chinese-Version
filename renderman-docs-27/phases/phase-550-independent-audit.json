    {
      "item_id": "7eb96b6013:3",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:5",
      "text": "简单的 Metallic PBR shader",
      "ascii_letters": 17,
      "cjk_chars": 3
    },
    {
      "item_id": "7eb96b6013:6",
      "text": "PxrDisneyBsdf",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:7",
      "text": "Walt Disney Animation Studios 制作的所有 CG 动画都使用这个 material model",
      "ascii_letters": 41,
      "cjk_chars": 12
    },
    {
      "item_id": "7eb96b6013:8",
      "text": "我想使用 Pixar Animation Studios 使用的 shader",
      "ascii_letters": 27,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:9",
      "text": "PxrSurface",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:10",
      "text": "这是 Pixar Animation Studios 长片动画中使用的同一套 material model。",
      "ascii_letters": 34,
      "cjk_chars": 13
    },
    {
      "item_id": "7eb96b6013:11",
      "text": "我想叠加多个 PxrSurfaces",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:12",
      "text": "PxrLayerSurface",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:13",
      "text": "与 PxrSurface 类似，但允许通过 layer masks 驱动 layering",
      "ascii_letters": 28,
      "cjk_chars": 10
    },
    {
      "item_id": "7eb96b6013:14",
      "text": "使用 ILM 的 production layering shaders",
      "ascii_letters": 28,
      "cjk_chars": 3
    },
    {
      "item_id": "7eb96b6013:15",
      "text": "LamaSurface",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:16",
      "text": "MaterialX Lama 是由 Industrial Light & Magic 开发的先进 material layering system，它引入了模块化构建 material networks 的方法，并包含近期关于能量守恒和色散的 shading R&D 工作。",
      "ascii_letters": 80,
      "cjk_chars": 36
    },
    {
      "item_id": "7eb96b6013:17",
      "text": "我只需要一个 constant material",
      "ascii_letters": 16,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:18",
      "text": "PxrConstant",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:19",
      "text": "一个基础 constant shader（常量着色器）。",
      "ascii_letters": 14,
      "cjk_chars": 9
    },
    {
      "item_id": "7eb96b6013:20",
      "text": "用于 volumes、clouds、pyro 和 VDBs 的 shader",
      "ascii_letters": 27,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:21",
      "text": "PxrVolume",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:22",
      "text": "PxrVolume 是一种 material，可用于渲染复杂度差异很大的 volumetric effects",
      "ascii_letters": 34,
      "cjk_chars": 16
    },
    {
      "item_id": "7eb96b6013:23",
      "text": "我想使用 Pixar 使用的 hair shader！",
      "ascii_letters": 15,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:24",
      "text": "PxrMarschnerHair",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:25",
      "text": "PxrMarschner 是一种 material，用于渲染真实感 hair、fur 和 fibers。",
      "ascii_letters": 33,
      "cjk_chars": 11
    },
    {
      "item_id": "7eb96b6013:26",
      "text": "我想使用 Lama hair shader。",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:27",
      "text": "LamaHairChiang",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:28",
      "text": "LamaHairChiang 是 Pixar Chiang hair shader 的可分层版本，并在 Pixar production 中使用。",
      "ascii_letters": 50,
      "cjk_chars": 12
    },
    {
      "item_id": "7eb96b6013:29",
      "text": "我想给 material 添加 displacement",
      "ascii_letters": 20,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:30",
      "text": "PxrDisplace",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:31",
      "text": "将此 node 添加到 shader output，即可给 material 添加 displacement",
      "ascii_letters": 36,
      "cjk_chars": 10
    },
    {
      "item_id": "7eb96b6013:32",
      "text": "Texture Loading、tiling 与 placement（纹理加载、平铺与放置）",
      "ascii_letters": 29,
      "cjk_chars": 10
    },
    {
      "item_id": "7eb96b6013:34",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:36",
      "text": "加载 texture map（纹理贴图）",
      "ascii_letters": 10,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:37",
      "text": "PxrTexture",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:38",
      "text": "RenderMan 版本的 texture file load node",
      "ascii_letters": 28,
      "cjk_chars": 3
    },
    {
      "item_id": "7eb96b6013:39",
      "text": "Triplanar Mapping（三平面映射）",
      "ascii_letters": 16,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:40",
      "text": "PxrRoundCube + PxrMultiTexture",
      "ascii_letters": 27,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:41",
      "text": "纹理的 Triplanar mapping",
      "ascii_letters": 16,
      "cjk_chars": 3
    },
    {
      "item_id": "7eb96b6013:42",
      "text": "HexTiling",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:43",
      "text": "PxrHexTile + PxrMultiTexture",
      "ascii_letters": 25,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:45",
      "text": "调整 Texture map 的 tiling 和 offset（平铺与偏移）",
      "ascii_letters": 22,
      "cjk_chars": 9
    },
    {
      "item_id": "7eb96b6013:46",
      "text": "PxrManifold2d",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:48",
      "text": "在 RenderMan 中使用 Metallic PBR maps",
      "ascii_letters": 24,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:49",
      "text": "PxrMetallicWorkflow",
      "ascii_letters": 19,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:50",
      "text": "允许 Metallic PBR maps 与 RenderMan shaders 一起使用",
      "ascii_letters": 31,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:51",
      "text": "Texture Correction（纹理校正）工具",
      "ascii_letters": 17,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:53",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:55",
      "text": "将 color map 转成黑白 map，",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:56",
      "text": "PxrThreshold",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:57",
      "text": "很适合从 diffuse maps 创建 roughness/breakup maps",
      "ascii_letters": 31,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:59",
      "text": "PxrRemap",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:60",
      "text": "可以更细致地控制纹理的 Input、Bias、Gain 和 Output 值",
      "ascii_letters": 19,
      "cjk_chars": 13
    },
    {
      "item_id": "7eb96b6013:61",
      "text": "对 texture 做 color correction（颜色校正）",
      "ascii_letters": 22,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:62",
      "text": "PxrColorGrade",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:63",
      "text": "PxrColorCorrect",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:64",
      "text": "调整纹理的 saturation、gain、contrast 以及其他元素",
      "ascii_letters": 22,
      "cjk_chars": 11
    },
    {
      "item_id": "7eb96b6013:65",
      "text": "调整 texture 的 Hue、Saturation 和 Value",
      "ascii_letters": 25,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:67",
      "text": "调整给定 input color 的 hue、saturation 和 value。",
      "ascii_letters": 28,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:68",
      "text": "使用 curve（曲线）调整 texture（纹理）",
      "ascii_letters": 12,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:69",
      "text": "PxrSplineMap",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:70",
      "text": "使用此 pattern 将 input remap 到 float 和 color 两种 outputs",
      "ascii_letters": 34,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:72",
      "text": "PxrBakeTexture",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:73",
      "text": "将 network patterns bake 到 Textures，模型需要 UVs",
      "ascii_letters": 30,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:74",
      "text": "Texture Layering & Blending（纹理分层与混合）",
      "ascii_letters": 23,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:76",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:78",
      "text": "Blend 两个 textures",
      "ascii_letters": 13,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:79",
      "text": "PxrBlend",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:81",
      "text": "Blend 最多 8 个 textures 的 stack",
      "ascii_letters": 18,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:82",
      "text": "PxrLayeredBlend",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:84",
      "text": "Blend textures 及其 masks。",
      "ascii_letters": 18,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:85",
      "text": "PxrLayeredTexture",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:86",
      "text": "这对给 texture result 添加 decals、labels、damage 等内容很有用。",
      "ascii_letters": 31,
      "cjk_chars": 11
    },
    {
      "item_id": "7eb96b6013:87",
      "text": "Bump 与 Displacement（凹凸与置换）",
      "ascii_letters": 16,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:89",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:91",
      "text": "向 material network（材质网络）添加 bump",
      "ascii_letters": 19,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:92",
      "text": "PxrBumpMixer",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:94",
      "text": "调整 displacement texture values（置换纹理值）",
      "ascii_letters": 25,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:95",
      "text": "PxrDispTransform",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:96",
      "text": "此 pattern 会把 input displacement values 转换到一个自定义 value range，供 PxrDisplace 的 input 使用。",
      "ascii_letters": 56,
      "cjk_chars": 15
    },
    {
      "item_id": "7eb96b6013:97",
      "text": "从黑白 bump map 创建 BumpRoughness map",
      "ascii_letters": 23,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:98",
      "text": "PxrBumpRoughness",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:99",
      "text": "使用此 pattern 时，RenderMan 会根据 camera 中 feature 的尺寸，在 bump map 与 roughness value 之间自动切换，",
      "ascii_letters": 50,
      "cjk_chars": 19
    },
    {
      "item_id": "7eb96b6013:101",
      "text": "PxrRGBtoNG",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:102",
      "text": "有时你可能想为 PxrBumpMixer 创建 bump map input，但最后一个 node 缺少 NG OUT。使用此 node 可将 RGB 转换为 NG",
      "ascii_letters": 42,
      "cjk_chars": 24
    },
    {
      "item_id": "7eb96b6013:103",
      "text": "Generators（生成器）节点",
      "ascii_letters": 10,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:105",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:110",
      "text": "生成 checker pattern（棋盘格图案）",
      "ascii_letters": 14,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:111",
      "text": "PxrChecker",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:112",
      "text": "PxrChecker 会计算一个简单的 checkerboard pattern。",
      "ascii_letters": 29,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:113",
      "text": "生成 procedural flakes（程序化片状效果）",
      "ascii_letters": 16,
      "cjk_chars": 9
    },
    {
      "item_id": "7eb96b6013:114",
      "text": "PxrFlakes",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:115",
      "text": "在制作 car paints 或 metallic shaders？使用 PxrFlakes 添加 specular variety。",
      "ascii_letters": 48,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:116",
      "text": "Procedural Fractal Noise（程序化分形噪声）",
      "ascii_letters": 22,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:117",
      "text": "PxrFractal",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:118",
      "text": "Fractal noises 可用于各种场景！",
      "ascii_letters": 13,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:119",
      "text": "Randomization（随机化）",
      "ascii_letters": 13,
      "cjk_chars": 3
    },
    {
      "item_id": "7eb96b6013:121",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:123",
      "text": "按 object、name 或 ID 随机化 texture outputs",
      "ascii_letters": 26,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:125",
      "text": "适合按 instance 或 duplicates 随机 roughness、diffuse 和 manifold placement",
      "ascii_letters": 51,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:126",
      "text": "将 textures 随机指定给大量 objects",
      "ascii_letters": 15,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:127",
      "text": "PxrRandomTextureManifold",
      "ascii_letters": 24,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:128",
      "text": "PxrRandomTextureManifold 搭配 PxrMultiTexture，可将随机 textures 指定给大量 objects。",
      "ascii_letters": 54,
      "cjk_chars": 11
    },
    {
      "item_id": "7eb96b6013:129",
      "text": "Blend textures 及其 masks",
      "ascii_letters": 18,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:130",
      "text": "PxrLayeredTexture",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:131",
      "text": "这对给 texture result 添加 decals、labels、damage 等内容很有用。",
      "ascii_letters": 31,
      "cjk_chars": 11
    },
    {
      "item_id": "7eb96b6013:133",
      "text": "PxrManifold2d",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:134",
      "text": "Edge Detection（边缘检测）工具",
      "ascii_letters": 13,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:136",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:138",
      "text": "我想创建 procedural edge masks 和 breakup",
      "ascii_letters": 26,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:139",
      "text": "PxrCurvature",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:140",
      "text": "这是一个实用且直接的 pattern，可创建 edge effects 和 curvature-based results，例如边缘磨损以及与其他 surface 接触的 objects。",
      "ascii_letters": 53,
      "cjk_chars": 28
    },
    {
      "item_id": "7eb96b6013:141",
      "text": "我想在 crevices 中加入 dust 和 dirt。",
      "ascii_letters": 16,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:143",
      "text": "PxrDirt 会渲染 local geometric occlusion。这对将 shading effects 应用到 nooks 和 crevices 很有用。",
      "ascii_letters": 57,
      "cjk_chars": 13
    },
    {
      "item_id": "7eb96b6013:144",
      "text": "我想渲染 Wireframe（线框）",
      "ascii_letters": 9,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:145",
      "text": "PxrWireframe",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:146",
      "text": "这个 pattern 用于把 geometry wireframes 绘制为 pattern assignment。",
      "ascii_letters": 42,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:147",
      "text": "检测 geometry 的 facing ratio（朝向比例）",
      "ascii_letters": 19,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:148",
      "text": "PxrFacingRatio",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:149",
      "text": "用途很多，包括 procedural edge dirt 以及制作 light bulb emission。",
      "ascii_letters": 35,
      "cjk_chars": 10
    },
    {
      "item_id": "7eb96b6013:152",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:154",
      "text": "在 RenderMan 中使用 HDRI map",
      "ascii_letters": 16,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:155",
      "text": "PxrDomeLight",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:156",
      "text": "在许多 visual effects 和 animation 工作中，场景主要通过 High Dynamic Range Image（HDRI）照明。",
      "ascii_letters": 47,
      "cjk_chars": 15
    },
    {
      "item_id": "7eb96b6013:157",
      "text": "使用动态 Sun / Sky environment",
      "ascii_letters": 17,
      "cjk_chars": 4
    },
    {
      "item_id": "7eb96b6013:158",
      "text": "PxrEnvDayLight",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:159",
      "text": "当你想为 exterior lighting 快速搭建简单设置时，Daylight simulations 很有帮助。",
      "ascii_letters": 35,
      "cjk_chars": 17
    },
    {
      "item_id": "7eb96b6013:160",
      "text": "Rect 或 Area light（矩形或面积光）",
      "ascii_letters": 13,
      "cjk_chars": 7
    },
    {
      "item_id": "7eb96b6013:161",
      "text": "PxrRectLight",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:162",
      "text": "这个 one-sided area light 模拟矩形 light source。",
      "ascii_letters": 28,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:163",
      "text": "Disc-shaped Light（圆盘形灯光）",
      "ascii_letters": 15,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:164",
      "text": "PxrDiscLight",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:165",
      "text": "这个 one-sided area light（单面面积光）模拟 disk-shaped light source（圆盘形光源）。",
      "ascii_letters": 38,
      "cjk_chars": 14
    },
    {
      "item_id": "7eb96b6013:166",
      "text": "Sphere-shaped Light（球形灯光）类型",
      "ascii_letters": 17,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:167",
      "text": "PxrSphereLight",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:169",
      "text": "Cylinder 或 tube-shaped light（圆柱或管状灯光）",
      "ascii_letters": 23,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:170",
      "text": "PxrCylinderLight",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:171",
      "text": "其用途包括照亮 objects，模拟许多建筑中使用的 commercial lighting、linear lights、fluorescent lights 和 light panels。它也可用于制作 lightsabers。",
      "ascii_letters": 76,
      "cjk_chars": 25
    },
    {
      "item_id": "7eb96b6013:172",
      "text": "Distant、infinite 或 sun/moon directional light",
      "ascii_letters": 38,
      "cjk_chars": 1
    },
    {
      "item_id": "7eb96b6013:173",
      "text": "PxrDistantLight",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:175",
      "text": "Portal Light",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:176",
      "text": "PxrPortalLight",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:177",
      "text": "由于带有很少或没有 direct lighting 的室内照明很难让 renderer 解析，portal lights 会帮助 renderer 将注意力引向外部 light source。",
      "ascii_letters": 53,
      "cjk_chars": 30
    },
    {
      "item_id": "7eb96b6013:178",
      "text": "为 shot-specific masks 创建 AOVs",
      "ascii_letters": 21,
      "cjk_chars": 3
    },
    {
      "item_id": "7eb96b6013:179",
      "text": "PxrAovLight",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:180",
      "text": "允许 lighting artist 输出 AOV (Area of Interest) mask。由于它是一个 \"light\"，我们也可以使用 light linking 和 light filter(s) 来修改输出 mask。",
      "ascii_letters": 68,
      "cjk_chars": 23
    },
    {
      "item_id": "7eb96b6013:181",
      "text": "Light Filters（灯光过滤器）",
      "ascii_letters": 12,
      "cjk_chars": 5
    },
    {
      "item_id": "7eb96b6013:183",
      "text": "RenderMan Node（RenderMan 节点）",
      "ascii_letters": 22,
      "cjk_chars": 2
    },
    {
      "item_id": "7eb96b6013:185",
      "text": "给 light 添加高级 spotlight 和 barn door 功能",
      "ascii_letters": 22,
      "cjk_chars": 8
    },
    {
      "item_id": "7eb96b6013:186",
      "text": "PxrBarnLightFilter",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:187",
      "text": "PxrBarnLightFilter 让我们可以创建 physically accurate window barns，并以正确阴影模拟真实片场照明。",
      "ascii_letters": 47,
      "cjk_chars": 21
    },
    {
      "item_id": "7eb96b6013:188",
      "text": "给 light 添加 Cookie 或 gobo texture，类似 projector 或模拟窗口 shadows（阴影）",
      "ascii_letters": 38,
      "cjk_chars": 13
    },
    {
      "item_id": "7eb96b6013:189",
      "text": "PxrCookieLightFilter",
      "ascii_letters": 20,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:190",
      "text": "PxrCookieLightFilter 会在 light 前方投射 painted texture。",
      "ascii_letters": 39,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:192",
      "text": "PxrRodLightFilter",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "7eb96b6013:193",
      "text": "PxrRodLightFilter 使用类似 \"rod\" 的 object 来 block light。",
      "ascii_letters": 36,
      "cjk_chars": 6
    },
    {
      "item_id": "7eb96b6013:194",
      "text": "调整 scene 某些区域中所选 light 的 exposure",
      "ascii_letters": 18,
      "cjk_chars": 10
    },
    {
      "item_id": "7eb96b6013:195",
      "text": "PxrIntMultiLightFilter",
      "ascii_letters": 22,
      "cjk_chars": 0
    }
  ],
