    {
      "item_id": "c9bad42db8:0",
      "text": "RenderMan for Maya (RfM) 的 Render Settings 通过 Maya Render Settings dialog 控制。可以从多个位置访问：",
      "ascii_letters": 57,
      "cjk_chars": 14
    },
    {
      "item_id": "c9bad42db8:1",
      "text": "主要是在 Maya Shelf 中，有一个 Render Settings 图标：",
      "ascii_letters": 23,
      "cjk_chars": 10
    },
    {
      "item_id": "c9bad42db8:2",
      "text": "通过菜单：Windows -> Rendering Editors -> Render Settings",
      "ascii_letters": 37,
      "cjk_chars": 4
    },
    {
      "item_id": "c9bad42db8:3",
      "text": "通过 RenderMan menu：RenderMan -> Render Settings",
      "ascii_letters": 36,
      "cjk_chars": 2
    },
    {
      "item_id": "c9bad42db8:4",
      "text": "当 Maya 处于 Rendering mode 时，通过菜单：Render -> Render Settings",
      "ascii_letters": 37,
      "cjk_chars": 8
    },
    {
      "item_id": "c9bad42db8:7",
      "text": "当 RenderMan 被选为 Maya renderer 时，会显示上面的 dialog。顶部有 6 个 tabs，用于控制 renderer 的不同部分。",
      "ascii_letters": 39,
      "cjk_chars": 24
    },
    {
      "item_id": "c9bad42db8:8",
      "text": "The Common Settings tab",
      "ascii_letters": 20,
      "cjk_chars": 0
    },
    {
      "item_id": "c9bad42db8:9",
      "text": "用于控制 image resolution、frame range 和其他选项。",
      "ascii_letters": 25,
      "cjk_chars": 9
    },
    {
      "item_id": "c9bad42db8:10",
      "text": "The Sampling tab",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "c9bad42db8:15",
      "text": "Features tab",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "c9bad42db8:16",
      "text": "可用于开启 motion blur，并添加 Cryptomatte 等其他 render features。",
      "ascii_letters": 35,
      "cjk_chars": 11
    },
    {
      "item_id": "c9bad42db8:17",
      "text": "The Advanced Settings Tab",
      "ascii_letters": 22,
      "cjk_chars": 0
    },
    {
      "item_id": "c9bad42db8:18",
      "text": "，artist 可以在这里编辑更高级的选项，例如 cache sizes 或 bucket order。",
      "ascii_letters": 27,
      "cjk_chars": 16
    },
    {
      "item_id": "c9bad42db8:20",
      "text": "Workspace Settings",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "c9bad42db8:21",
      "text": "它会显示 output locations 的 job settings，以及更多 pipeline/file system settings",
      "ascii_letters": 52,
      "cjk_chars": 9
    }
  ],
