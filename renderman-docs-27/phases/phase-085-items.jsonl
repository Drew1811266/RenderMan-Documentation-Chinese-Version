{"id": "55dae582a8ac16274be0c887a3d38271ee39c70696b3c851ba5b4d8c8e0e57ba", "item_id": "92d0ea2516:0", "text": "PxrBakePointCloud"}
{"id": "682965b2e489a890aa9a42a5741a32f56921f6a90c737ffeaf59ac6652c4607c", "item_id": "92d0ea2516:1", "text": "can be used as a pass-through node for baking patterns networks to 3D point clouds as part of the"}
{"id": "56bbbb0a1a7c2cf2cf88ecbcf15f9bdcd8b07539097af7aa3b7a712219f9dd61", "item_id": "92d0ea2516:2", "text": "baking"}
{"id": "219924f7930f8dafc346f5e0f5df5ca949379b2e1f5577098f058f92287114aa", "item_id": "92d0ea2516:3", "text": "workflow."}
{"id": "35aea6f833e7d09d9722a54bdee4bc25b02fd25547d6613ee8d9457096af94fb", "item_id": "92d0ea2516:5", "text": "Input Color"}
{"id": "3a3d8b01482e2c2dce38c55a46423ad21ab697780b17e33fd052dfc4627c225b", "item_id": "92d0ea2516:6", "text": "This is the incoming result of the pattern network to be baked. This connection requires a color (RGB)."}
{"id": "fd5f9eb23f15d342a80302b5539c7c8052067341e9b462dbfa6c317490518be0", "item_id": "92d0ea2516:7", "text": "Input Float"}
{"id": "2800e261981cd931c6c5895aaa30e499167eb5aaac77698cd153fe4dd189ce53", "item_id": "92d0ea2516:8", "text": "This is the incoming result of a pattern network where the output is a float or scalar value. This is useful for baking some procedural noise like PxrVoronoise."}
{"id": "971b974235a86ca628dcc713d6e2e8d975206cc84c858720ce046c2dab72855a", "item_id": "92d0ea2516:9", "text": "Filename"}
{"id": "3940a321f9571592a03ba929c6fc44367dd0b9005166a8f4c9cec2ce7e532e50", "item_id": "92d0ea2516:10", "text": "The input/output filename of the resulting baked point cloud."}
{"id": "bec9334c3960e949a9d4aa030e20a1394ed8a9bfab4919cbc299d6b57b897d46", "item_id": "92d0ea2516:11", "text": "This parameter is required."}
{"id": "c77d69d93d44e0adf53bed91c3500f1aeaad1cb0b8c1aaf5a2355ed98f7bafbe", "item_id": "92d0ea2516:12", "text": "Bake Mode"}
{"id": "f383a3bf8be07082b4097934988596974663539fda99b2fd5522ff36da90439a", "item_id": "92d0ea2516:13", "text": "Enable or disable point cloud baking."}
{"id": "8456352791573730647909c9c4a24cd8c3d23bf4148cfb5f59c950e75171fafe", "item_id": "92d0ea2516:14", "text": "File Type"}
{"id": "fd8476e3db23c3bdb53340de7b646fe47365c735548c87506904bcce915972d4", "item_id": "92d0ea2516:15", "text": "Output file type display driver: PTC (.ptc)"}
{"id": "b7003a845d3b1c6945edcee951c086c6f3f8d0bc3bb186aa5ebe8960d3d2d40a", "item_id": "92d0ea2516:17", "text": "Density of baking points per unit in world space. Larger values create more points."}
{"id": "b514ebf73921fea11670ca9640e96c27bc4e980867839d368eca5bd872bd174f", "item_id": "92d0ea2516:18", "text": "Coordinate System"}
{"id": "ec05670f3f505fbdf8b192a782ee1165f1c84b80bc2567a86b195111ea79e2d3", "item_id": "92d0ea2516:19", "text": "Output point cloud coordinate space:"}
{"id": "486ea46224d1bb4fb680f34f7c9ad96a8f24ec88be73ea8e5a6c65260e9cb8a7", "item_id": "92d0ea2516:20", "text": "world"}
{"id": "2958d416d08aa5a472d7b509036cb7eafd542add84527e66a145ea64cb4cdc75", "item_id": "92d0ea2516:21", "text": "object"}
{"id": "89e8b9518d92279489bbdee26f3dc646d921d89a15afbd3a3e0ad695328a3da0", "item_id": "92d0ea2516:22", "text": "camera"}
{"id": "32f9eee55145ad05c82efa36ecc286f890e5aef0d17b6080362fe8746b0ba474", "item_id": "92d0ea2516:23", "text": "ptex (outputs Ptex compatible point cloud (.ptc) file for use with the ptxmake utility."}
{"id": "5237d85f5b9e45261e6e6dd174d3d22cbd8de21328e48c1759de8717f149e647", "item_id": "92d0ea2516:24", "text": "Ptex requires that the geometry have a '__faceindex' primvar."}
