    {
      "item_id": "dad479bd6c:112",
      "text": "列出最近连接过的 Dashboard 用户（session mailbox）：",
      "ascii_letters": 23,
      "cjk_chars": 10
    },
    {
      "item_id": "dad479bd6c:113",
      "text": "http://ENGINE/Tractor/monitor?q=mboxes",
      "ascii_letters": 31,
