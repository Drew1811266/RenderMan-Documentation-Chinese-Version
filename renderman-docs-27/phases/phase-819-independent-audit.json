    {
      "item_id": "dad479bd6c:143",
      "text": "通过 engine 更改 blade 的 NIMBY 状态：",
      "ascii_letters": 16,
      "cjk_chars": 7
    },
    {
      "item_id": "dad479bd6c:144",
      "text": "首先发送 login 请求以接收 session ID（tsid），然后：",
      "ascii_letters": 18,
      "cjk_chars": 11
    },
    {
      "item_id": "dad479bd6c:145",
      "text": "http://ENGINE/Tractor/ctrl?q=battribute&tsid=SSS&b=BBB&nimby=NNN",
      "ascii_letters": 51,
      "cjk_chars": 0
    },
    {
      "item_id": "dad479bd6c:147",
      "text": "SSS = login 响应中的 tsid",
      "ascii_letters": 12,
      "cjk_chars": 4
    },
    {
      "item_id": "dad479bd6c:148",
      "text": "BBB = 标识 blade，格式如 \"blade_hname/192.168.0.1\"",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "dad479bd6c:152",
      "text": "nimby=jobOwner1,owner2,... -- blade 只接受指定用户拥有的作业",
      "ascii_letters": 23,
      "cjk_chars": 12
    },
    {
      "item_id": "dad479bd6c:154",
      "text": "http://BLADE/blade/ctrl?nimby=NNN",
      "ascii_letters": 26,
      "cjk_chars": 0
    },
    {
      "item_id": "dad479bd6c:158",
      "text": "http://ENGINE/Tractor/monitor?q=statistics",
      "ascii_letters": 35,
      "cjk_chars": 0
    },
    {
      "item_id": "dad479bd6c:162",
      "text": "\"dt\" - 每个 sampling interval 采样间隔的实际长度",
      "ascii_letters": 18,
      "cjk_chars": 11
    },
    {
      "item_id": "dad479bd6c:163",
      "text": "\"enla\" - engine normalized load avg，即 engine 主机上的 cpu load",
      "ascii_letters": 40,
      "cjk_chars": 5
    },
    {
      "item_id": "dad479bd6c:164",
      "text": "\"rtot\" - 该 interval 内 engine 入站查询总数",
      "ascii_letters": 18,
      "cjk_chars": 8
    },
    {
      "item_id": "dad479bd6c:165",
      "text": "\"asn\" - 该 interval 内完成的 assignment 分配数量",
      "ascii_letters": 21,
      "cjk_chars": 9
    },
    {
      "item_id": "dad479bd6c:166",
      "text": "\"nrun\" - 当前在 farm 上 dispatch 并运行的 cmd 数量",
      "ascii_letters": 19,
      "cjk_chars": 10
    },
    {
      "item_id": "dad479bd6c:168",
      "text": "\"ncrdy\" - 所有等待作业中 ready command 的总 backlog 积压量",
      "ascii_letters": 24,
      "cjk_chars": 12
    },
    {
      "item_id": "dad479bd6c:169",
      "text": "\"nslot\" - blade 报告的 farm 总 slot 数",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "dad479bd6c:170",
      "text": "\"nsin\" - farm 上正在使用的总 slot 数",
      "ascii_letters": 12,
      "cjk_chars": 8
    },
    {
      "item_id": "dad479bd6c:171",
      "text": "\"tecpu\" - 当前 tractor-engine 造成的 CPU 利用率估计值",
      "ascii_letters": 21,
      "cjk_chars": 11
    },
    {
      "item_id": "dad479bd6c:172",
      "text": "\"temem\" - 当前 tractor-engine 造成的 RAM 利用率估计值",
      "ascii_letters": 21,
      "cjk_chars": 11
    },
    {
      "item_id": "dad479bd6c:175",
      "text": "\"dbcqn\" - 待处理 job state 作业状态数据库 commit 的 backlog 积压量",
      "ascii_letters": 26,
      "cjk_chars": 14
    },
    {
      "item_id": "dad479bd6c:176",
      "text": "\"iqn\" - main intake queue 主接收队列上等待请求的 backlog 积压量",
      "ascii_letters": 25,
      "cjk_chars": 14
    },
    {
      "item_id": "dad479bd6c:177",
      "text": "\"sqn\" - shipper pool queue 发送池队列上等待请求的 backlog 积压量",
      "ascii_letters": 26,
      "cjk_chars": 14
    },
    {
      "item_id": "dad479bd6c:178",
      "text": "\"aqn\" - assigner queue 分配器队列上等待请求的 backlog 积压量",
      "ascii_letters": 23,
      "cjk_chars": 14
    },
    {
      "item_id": "dad479bd6c:179",
      "text": "\"qqn\" - job archive queue 作业归档队列上等待请求的 backlog 积压量",
      "ascii_letters": 25,
      "cjk_chars": 15
    },
    {
      "item_id": "dad479bd6c:180",
      "text": "\"jqn\" - job submission queue 作业提交队列上等待请求的 backlog 积压量",
      "ascii_letters": 28,
      "cjk_chars": 15
    },
    {
      "item_id": "dad479bd6c:181",
      "text": "\"mqn\" - monitor UI queue 监控 UI 队列上等待请求的 backlog 积压量",
      "ascii_letters": 26,
      "cjk_chars": 13
    },
    {
      "item_id": "dad479bd6c:182",
      "text": "\"nmbox\" - 已订阅的 UI session 会话",
      "ascii_letters": 14,
      "cjk_chars": 6
    },
    {
      "item_id": "dad479bd6c:184",
      "text": "http://ENGINE/Tractor/monitor?q=statslog",
      "ascii_letters": 33,
