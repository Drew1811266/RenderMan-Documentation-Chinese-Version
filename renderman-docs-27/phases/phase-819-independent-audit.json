    },
    {
      "item_id": "dad479bd6c:115",
      "text": "http://ENGINE/Tractor/ctrl?q=tracer&fmt=plain",
      "ascii_letters": 36,
      "cjk_chars": 0
    },
    {
      "item_id": "dad479bd6c:116",
      "text": "-- 下一次 assignment pass 分配遍历",
      "ascii_letters": 14,
      "cjk_chars": 7
    },
    {
      "item_id": "dad479bd6c:117",
      "text": "添加 &t=bbbb -- 针对名为 bbbb 的 blade；添加 &t=jjjj -- 针对 jid 为 jjjj 的作业",
      "ascii_letters": 26,
      "cjk_chars": 15
    },
    {
      "item_id": "dad479bd6c:119",
      "text": "http://ENGINE/Tractor/btrack?q=delist&id=hhhhh/aa.aa.aa.aa",
      "ascii_letters": 45,
      "cjk_chars": 0
    },
    {
      "item_id": "dad479bd6c:120",
      "text": "其中 hhhhh 是 blade 的 hostname 主机名，aa.aa.aa.aa 是该 blade 当前的 tcp/ip 地址。",
      "ascii_letters": 36,
      "cjk_chars": 14
    },
    {
      "item_id": "dad479bd6c:122",
      "text": "http://ENGINE/Tractor/ctrl?q=status&qlen=1",
