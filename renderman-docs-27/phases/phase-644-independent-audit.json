    {
      "item_id": "2f824cd655:2",
      "text": "Read：将 scene description 读入 renderer（如果已经读入，则更新它）",
      "ascii_letters": 28,
      "cjk_chars": 13
    },
    {
      "item_id": "2f824cd655:3",
      "text": "对 geometry 进行 tessellation（并可选 displacement）；构建 ray tracing data structures",
      "ascii_letters": 56,
      "cjk_chars": 8
    },
    {
      "item_id": "2f824cd655:4",
      "text": "生成并发射 camera rays",
      "ascii_letters": 10,
      "cjk_chars": 5
    },
    {
      "item_id": "2f824cd655:5",
      "text": "对 ray hit points 进行 shading：评估 shading networks、materials，并计算 direct illumination",
      "ascii_letters": 61,
      "cjk_chars": 8
    },
    {
      "item_id": "2f824cd655:6",
      "text": "生成 indirect illumination 所需的 rays；trace 这些 rays",
      "ascii_letters": 33,
      "cjk_chars": 7
    },
    {
      "item_id": "2f824cd655:8",
      "text": "第 1 步：场景转换（Step 1 Scene translation）",
      "ascii_letters": 20,
      "cjk_chars": 6
    },
    {
      "item_id": "2f824cd655:9",
      "text": "Step 2 Path tracing（路径追踪）",
      "ascii_letters": 15,
      "cjk_chars": 4
    },
    {
      "item_id": "2f824cd655:10",
      "text": "第 3 步：显示数据（Step 3. Display the data）",
      "ascii_letters": 18,
      "cjk_chars": 6
    },
    {
      "item_id": "2f824cd655:11",
      "text": "第 4 步：降噪处理（Step 4. Denoising）",
      "ascii_letters": 13,
      "cjk_chars": 6
    },
    {
      "item_id": "2f824cd655:12",
      "text": "场景转换阶段（Scene Translation）",
      "ascii_letters": 16,
      "cjk_chars": 6
    },
    {
      "item_id": "2f824cd655:13",
      "text": "对 geometry 进行 tessellation / 生成 micropolygons",
      "ascii_letters": 33,
      "cjk_chars": 5
    },
    {
      "item_id": "2f824cd655:14",
      "text": "把 data 放入 RAM（system 或/和 vram）",
      "ascii_letters": 17,
      "cjk_chars": 5
    },
    {
      "item_id": "2f824cd655:15",
      "text": "TIP：将 geometry 保持为 polygons 更便宜，但 RenderMan 更偏好 subdivision",
      "ascii_letters": 39,
      "cjk_chars": 11
    },
    {
      "item_id": "2f824cd655:17",
      "text": "Path tracing（路径追踪）",
      "ascii_letters": 11,
      "cjk_chars": 4
    },
    {
      "item_id": "2f824cd655:18",
      "text": "从 camera 发射光线 rays",
      "ascii_letters": 10,
      "cjk_chars": 5
    },
    {
      "item_id": "2f824cd655:20",
      "text": "发现 shaders 并进行 render",
      "ascii_letters": 13,
      "cjk_chars": 5
    },
    {
      "item_id": "2f824cd655:21",
      "text": "TIP：Procedural shading networks 总是比 textures 更昂贵。如果你确实需要 procedural networks，可以将它们 bake 到 disc。",
      "ascii_letters": 62,
      "cjk_chars": 19
    },
    {
