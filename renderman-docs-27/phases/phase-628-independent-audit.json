    {
      "item_id": "ae28f728cc:3",
      "text": "：Julia Boisvert、Evan Dickinson、Emmalie Hall 共同完成场景",
      "ascii_letters": 37,
      "cjk_chars": 6
    },
    {
      "item_id": "ae28f728cc:4",
      "text": "Overview（概览）",
      "ascii_letters": 8,
      "cjk_chars": 2
    },
    {
      "item_id": "ae28f728cc:5",
      "text": "Dragon Plush 是由艺术家 Julia Boisvert 进行 asset look development、Evan Dickinson 根据 Emmalie Hall 的概念进行建模的资产，该概念来自一部 group short（小组短片），标题为",
      "ascii_letters": 78,
      "cjk_chars": 33
    },
    {
      "item_id": "ae28f728cc:6",
      "text": "Serendipity",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "ae28f728cc:8",
      "text": "多层 felt groom 在 Houdini 中开发，并使用 RenderMan 和 LamaHairChiang shaders 渲染。该角色由多种材质和 hair types 构成，使用 Substance Painter、Houdini 和 RenderMan for Maya 的组合创建。",
      "ascii_letters": 94,
      "cjk_chars": 31
    },
    {
      "item_id": "ae28f728cc:10",
      "text": "About the Artist（艺术家简介）",
      "ascii_letters": 14,
      "cjk_chars": 5
    },
    {
      "item_id": "ae28f728cc:11",
      "text": "Julia Boisvert 是 Texas A&M University 的 Visualization 学生，对 look 和 visual development 感兴趣。她喜欢创作以环境为中心的 2D art，目前也希望进一步探索角色与 groom-driven look development。",
      "ascii_letters": 94,
      "cjk_chars": 34
