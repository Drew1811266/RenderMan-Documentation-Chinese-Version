{"id": "80d6d5cc4e1d4151fde1e60d5c413de6bebed40d099eaf24b14b2ae8eb701268", "item_id": "9a1300693e:0", "text": "Export OBJ and OpenEXR from ZBrush"}
{"id": "9c01bc6963215fa643b82f512026a45c32db69b9865be63cf9079abe7a48dbdd", "item_id": "9a1300693e:1", "text": "Shift+d to step down to the"}
{"id": "9a8d1bbe2f3ae3be3c2a1e5164996082a9b09fbe562db9f7e2444f9a8f02e652", "item_id": "9a1300693e:2", "text": "lowest subdivision."}
{"id": "56d036aa6432c9f16fff20f2c8bbf5c1e3d7d85a6d1953eb0e145ab5c366fe7e", "item_id": "9a1300693e:3", "text": "Lion Sculpted by Olivier Drion."}
{"id": "6cc42d8a7cf59bcb9f9544d8c7a7d359c157d0139eec046ab1d6e4a42c3aa88a", "item_id": "9a1300693e:8", "text": "Hit the Switch button in"}
{"id": "5a8cef3896837d50d7d1b8177aa658bce28fe0d25a8a68f85f1d4835d9722284", "item_id": "9a1300693e:9", "text": "Morph Target"}
{"id": "4ba9a8f27b8ad0e7b8c4f4901dfb2fce98f1e99f2a5ca24373169120acc4e961", "item_id": "9a1300693e:10", "text": "to switch to the original model"}
{"id": "7bd90ff622eda66b0536a11543db506eedd3932038f5870a1386113949b064fc", "item_id": "9a1300693e:11", "text": ".  If you don't have a Morph Target setup, please consult ZBrush documentation on how to set up a Morph Target."}
{"id": "911ba2bf1bde1c68d7e9b974dc21281e2897a3435a46c7132287134ca9136d0a", "item_id": "9a1300693e:12", "text": "In Preferences, Import/Export, Vector Displacement Map, set the"}
{"id": "5d28aff48bf9014e42d96124089b6a1230313d793584c3ce69dee41a61fe3cb2", "item_id": "9a1300693e:13", "text": "Tangent FlipAndSwitch to 43."}
{"id": "f92e42bb0f19b8bd9abc6b07c5625b50963417410eab636e8c8968b83064812c", "item_id": "9a1300693e:14", "text": "There are 48 different vector displacement because a red channel for a renderer may be up while down for the another renderer.  RenderMan is 43."}
{"id": "43153527689de65eaff2aa7519bc703b53d90a07d715fa3789b8322b7b3e8f71", "item_id": "9a1300693e:15", "text": "Recent changes meant a change from Tangent FlipAndSwitch 41, if your displacement is not correct, you may need this setting rather than 43."}
{"id": "4634b764aa458b9d306775e48e8b16ddfe4919c882a5e15a733c5541e1af1fe0", "item_id": "9a1300693e:16", "text": "On the Tools, Vector Displacement Map, set"}
{"id": "c5edf0d1f5baa2b89c66cb691f60384e0ec60c856c2531beeb5f63743e2192cd", "item_id": "9a1300693e:17", "text": "vd Tangent"}
{"id": "8cfec103d41ddcd8e9c1ccdbf6c137521283d159756c6c387332efb2a3edc661", "item_id": "9a1300693e:18", "text": "on, set"}
{"id": "f6ef3021329c337b62eda63c4baf0437fd3753b910b4e8b9844a541e5f3857d1", "item_id": "9a1300693e:19", "text": "vd 32 Bit"}
{"id": "eabbceb14c2d8652576b0f99c10f49406a6b38a7b1e21d04ebd1c371bc87f4a2", "item_id": "9a1300693e:20", "text": "to export a 32-bit map otherwise it is 16-bit, set"}
{"id": "1bf550c5fbd26c5ffd2562439a42052663c75a88b82f3b76836bc7fddd5a5166", "item_id": "9a1300693e:21", "text": "vd SUV"}
{"id": "ea49191e86e2905325c63257807a80d76b97c696dc986c6245c6c70109d9f424", "item_id": "9a1300693e:22", "text": "for smooth UV to on,"}
{"id": "093bd156afa8b882b9c762e252f9e2fb5c8955bc189e0af69d083941f4fa28c2", "item_id": "9a1300693e:23", "text": "vd Normals"}
{"id": "c3632a6f4ebf5d6533226587eb25d18babff2340fa10c534a31b399f215ce941", "item_id": "9a1300693e:24", "text": "to on."}
{"id": "e870200141af46af06270b2466899f3d2903b4051154233ec84014773fff9ad9", "item_id": "9a1300693e:25", "text": "Click on CreateAndExport VDMap to export the maps and OBJ. The maps will be exported as OpenEXR."}
{"id": "20659ad5f0972cda0363f160d390c5f839ea09453b528467673bd13efd153aef", "item_id": "9a1300693e:26", "text": "Import OBJ and Add Subdiv Scheme"}
{"id": "d4f3fbefac9db879491ec7fb561a98f922878f6dc2b594731b6de1cd04782fdb", "item_id": "9a1300693e:27", "text": "For some subdivision surfaces, it may be helpful to add the attribute \"Dice Watertight\" to resolve seam issues. This may incur a memory overhead so it is not on by default."}
{"id": "4804fd90aa80237bf2fd24c1eeacbb0df81f14be337eb3f0ede0f44190cd3e0b", "item_id": "9a1300693e:28", "text": "Import the OBJ you just exported from ZBrush.  For its shape node, add"}
{"id": "e3857f4d93679a02be31f95758374a744f0946848efff2570e1dcd28e10a62d6", "item_id": "9a1300693e:29", "text": "Attributes|RenderMan|Subdiv Scheme:"}
{"id": "8cd70b7548bffcceb2e3f350d184cdc393d6493f4bc0073d93f18584fffca596", "item_id": "9a1300693e:30", "text": "Assign Displacement Shader"}
{"id": "a2a769e959cfd33c6744a4099fd4d901e8e2814f5dce4ca3f330aece5991d1ef", "item_id": "9a1300693e:41", "text": "Create a"}
{"id": "750e96fc109c260a0f6873fdceb8a13390f0e85f21462ba29a4f4986ab22d0c2", "item_id": "9a1300693e:33", "text": "node. Set the Filename to your exported ZBrush EXR map. Keep all parameters at their defaults."}
{"id": "0b0e9ab670036c644bddfd28f667c38ba3ae862c46398da670f565d2f3a2ee79", "item_id": "9a1300693e:36", "text": "node. Set Displacement Type to"}
{"id": "5653de957685a1c3d5e037afd1ff512e45076060d05993db8896dac40803199b", "item_id": "9a1300693e:37", "text": "ZBrush Vector"}
{"id": "c3c4a1075e57748f6edf49db4e9efb7532c158a6abcfafc94c8e7918ffcd242c", "item_id": "9a1300693e:38", "text": "and Vector Space to"}
{"id": "9390d6186e7bcfbd8c86df0b5f069f0f50c8e142b253ae3dd7a3894709b16665", "item_id": "9a1300693e:39", "text": "Tangent"}
{"id": "022543dbe3b58a1681fca19925453b701d7a289d04c90ad0f56ea226c7858d89", "item_id": "9a1300693e:42", "text": "PxrDisplace"}
{"id": "ee82bd9bc506163ac896b4860a2f02298135871ab36f8b07d287bbae57b8728e", "item_id": "9a1300693e:43", "text": "node (this is the displacement shader that actually displaces your surface)."}
{"id": "71f4a11e4e43d2218d678b14cfa45c044c71acf325c9a1c45022508b3de9494f", "item_id": "9a1300693e:44", "text": "Connect PxrTexture's output Result RGB to PxrDispTransform's Disp Vector."}
{"id": "354502a0db18ba1152f42fcec386e241d53668e56a4c3bde7e6f23c60069b899", "item_id": "9a1300693e:45", "text": "Connect PxrDispTransform's Result XYZ to PxrDisplace's Disp Vector. Your graph should look like this:"}
{"id": "9fd728c66c9a256b121472dabf32a34317aed01d8427d70ec830289cf23a7cc8", "item_id": "9a1300693e:46", "text": "Add"}
{"id": "b336a381456906a409f4a23a1e2fdcdc211c614ca7c3c0d3c298839342eb13b0", "item_id": "9a1300693e:48", "text": ", assign it to the model and add some"}
{"id": "6fe6c35728c65f0351ca3e4f151b8010215afec63174941e71755ea1d8440475", "item_id": "9a1300693e:49", "text": "lights"}
{"id": "6cfdcfeea21743fb5d35088e0bc9516bdbfe8e796f7d87ff701804987ad6315e", "item_id": "9a1300693e:50", "text": ", set the displacement bound appropriately, and render!"}
{"id": "8f2b0e64314d73b772b7db4326e901df159bf994b1679644c932f6c13ed87a0f", "item_id": "9a1300693e:51", "text": "Maya Project"}
{"id": "24525994465cdce0db95d12e8822e6934f4e84e674e99aba129e57ceefa7a480", "item_id": "9a1300693e:52", "text": "Download a Maya Project and test the official Zbrush vector displacement scene."}
{"id": "6b1cad58bcaaf0ed253ab132fd2fbbcd1f604d4142817b38b03234bda3481cea", "item_id": "9a1300693e:53", "text": "Download RfM"}
{"id": "121194215d5d77751afdedd2eb9238f1b1dd23dd3b5f160bb0fe3e60f19f4643", "item_id": "9a1300693e:54", "text": "Or a rib file..."}
{"id": "3a26235e3ae73ab2ffb1cd2d02b326dc2642c577b82fe07666f5d26903725997", "item_id": "9a1300693e:55", "text": "Download RIB"}
