{"id": "0ddc89a547b680db1cc1c539db9e03ff23f7fea8700f6f68e6c94c5a94f33132", "item_id": "319d053aee:0", "text": "Known Limitations"}
{"id": "fa9da5754ccfd409028cef393a17acae922be11469a590d1f2b99d9f45349337", "item_id": "319d053aee:1", "text": "Geometry"}
{"id": "c45ee09503684e36534a34243b897fb167b2b5df7d1885870284c4b4a49edc02", "item_id": "319d053aee:2", "text": "NURBS and Implicits not supported"}
{"id": "495acbf9ec2c90cb4e36d217cd2435571ec1fa351cc3053c14403ee124e6bb44", "item_id": "319d053aee:3", "text": "Shading"}
{"id": "cc7fef852eedc002e78cf99fe3db0a2c64c0b7eccb99e85da0df0c4310c6c6eb", "item_id": "319d053aee:4", "text": "For best performance, you should manually pre-convert your textures via"}
{"id": "f03ea00b18d9aa9880720aacfb2abc16fe6ae8e4342fd78d93c1c73a4059b349", "item_id": "319d053aee:5", "text": "txmake"}
{"id": "249dc3b0b837a94a4421b9ef0b65e98e9d6183d082e2bad03f9d9e20252ffc9a", "item_id": "319d053aee:6", "text": "or use the Texture Manager"}
{"id": "bfa40e79b1ca72374df4339988a60ce5b13338c14212ff96fea4181f0d07994f", "item_id": "319d053aee:7", "text": "The dynamic and uniform array node is not expected to work in Solaris"}
{"id": "16529ec5619a9c68ce445f90a1fd031478a10f57d667818b4a1f644d54a033e7", "item_id": "319d053aee:8", "text": "Image Tool"}
{"id": "ec85355dfc5b5228ff94434356aa29798ead567a295c24dc259a7b3aa1a1fcdd", "item_id": "319d053aee:9", "text": "Rendering to IT with ACES currently needs the env variable"}
{"id": "84324b2cf5b2ab6b70305c9a78918e7b7d82c2883372612191d7ed6d23f38f13", "item_id": "319d053aee:10", "text": "IT_OCIOV1"}
{"id": "d08431b4e5807c7777beb67c521900f9a62e1ee3417eddb8b00d3189cae34074", "item_id": "319d053aee:11", "text": "to be set to your ACES config.ocio"}
{"id": "bf9f221b63658c39b7dc8c81d5ac8712bd8c21fff1dbbe7d2a58e0ebc02b3037", "item_id": "319d053aee:12", "text": "Crop tool and image selector is not supported"}
{"id": "6386f97e31ef35b2de97b7e2c5b135e18a1e400563ce815fbf77657fa2d46b54", "item_id": "319d053aee:13", "text": "OSX"}
{"id": "2c741cac828152b6a8686c62689fdf41200fd364882de7dac33a13a2bef1cb64", "item_id": "319d053aee:14", "text": "M1 on OSX is not currently supported."}
{"id": "233fe09b43b1f006d445faa02fe4f99e80c38304b8c0992d2e6b4eed63172f13", "item_id": "319d053aee:15", "text": "You can run via Rosetta, but be warned, performance won't be as good until native support is added."}
