  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "4184a1c17c:0",
      "text": "这个 command line tool 由 engine 使用，用于自动启动和停止后端 PostgreSQL relational database server。Site admins 也可以使用它执行各种 database maintenance tasks。",
      "ascii_letters": 89,
      "cjk_chars": 26
    },
    {
      "item_id": "4184a1c17c:1",
      "text": "Usage: tractor-dbctl [options]（用法）",
      "ascii_letters": 24,
      "cjk_chars": 2
    },
    {
      "item_id": "4184a1c17c:4",
      "text": "Description（说明字段内容）",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "4184a1c17c:5",
      "text": "--start-for-engine",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:6",
      "text": "启动 postgresql server，并按 db.config 中的配置自动 build/upgrade schema（engine 使用）",
      "ascii_letters": 48,
      "cjk_chars": 12
    },
    {
      "item_id": "4184a1c17c:7",
      "text": "--stop-for-engine",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:8",
      "text": "按 db.config 中的配置停止 postgresql server（engine 使用）",
      "ascii_letters": 30,
      "cjk_chars": 9
    },
    {
      "item_id": "4184a1c17c:10",
      "text": "启动 postgresql 数据库 server",
      "ascii_letters": 16,
      "cjk_chars": 5
    },
    {
      "item_id": "4184a1c17c:12",
      "text": "停止 postgresql server；如果 engine 无法自动完成停止，或 postgresql server 是手动启动的，可以用它关闭 postgresql；engine 正在运行时不要执行此命令。",
      "ascii_letters": 54,
      "cjk_chars": 37
    },
    {
      "item_id": "4184a1c17c:14",
      "text": "检查 postgresql server 的状态",
      "ascii_letters": 16,
      "cjk_chars": 5
    },
    {
      "item_id": "4184a1c17c:16",
      "text": "初始化 postgresql data directory；server 必须未运行",
      "ascii_letters": 29,
      "cjk_chars": 8
    },
    {
      "item_id": "4184a1c17c:18",
      "text": "构建 tractor database；server 必须正在运行",
      "ascii_letters": 21,
      "cjk_chars": 8
    },
    {
      "item_id": "4184a1c17c:20",
      "text": "移除 postgres database directory；server 必须未运行；这会移除",
      "ascii_letters": 31,
      "cjk_chars": 11
    },
    {
      "item_id": "4184a1c17c:22",
      "text": "当前和历史 job 与 blade information。",
      "ascii_letters": 19,
      "cjk_chars": 6
    },
    {
      "item_id": "4184a1c17c:24",
      "text": "更新 database schema 数据库结构",
      "ascii_letters": 14,
      "cjk_chars": 7
    },
    {
      "item_id": "4184a1c17c:25",
      "text": "--check-upgrade",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:27",
      "text": "--no-auto-upgrade",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:28",
      "text": "阻止 database schema 数据库结构自动 upgrade 升级",
      "ascii_letters": 21,
      "cjk_chars": 11
    },
    {
      "item_id": "4184a1c17c:29",
      "text": "--purge-jobs",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:33",
      "text": "--reset-job-counter",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:34",
      "text": "重置 job id counter，使 job ids（jids）从 1 开始；只能与 --purge-jobs 一起使用",
      "ascii_letters": 31,
      "cjk_chars": 13
    },
    {
      "item_id": "4184a1c17c:35",
      "text": "--show-params",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:36",
      "text": "显示存储在 database 中的 configuration parameters",
      "ascii_letters": 31,
      "cjk_chars": 7
    },
    {
      "item_id": "4184a1c17c:37",
      "text": "--update-params",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:38",
      "text": "将 config files 中定义的某些 configuration parameters 推送到 database",
      "ascii_letters": 42,
      "cjk_chars": 10
    },
    {
      "item_id": "4184a1c17c:39",
      "text": "--logs-usage",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:40",
      "text": "报告 postgresql log files 使用的 disk space",
      "ascii_letters": 27,
      "cjk_chars": 5
    },
    {
      "item_id": "4184a1c17c:41",
      "text": "--purge-logs",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:42",
      "text": "移除 postgresql 日志 log files 文件",
      "ascii_letters": 18,
      "cjk_chars": 6
    },
    {
      "item_id": "4184a1c17c:43",
      "text": "--backup=filename",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:44",
      "text": "将 backup 写入指定 file；server 必须未运行。",
      "ascii_letters": 16,
      "cjk_chars": 10
    },
    {
      "item_id": "4184a1c17c:45",
      "text": "--restore=filename",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:46",
      "text": "从指定 backup file 恢复 database；server 必须未运行",
      "ascii_letters": 24,
      "cjk_chars": 10
    },
    {
      "item_id": "4184a1c17c:47",
      "text": "--config-dir=path",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "4184a1c17c:48",
      "text": "tractor config directory 的配置 path 路径",
      "ascii_letters": 26,
      "cjk_chars": 5
    },
    {
      "item_id": "4184a1c17c:51",
      "text": "除 errors 外，抑制所有 output",
      "ascii_letters": 12,
      "cjk_chars": 6
    },
    {
      "item_id": "4184a1c17c:57",
      "text": "打印 debug messages 调试消息",
      "ascii_letters": 13,
      "cjk_chars": 6
    }
  ],
