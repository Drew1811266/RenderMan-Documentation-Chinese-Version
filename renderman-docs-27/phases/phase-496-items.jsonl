{"id": "250cafa6cb9c08f9b4732140a1d71bc46148f2b9f37d1f8b8a9712324e093b91", "item_id": "9dd6ac6f66:0", "text": "Export FBX from Mudbox"}
{"id": "a8408fb5985cb35cb28baa109b9eb68f5866e792129c37b74e72128990f20a3b", "item_id": "9dd6ac6f66:1", "text": "Before you start sculpting, export your Fbx from Mudbox."}
{"id": "40d419684c409a6e6512ee4282aa7b4472d57765059c6b3c42b09ce1fd13cf98", "item_id": "9dd6ac6f66:2", "text": "Export an OpenEXR from Mudbox"}
{"id": "13b23e06a58533a871c01e074ce5feb0e6c96185d4a248f62fa15d6ccf146602", "item_id": "9dd6ac6f66:3", "text": "Export a PTex from Mudbox"}
{"id": "3e36400281798dcee9a684fbd91c03b7032a5e590e6b7cb01d04d1c239d4032c", "item_id": "9dd6ac6f66:4", "text": "Import FBX and Add Subdiv Scheme"}
{"id": "22c01c6262ce77ffb9abdf0d2ad096a105768c955f40d2096e0e86f27e007ae8", "item_id": "9dd6ac6f66:5", "text": "Import the FBX you just exported from Mudbox.  For its shape node, add"}
{"id": "e3857f4d93679a02be31f95758374a744f0946848efff2570e1dcd28e10a62d6", "item_id": "9dd6ac6f66:6", "text": "Attributes|RenderMan|Subdiv Scheme:"}
{"id": "bd1b116c190f14a7fec6454999cd0b57473681d85f184b67470b28e48b16f31a", "item_id": "9dd6ac6f66:7", "text": "Assign Displacement Shader (UV Texture)"}
{"id": "a2a769e959cfd33c6744a4099fd4d901e8e2814f5dce4ca3f330aece5991d1ef", "item_id": "9dd6ac6f66:34", "text": "Create a"}
{"id": "ac08f8cb0f47b054413be8a9a9007ae1a9e87ba9478301a235e111ca3d3c7c47", "item_id": "9dd6ac6f66:10", "text": "node. Set the Filename to your exported Muxbox EXR map. Keep all parameters at their defaults."}
{"id": "4759498ac2a719c619e2c8cf8ee60af2d2407425e95d308eb208425b2a6d427a", "item_id": "9dd6ac6f66:27", "text": "Create"}
{"id": "0b0e9ab670036c644bddfd28f667c38ba3ae862c46398da670f565d2f3a2ee79", "item_id": "9dd6ac6f66:29", "text": "node. Set Displacement Type to"}
{"id": "9acab15aa80cd62ea880231e2f79f62aefaee7ad0bcc74f80fb81b2b399e8c1f", "item_id": "9dd6ac6f66:30", "text": "Mudbox Vector"}
{"id": "c3c4a1075e57748f6edf49db4e9efb7532c158a6abcfafc94c8e7918ffcd242c", "item_id": "9dd6ac6f66:31", "text": "and Vector Space to"}
{"id": "9390d6186e7bcfbd8c86df0b5f069f0f50c8e142b253ae3dd7a3894709b16665", "item_id": "9dd6ac6f66:16", "text": "Tangent"}
{"id": "022543dbe3b58a1681fca19925453b701d7a289d04c90ad0f56ea226c7858d89", "item_id": "9dd6ac6f66:35", "text": "PxrDisplace"}
{"id": "ee82bd9bc506163ac896b4860a2f02298135871ab36f8b07d287bbae57b8728e", "item_id": "9dd6ac6f66:36", "text": "node (this is the displacement shader that actually displaces your surface)."}
{"id": "71f4a11e4e43d2218d678b14cfa45c044c71acf325c9a1c45022508b3de9494f", "item_id": "9dd6ac6f66:37", "text": "Connect PxrTexture's output Result RGB to PxrDispTransform's Disp Vector."}
{"id": "354502a0db18ba1152f42fcec386e241d53668e56a4c3bde7e6f23c60069b899", "item_id": "9dd6ac6f66:38", "text": "Connect PxrDispTransform's Result XYZ to PxrDisplace's Disp Vector. Your graph should look like this:"}
{"id": "88bc9a8ba569e60dc61b448650225cd2fea893fc5aa756422b3e9a35277167cd", "item_id": "9dd6ac6f66:23", "text": "Assign Displacement Shader (PTex)"}
{"id": "955f4d475bb6a22d836253b921bf273ed12f22a6996aa53991fa9f067eeadbe4", "item_id": "9dd6ac6f66:25", "text": "PxrPtexture"}
{"id": "137ef2b68958689329d98fcf03491d5a662e22c27dbb44ac474ebd02f69e1bef", "item_id": "9dd6ac6f66:26", "text": "node. Set the Filename to your exported Muxbox ptx map. Keep all parameters at their defaults."}
{"id": "78ae647dc5544d227130a0682a51e30bc7777fbb6d8a8f17007463a3ecd1d524", "item_id": "9dd6ac6f66:32", "text": "World"}
{"id": "6d89eb7d0938564938636b4a5ee73c09e55c2e6e5aaa9e3016781bf54805e8d3", "item_id": "9dd6ac6f66:39", "text": "Render"}
{"id": "9fd728c66c9a256b121472dabf32a34317aed01d8427d70ec830289cf23a7cc8", "item_id": "9dd6ac6f66:40", "text": "Add"}
{"id": "b336a381456906a409f4a23a1e2fdcdc211c614ca7c3c0d3c298839342eb13b0", "item_id": "9dd6ac6f66:42", "text": ", assign it to the model and add some"}
{"id": "6fe6c35728c65f0351ca3e4f151b8010215afec63174941e71755ea1d8440475", "item_id": "9dd6ac6f66:43", "text": "lights"}
{"id": "6cfdcfeea21743fb5d35088e0bc9516bdbfe8e796f7d87ff701804987ad6315e", "item_id": "9dd6ac6f66:44", "text": ", set the displacement bound appropriately, and render!"}
{"id": "a01b94f9c92dee146736e1811f02c11174c8f2dbcb4b2e120c252be50de84fdf", "item_id": "9dd6ac6f66:45", "text": "Toad King created created by Craig Barr, Autodesk Media and Entertainment."}
