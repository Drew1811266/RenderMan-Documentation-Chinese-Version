{"id": "d7cc49765e90ea651e1a96153556b2c9a2e7dd9d0db3913084df9d23f9f1647f", "item_id": "dd41c144e5:0", "text": "Starting with version 24 RenderMan includes an entirely new diagnostics sub-system, re-written from the ground up to incorporate live, configurable statistics. See RenderMan page"}
{"id": "a903a293d9eb401fea8de4f582edb81f5048c81bf11eb92d8c814125758956ef", "item_id": "dd41c144e5:3", "text": "To continue to use the legacy statistics, check"}
{"id": "e37d2dac77451a7401295fe23c8f179137984e6597bd2261ab9b59074004d296", "item_id": "dd41c144e5:4", "text": "Render Statistics"}
