{"id": "7e0d42307c38f463570d9e5953c99394b748424b29e8b8a47ee288d04074d351", "item_id": "dd41c144e5:6", "text": "Options | Statistics"}
{"id": "e76128b80aaa71eb9d7b280cc1295b9308f71f724be77a340665444710bdb18c", "item_id": "dd41c144e5:7", "text": "Tab:"}
{"id": "de37280f77fb930c2dbefe3b4d521ea5cf7a5109e77ddb63e0877ac9b24062e1", "item_id": "dd41c144e5:8", "text": "By default, it uses the Disk File's path and base name."}
{"id": "85f9bd962375c4f59ec8a794ed45fa7984e1a7c1191f1df72cd588ac552403ca", "item_id": "dd41c144e5:9", "text": "You can view the output xml file with any web browser.  See"}
{"id": "817e36c5fad8df7c381b769f3d0dd4f52e7aa51ade629853d413e607263315b3", "item_id": "dd41c144e5:10", "text": "Legacy Diagnostics"}
