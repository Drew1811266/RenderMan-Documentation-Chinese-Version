{"id": "07ef0c56c60f1b4fdca4698b28fbff7c32f9a479ffcdcd7c0f829ad0f5927e48", "item_id": "d4a23e66c6:0", "text": "Produces a color that represents the radiation emitted by an ideal black body heated at the given temperature in the visible spectrum. This allows you to easily create plausible light colors based on standard temperature measurement."}
{"id": "b958ce8b871ab36b3ceee0e0f012b6182962b2db7926be0a670149f9fbd00b84", "item_id": "d4a23e66c6:2", "text": "Temperature"}
{"id": "5ce7df041c34b68552d501368663cb3b96b7643d4ea4c607bd6ab6bc62bbd672", "item_id": "d4a23e66c6:3", "text": "The temperature (in kelvin) of the black body. Color temperatures over 5,000K are called cool colors (bluish white), while lower color temperatures (2,700 to 3,000 K) are called warm colors (yellowish white through red)."}
{"id": "171ef9140267b2097f83844ccfcd92d6acecf7ff71943eaf02d6fa35d003d674", "item_id": "d4a23e66c6:4", "text": "Top: linear ramp from 1,000K to 6,500K at -22 exposure. Bottom: linear ramp from 5,000K to 15,000K at -28 exposure."}
{"id": "2165909b54c15a440ee80baf7077a35f677c8c40514514a60eec5b275ee8dfae", "item_id": "d4a23e66c6:5", "text": "Temperature Value"}
{"id": "0e570ca6fabe24f94e52c1833f3ffd25567022beb826fa16891f3322051bc221", "item_id": "d4a23e66c6:6", "text": "Source"}
{"id": "0a285d3e3b1ff7d2ff746ff6b45a48681e55083f5450b13f75fed6149e5b1421", "item_id": "d4a23e66c6:7", "text": "Match flame"}
{"id": "8df1214871f0f58433e62c5bed442e1a07a7af26b6f88e17acc0b37009fe5b4a", "item_id": "d4a23e66c6:8", "text": "Candle flame, sunset/sunrise"}
{"id": "ba5b702a04deab02da764543f1fb50a64489403af2f41e63340962f3694006e3", "item_id": "d4a23e66c6:9", "text": "2700 to 3300"}
{"id": "4bd9e4d2c9cb5fa710d9b9062cede29c2f4d6f4ae28d7dcfba57323fedef784d", "item_id": "d4a23e66c6:10", "text": "Incandescent lamps"}
{"id": "fb9568174a7a8b0c2bfa1bc875ff38de9c0aeb082fdb3c9ea3b17b6d838f366e", "item_id": "d4a23e66c6:11", "text": "Soft (or warm) white compact fluorescent lamps"}
{"id": "56585230a2767ae86ef7d5673f3077650106e695f99495674a59335ecbf53528", "item_id": "d4a23e66c6:12", "text": "Studio lamps, photofloods, etc."}
{"id": "94359696d4dc746633fb788548088eecafda637fae1ca9cfc931c8add2ddca2d", "item_id": "d4a23e66c6:13", "text": "Studio \"CP\" light"}
{"id": "9dcdd14332d61f5f2b80e18ee78545669824311b6b2254ed6735aec208218d70", "item_id": "d4a23e66c6:14", "text": "4100 to 4150"}
{"id": "79191631cbf1cad7c8dd661880a1e63533a426640ec6c647aa8354228413f2cb", "item_id": "d4a23e66c6:15", "text": "Moonlight"}
{"id": "985b7835bc53800565dad86fe7f196359807a3f652b0e73aa0332bc69642f3ec", "item_id": "d4a23e66c6:16", "text": "Horizon daylight"}
{"id": "ad869122eaf567102fc415d386a3a77227e3f6452d0c86aae6e93ebec58034c5", "item_id": "d4a23e66c6:17", "text": "5500 to 6000"}
{"id": "2a86ab841b48800d1013046c38dde517a38a86a18f743db66e308d1a28f7c826", "item_id": "d4a23e66c6:18", "text": "Vertical daylight, electronic flash"}
{"id": "ed8617bd4173e6cf220b13d9c36b1eb75379bf6628a75ad5a71d8b05f9d27df9", "item_id": "d4a23e66c6:19", "text": "Xenon short-arc lamp"}
{"id": "d2d15386559da323af53b97dee5f8432d95f5f2fbd4e69e5f88a831c1c836732", "item_id": "d4a23e66c6:20", "text": "Daylight, overcast"}
{"id": "3a9875129f8c0f623dc2ce46a070d65c28fab586995ce755c85ab6bf0f7aaee7", "item_id": "d4a23e66c6:21", "text": "6500 to 10500"}
{"id": "fef3191830b862d5d6067aa99738531d8d50b72ef4ed50448e0fb41ed4e726cc", "item_id": "d4a23e66c6:22", "text": "LCD or CRT screen"}
{"id": "4a2b558169735aa8cd540480fd04c6a3b4d1e46284c5a3f7151fa96f223b66d2", "item_id": "d4a23e66c6:23", "text": "15000 to 27000"}
{"id": "efe60247101eaf5cc1a069055d1f2b1d260f68fb36420f67751a6a295aeb3ded", "item_id": "d4a23e66c6:24", "text": "Clear blue poleward sky"}
{"id": "a7efd3df130129ce58a44698cad3db8787dfed1d4b99580e7b826752aa7e04ba", "item_id": "d4a23e66c6:25", "text": "Physical Intensity"}
{"id": "754efef1d4b07612226af555fc8777a495810144511ca9869113f52f2b19a510", "item_id": "d4a23e66c6:26", "text": "When set to 1, the color will emit the correct amount of energy. WARNING: Your color will become super intense."}
{"id": "cc5454a4b7ce211370dcd2aa0ae58d6b564eee7940b42de516d05f5b269c414b", "item_id": "d4a23e66c6:27", "text": "Exposure"}
{"id": "3d0e573365d562899bff876d52e265ce532d63127644868c003bdf89a3b40ecd", "item_id": "d4a23e66c6:28", "text": "Use exposure to adjust the amount of emited energy. Very useful if physical intensity is above zero."}
{"id": "8b76e2df9050f924b018cff8809cbc580f39a71664984ae54adf99defe9eaa2e", "item_id": "d4a23e66c6:29", "text": "Output Parameters"}
{"id": "d76cd2ea3537dbac1a9b90ba977fe5ad654d6f7f3c36b060963224d8b5611f99", "item_id": "d4a23e66c6:30", "text": "resultRGB"}
{"id": "09ef84bf4efcc02fe93fca7f96e1a716ab65c9672f2571764245caa9e255052f", "item_id": "d4a23e66c6:31", "text": "The color emitted from the black body that was heated to the given temperature."}
{"id": "c9223602a8320733dcf0de118c9880f9df06acdfdb068bb26ba166fc96c52d6c", "item_id": "d4a23e66c6:32", "text": "resultR"}
{"id": "c1ce276296aa97e85eded6362e0ad2b80973bc92228513facedd911006df8937", "item_id": "d4a23e66c6:33", "text": "The R channel from the resultRGB output."}
{"id": "2e12f103dc4a4b216b21cc6f017371b08507fc67f2a1ad9f133aa333afe0fc11", "item_id": "d4a23e66c6:34", "text": "resultG"}
{"id": "009cc7a7eb8d7664fe8e8a024e817626113dd5198fc3a164f5ec297f2fa68da3", "item_id": "d4a23e66c6:35", "text": "The G channel from the resultRGB output."}
{"id": "c3719f180d82ecafb70ce347c3499e7668a3d9262533cadae303c770922865ff", "item_id": "d4a23e66c6:36", "text": "resultB"}
{"id": "d1e2217f59ea1bd29de7ec3ac2c05c763eca2c3bf612f3e04ff7cfd536f9f8e0", "item_id": "d4a23e66c6:37", "text": "The B channel from the resultRGB output."}
