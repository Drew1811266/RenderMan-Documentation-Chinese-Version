  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "e4747f35b8:0",
      "text": "本课展示如何从 storytelling perspective 来组织你的 shading layers。",
      "ascii_letters": 36,
      "cjk_chars": 12
    },
    {
      "item_id": "e4747f35b8:1",
      "text": "带着明确目的去 scratch surfaces，思考 dirt 为什么会聚集在特定 crevices，以及 decals 如何为 props 添加 story。",
      "ascii_letters": 43,
      "cjk_chars": 25
    },
    {
      "item_id": "e4747f35b8:2",
      "text": "这个 shader layering 中的每个 stage 都是一个 LamaLayer，mix 由 hand-painted mask 或 procedural mask 控制。",
      "ascii_letters": 60,
      "cjk_chars": 14
    },
    {
      "item_id": "e4747f35b8:7",
      "text": "OTTO 不得不在 factory default 下重新喷涂成 grey。",
      "ascii_letters": 22,
      "cjk_chars": 10
    },
    {
      "item_id": "e4747f35b8:9",
      "text": "由于 OTTO 现在已经显得 far worse for wear，他被留在 corner 里慢慢 rust。",
      "ascii_letters": 29,
      "cjk_chars": 15
    },
    {
      "item_id": "e4747f35b8:10",
      "text": "随着 time 过去，他被遗忘了，只是站在 factory 的 corner 里，不断 gathering dirt and dust。",
      "ascii_letters": 37,
      "cjk_chars": 17
    }
  ],
