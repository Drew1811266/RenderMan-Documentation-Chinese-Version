      "ascii_letters": 25,
      "cjk_chars": 9
    },
    {
      "item_id": "c2987eac15:65",
      "text": "Display or Sample Filters",
      "ascii_letters": 22,
      "cjk_chars": 0
    },
    {
      "item_id": "c2987eac15:66",
      "text": "，例如 Stylized Looks、Cryptomatte 和其他 effects。",
