{"id": "352763f9814782a563a3fdf6cfd26652726048bb5d6009feb737dba4c76d9ad8", "item_id": "aa0962e34c:0", "text": "Welcome to your new space!"}
{"id": "b8b94437bb3376c0930c92139edb8dace33cada9c16806e1d2ce81bee655d39c", "item_id": "aa0962e34c:1", "text": "Spaces help your team structure, organize, and share work, so every team member has visibility into institutional knowledge and access to the information they need to do their best work."}
{"id": "509fb5245bc6960a8d7554aa6739f6fc139e4447ce5004ea24506c003dfab756", "item_id": "aa0962e34c:2", "text": "Get started with the basics"}
{"id": "02cf36522a702caed8ab053add6758f2c6c7259d3622226e94a038e77ebca81c", "item_id": "aa0962e34c:3", "text": "Start editing this content:"}
{"id": "7a789f72517897bbce7d2a8f4674b9fdc411e62aee7efa7b61b6bf8281f75833", "item_id": "aa0962e34c:4", "text": "Click the pencil icon ✏️ or"}
{"id": "bd6d66ddb701a5ba570dc18418028cc5030f6c8133e71c2f807744e226233de0", "item_id": "aa0962e34c:5", "text": "on your keyboard to edit and start typing. You can edit anywhere."}
{"id": "8a043f55ef38458453a5d90a4a8528f6aeef45cbf281fdaf0413fb7cbf9f3058", "item_id": "aa0962e34c:6", "text": "Hit"}
{"id": "31ebdf9571447f26a55e4cc47818138e3a3221f1f941faae21f14b40bf64329d", "item_id": "aa0962e34c:7", "text": "to see all the types of content you can add to your page. Try"}
{"id": "5c836e411f588c6681e4de6aa8f85a795b1433ae431c056c31b60d8dff8b3492", "item_id": "aa0962e34c:9", "text": "Use the toolbar at the top to play around with"}
{"id": "795ea3efa43d0872b63bf0067be97553b46983e4f075097669391e9d15388ecc", "item_id": "aa0962e34c:10", "text": "font"}
{"id": "c4c680876abbec38a537c2a2956380ac92f313cba1337083e52126bfa3f0d887", "item_id": "aa0962e34c:11", "text": "formatt"}
{"id": "91af7d847f80f22c5ef0d11588ce9bb5d10d9ba7e8f83f380f807ab3066eb289", "item_id": "aa0962e34c:12", "text": "ing"}
{"id": "e265284a6ebaac8e0bdb1015dc9b364f1c89734e8e7b1956fb7dd0cb86b77602", "item_id": "aa0962e34c:13", "text": ", and more"}
{"id": "95ba4ed9329f4a2591e3bd89366e38cca9b26aeab3e72106ae60ad6757e05495", "item_id": "aa0962e34c:14", "text": "Click"}
{"id": "3c706a2858bbe1cbc2369f88608855747443e124d6521b7299f308976b5b1334", "item_id": "aa0962e34c:15", "text": "to save your draft or"}
{"id": "0efadf7721f7c1d356223c54a097add586cfb523e5720cabfa07d961fdf8de7a", "item_id": "aa0962e34c:16", "text": "when your page is ready to be shared"}
{"id": "aa27cd3178e980d67abccd9b10447d28082af75d9e591df7ac21b1370f789da3", "item_id": "aa0962e34c:17", "text": "🪄 Need some inspiration?"}
{"id": "a7357a3845b35e30c3285279fb91a6348ba1a316fe1596ac7251df6df0c4f068", "item_id": "aa0962e34c:18", "text": "Check out our"}
{"id": "686b12ef98e1fb3159e91da76e60a17a508af8fc77d06898b46bf3f55afb329a", "item_id": "aa0962e34c:19", "text": "Confluence best practices guide"}
{"id": "1952bb9256fbd616736ff4ab08f44ba9a3591be67825082c7b5a3f23869dd265", "item_id": "aa0962e34c:21", "text": "Get a quick intro into what spaces are and how to best use them at"}
{"id": "971680f81d215812a56498e32bf9f2581e7a6c2ddccf28cb93339d3ed9f7fc2e", "item_id": "aa0962e34c:22", "text": "Set up your site and spaces"}
{"id": "9469303b0616a863f33789e951c700ac0b16ab836ba7e182b3f6178338e66252", "item_id": "aa0962e34c:24", "text": "Check out our guide for ideas on how to"}
{"id": "7f9aac2a30dd9adb5705984103d355cd9e3562352fddd45bc26ec07064e0b614", "item_id": "aa0962e34c:25", "text": "set up your space overview"}
{"id": "8d363e764497c17f0a8e5a779421594ebef4c3f3042e00677cf5399558c08224", "item_id": "aa0962e34c:27", "text": "If starting from a blank space is daunting, try using one of the"}
{"id": "811c1d6619d20b0879f0593ef01e77062a7bc92ef359772a313461c5d2af5da2", "item_id": "aa0962e34c:28", "text": "space templates"}
