  "raw_ascii_heavy": [
    {
      "item_id": "4549dc28d9:0",
      "translation": "Aggregate Volumes（聚合体积）",
      "words": [
        "Aggregate",
        "Volumes"
      ]
    },
    {
      "item_id": "4549dc28d9:1",
      "translation": "聚合体积可以通过把多个体积组合成一个供渲染器处理的单一结构来缩短体积渲染时间。要在 RfH 中开始使用 aggregate volumes（聚合体积），需要两个步骤：在体积几何体上设置聚合名称，并在积分器中指定匹配的聚合名称。",
      "words": [
        "RfH",
        "aggregate",
        "volumes"
      ]
    },
    {
      "item_id": "4549dc28d9:3",
      "translation": "首先，选择包含要归入某个聚合的体积的 OBJ 节点。然后可以使用 RenderMan 工具架上的 “Aggregate” shelf tool（Aggregate 工具架工具）、RenderMan 菜单中的 “aggregate Volume” menu tool（aggregate Volume 菜单工具），也可以手动向 OBJ 添加 ri_volume_aggregate 渲染参数。",
      "words": [
        "OBJ",
        "RenderMan",
        "Aggregate",
        "shelf",
        "tool",
        "Aggregate",
        "RenderMan",
        "aggregate",
        "Volume",
        "menu",
        "tool",
        "aggregate",
        "Volume",
        "OBJ",
        "ri_volume_aggregate"
      ]
    },
    {
      "item_id": "4549dc28d9:4",
      "translation": "如果使用任一聚合工具，会弹出窗口要求你指定聚合名称。默认值为 globalVolumeAggregate。接受后，该工具会使用给定的聚合名称，把 ri_volume_aggregate 和 ri_volume_dsominmax 添加到 obj 上。",
      "words": [
        "globalVolumeAggregate",
        "ri_volume_aggregate",
        "ri_volume_dsominmax",
        "obj"
      ]
    },
    {
      "item_id": "4549dc28d9:5",
      "translation": "也可以改在 Geometry（几何体）级别指定 volume aggregates（体积聚合）。为此，需要添加一个名为 ri_volume_aggregate 的 primitive attribute（图元属性）。如果 ri_volume_aggregate 同时设置为对象参数和几何体属性，则会使用几何体属性值。",
      "words": [
        "Geometry",
        "volume",
        "aggregates",
        "ri_volume_aggregate",
        "primitive",
        "attribute",
        "ri_volume_aggregate"
      ]
    },
    {
      "item_id": "4549dc28d9:6",
      "translation": "在 Solaris 中没有用于设置 volume aggregates（体积聚合）的 custom（自定义）工具。必须使用 Geometry Render Setting LOP 添加该设置。",
      "words": [
        "Solaris",
        "volume",
        "aggregates",
        "custom",
        "Geometry",
        "Render",
        "Setting",
        "LOP"
      ]
    },
    {
      "item_id": "4549dc28d9:8",
      "translation": "PxrPathTracer 有四个与 aggregate volumes（聚合体积）相关的参数。在简单情况下，只需设置全局 “Volume Aggregate” 参数。但由于标准 visibility attributes（可见性属性）在体积聚合内部不起作用，你可能会遇到需要为每种可见性类型（camera、indirect 和 transmission）分别指定聚合名称的情况。这些名称可以在另外三个覆盖参数中指定。",
      "words": [
        "PxrPathTracer",
        "aggregate",
        "volumes",
        "Volume",
        "Aggregate",
        "visibility",
        "attributes",
        "camera",
        "indirect",
        "transmission"
      ]
    }
  ],
