  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "1890bc26a7:0",
      "text": "Path tracing（路径追踪）是一种生成 digital images 的方法，它模拟 light 在 virtual world 中如何与 objects 交互。",
      "ascii_letters": 48,
      "cjk_chars": 22
    },
    {
      "item_id": "1890bc26a7:1",
      "text": "通过向 scene 中发射 rays（line segments）并跟踪它们在 objects 之间的 bounce，来追踪 light 的路径。",
      "ascii_letters": 39,
      "cjk_chars": 21
    },
    {
      "item_id": "1890bc26a7:2",
      "text": "Path tracing 的名称来自计算 light 从 light source 到 camera 的完整路径。",
      "ascii_letters": 33,
      "cjk_chars": 14
    },
    {
      "item_id": "1890bc26a7:3",
      "text": "Light 可能会在 virtual scene 内的许多 objects 之间 bounce。当一条 light ray 命中 surface 时，它会 bounce 并创建新的 light rays。因此，一条 path 可以由多条 rays 组成。",
      "ascii_letters": 68,
      "cjk_chars": 34
    },
    {
      "item_id": "1890bc26a7:5",
      "text": "下面由 Disney Animation Studios 制作的视频，对 Path Tracing 提供了出色的概览。",
      "ascii_letters": 33,
      "cjk_chars": 17
    }
  ],
