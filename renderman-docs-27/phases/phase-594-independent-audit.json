  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "c660d97132:1",
      "text": "：HDR Studio Maps",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "c660d97132:3",
      "text": "Julien Duval",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "c660d97132:5",
      "text": "：Attach these maps to RenderMan lights（将这些 maps 连接到 RenderMan lights）",
      "ascii_letters": 51,
      "cjk_chars": 6
    },
    {
      "item_id": "c660d97132:6",
      "text": "Overview（资源概览）",
      "ascii_letters": 8,
      "cjk_chars": 4
    },
    {
      "item_id": "c660d97132:7",
      "text": "这些 light maps 是在 studio 中拍摄，并编辑为 HDRI textures。",
      "ascii_letters": 27,
      "cjk_chars": 11
    },
    {
      "item_id": "c660d97132:8",
      "text": "给 lights 添加 texture，是获得非完美 reflections 和 shadows 的好方法。你可以把它们 plug into PxrRectLight 的 color map attribute。Textures 已预转换为 tex format，并以易于 drag-and-drop 的 folder 形式提供给 RenderMan Preset Browser。",
      "ascii_letters": 124,
      "cjk_chars": 36
    },
    {
      "item_id": "c660d97132:10",
      "text": "soft box 完全 neutral、desaturated。原始尺寸为 65 x 65 cm。",
      "ascii_letters": 28,
      "cjk_chars": 7
    },
    {
      "item_id": "c660d97132:11",
      "text": "spot 以 6500K 平衡，并带有轻微 warm variations。原始尺寸直径为 18 cm。",
      "ascii_letters": 21,
      "cjk_chars": 15
    },
    {
      "item_id": "c660d97132:12",
      "text": "kitchen 以 6500K 拍摄，提供 warm color。原始尺寸为 36 x 6 cm。",
      "ascii_letters": 20,
      "cjk_chars": 10
    },
    {
      "item_id": "c660d97132:13",
      "text": "kitchen 使用基于 light source 的 white balance 拍摄。原始尺寸为 36 x 6 cm。",
      "ascii_letters": 33,
      "cjk_chars": 12
    },
    {
      "item_id": "c660d97132:14",
      "text": "注意，high resolution versions 只应在 closeups 中使用；在大多数 cases 下，low resolution versions 应该已经足够。",
      "ascii_letters": 56,
      "cjk_chars": 19
    },
    {
      "item_id": "c660d97132:17",
      "text": "Asset Library > LightRigs",
      "ascii_letters": 21,
      "cjk_chars": 0
    },
    {
      "item_id": "c660d97132:18",
      "text": "folder。文件按 category 组织，可以在 preset browser 中轻松搜索。",
      "ascii_letters": 27,
      "cjk_chars": 13
    },
    {
      "item_id": "c660d97132:19",
      "text": "请确保把安装目录中的 RenderManAssetLibrary folder 转移到具有 full writing privileges 的位置。",
      "ascii_letters": 48,
      "cjk_chars": 18
    },
    {
      "item_id": "c660d97132:20",
      "text": "当你转移 Materials folder 并把 Asset Library 移到其他位置后，必须通过 Maya preferences 告诉 Maya 使用新的 path。",
      "ascii_letters": 50,
      "cjk_chars": 23
    },
    {
      "item_id": "c660d97132:21",
      "text": "或者，你可以在 Maya.env file 中创建一个新的 environment variable，以确保始终指向正确的 folder：",
      "ascii_letters": 36,
      "cjk_chars": 23
    },
    {
      "item_id": "c660d97132:23",
      "text": "Public Domain. Free of known copyright restrictions.（公有领域，无已知版权限制。）",
      "ascii_letters": 44,
      "cjk_chars": 11
    }
  ],
