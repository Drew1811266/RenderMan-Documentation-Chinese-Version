    {
      "item_id": "e361c27c27:106",
      "text": "Monitor Controls（监视器控制）",
      "ascii_letters": 15,
      "cjk_chars": 5
    },
    {
      "item_id": "e361c27c27:107",
      "text": "monitor controls 可让你访问 Gamma 和 Exposure 等设置。最右侧按钮会将 Gamma 和 Exposure 控制项重置为默认值。还有一些有用的 monitor control 快捷键，包括：",
      "ascii_letters": 55,
      "cjk_chars": 38
    },
    {
      "item_id": "e361c27c27:108",
      "text": "Exposure Up 1 F-Stop（曝光增加 1 档）",
      "ascii_letters": 15,
      "cjk_chars": 5
    },
    {
      "item_id": "e361c27c27:111",
      "text": "Exposure Down 1 F-Stop（曝光降低 1 档）",
      "ascii_letters": 17,
      "cjk_chars": 5
