    {
      "item_id": "d8961de1ea:0",
      "text": "Preferences Panel",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "d8961de1ea:1",
      "text": "点击 username 后激活的 drop down menu 中的 \"Preferences\"，即可显示 dashboard preferences pane。",
      "ascii_letters": 55,
      "cjk_chars": 12
    },
    {
      "item_id": "d8961de1ea:3",
      "text": "job graph 现在支持一种新的 display mode，可以以 collapsed format 显示 job graph。job graph 的 preference 定义 task graph 首次显示时的 initial display mode。两个选项分别是完全展开所有 task，或将所有 task 折叠到 job node。",
      "ascii_letters": 102,
      "cjk_chars": 42
    },
    {
      "item_id": "d8961de1ea:5",
      "text": "选择 jobs page 的 layout scheme。当前有两种 layout：一种让 job list 使用 browser window 的整个宽度；另一种把 task graph 放在 job list 右侧。",
      "ascii_letters": 62,
      "cjk_chars": 26
    },
    {
      "item_id": "d8961de1ea:7",
      "text": "Job List 支持从 engine 自动 reload job data。reload interval 定义两次自动 reload job data 之间的时间（以秒为单位）。使用 filter 时，job reload 有助于让显示与 filter 更同步。",
      "ascii_letters": 74,
      "cjk_chars": 34
    },
    {
      "item_id": "d8961de1ea:10",
      "text": "在 Job Graph 中显示 Log 指示器",
      "ascii_letters": 11,
      "cjk_chars": 7
    },
    {
      "item_id": "d8961de1ea:11",
      "text": "控制 job graph 中 log indicator 的可见性显示。",
      "ascii_letters": 20,
      "cjk_chars": 9
    },
    {
      "item_id": "d8961de1ea:12",
      "text": "在 Job Graph 中显示 Preview 指示器",
      "ascii_letters": 15,
      "cjk_chars": 7
    },
    {
      "item_id": "d8961de1ea:13",
      "text": "控制 job graph 中 preview indicator 的可见性显示。",
      "ascii_letters": 24,
      "cjk_chars": 9
    },
    {
      "item_id": "d8961de1ea:15",
      "text": "控制 scrollbar 的宽度。",
      "ascii_letters": 9,
      "cjk_chars": 5
    },
    {
      "item_id": "d8961de1ea:17",
      "text": "控制重启 job 时是否显示 confirmation dialog。",
      "ascii_letters": 21,
      "cjk_chars": 9
    },
    {
      "item_id": "d8961de1ea:19",
      "text": "控制重启 actively running task 时是否显示 confirmation dialog。",
      "ascii_letters": 37,
      "cjk_chars": 9
    },
    {
      "item_id": "d8961de1ea:21",
      "text": "控制请求对所选 job 中的 Retry All error task 执行操作时是否显示 confirmation dialog。",
      "ascii_letters": 38,
      "cjk_chars": 18
    },
    {
      "item_id": "d8961de1ea:23",
      "text": "控制请求对所选 job 中的 Skip All error task 执行操作时是否显示 confirmation dialog。",
      "ascii_letters": 37,
      "cjk_chars": 18
    },
    {
      "item_id": "d8961de1ea:25",
