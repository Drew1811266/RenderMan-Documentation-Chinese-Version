{"id": "75b38c876a58011b075a7173dc8f84f5fbc4fb0ca90e1ddc0e6dd469c76929bd", "item_id": "2e5ba288f1:0", "text": "Licensing"}
{"id": "420e2d4380e8b92ab6a139872c3b38407f2b30f4843c9f97de79cd0f394925e6", "item_id": "2e5ba288f1:1", "text": "Stylized Looks"}
{"id": "b61c577d1d94fce070444cd2510a985ffaf8bcca2c006a167ef521c3a6bbc980", "item_id": "2e5ba288f1:2", "text": "is only available to commercial customers of RenderMan."}
{"id": "82a3077efa0b253963ecb825a2e5bc18da7ef465ba24c4415fb3cb4212c6c524", "item_id": "2e5ba288f1:3", "text": "The innovative Stylized Looks toolset allows RenderMan to deliver images beyond photorealism. Artists can render images that look like cartoons, illustrations, or watercolors. This flexible system allows the creation of unique looks and is limited only by imagination."}
{"id": "320fef86610825ac82d7e61a9e8bfb4a1c63616bb5be532d28d0724a873705cb", "item_id": "2e5ba288f1:4", "text": "What’s new in RenderMan 27 Stylized Looks"}
