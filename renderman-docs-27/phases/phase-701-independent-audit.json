  "actionable_ascii_heavy_residuals": [],
  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "8c7ae5e5f3:1",
      "text": "foo.format",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:4",
      "text": "的 RenderMan texture file。",
      "ascii_letters": 20,
      "cjk_chars": 1
    },
    {
      "item_id": "8c7ae5e5f3:6",
      "text": "原有内容（如果有）会被静默覆盖。输入文件支持以下格式：BMP、DPX、GIF、HDR、JPEG、MayaIFF、OpenEXR、PIC、PNG、PPM、Pixar DeepData、Pixar Texture、SGI、TGA、TIFF、XPM、Z-File。",
      "ascii_letters": 82,
      "cjk_chars": 23
    },
    {
      "item_id": "8c7ae5e5f3:13",
      "text": "<m> 控制 texture coordinates 位于第一个 ST tile 之外时返回的 texture values。",
      "ascii_letters": 38,
      "cjk_chars": 13
    },
    {
      "item_id": "8c7ae5e5f3:17",
      "text": "适用于非周期性的 texture access。",
      "ascii_letters": 13,
      "cjk_chars": 8
    },
    {
      "item_id": "8c7ae5e5f3:18",
      "text": "periodic",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:19",
      "text": "适用于周期性的 texture access。",
      "ascii_letters": 13,
      "cjk_chars": 7
    },
    {
      "item_id": "8c7ae5e5f3:21",
      "text": "图像尺寸调整（Image Resize）",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:28",
      "text": "-format openexr",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:29",
      "text": "<r> resize operation 可以是以下选项之一：",
      "ascii_letters": 16,
      "cjk_chars": 9
    },
    {
      "item_id": "8c7ae5e5f3:46",
      "text": "调整尺寸滤镜（Resize Filter）",
      "ascii_letters": 12,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:47",
      "text": "-filter <f>  在 resized 时应用以下 filter choices 之一。",
      "ascii_letters": 27,
      "cjk_chars": 8
    },
    {
      "item_id": "8c7ae5e5f3:51",
      "text": "triangle",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:53",
      "text": "gaussian",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:54",
      "text": "gaussian-soft",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:55",
      "text": "catmull-rom",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:56",
      "text": "mitchell",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:60",
      "text": "blackman-harris",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:61",
      "text": "默认值为 'catmull-rom'。",
      "ascii_letters": 10,
      "cjk_chars": 4
    },
    {
      "item_id": "8c7ae5e5f3:62",
      "text": "图像模糊控制（Image Blur：-blur <f> / -sblur <f> / -tblur <f>）",
      "ascii_letters": 26,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:64",
      "text": "-sblur <f>  只将 blur 应用到 S",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:65",
      "text": "-tblue <f>  只将 blur 应用到 T",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:68",
      "text": "Alpha 边缘像素扩展（Bleed Alpha）",
      "ascii_letters": 15,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:69",
      "text": "-bleedalpha",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:70",
      "text": "围绕 alpha mask 径向扩张 pixel values，适用于",
      "ascii_letters": 20,
      "cjk_chars": 9
    },
    {
      "item_id": "8c7ae5e5f3:71",
      "text": "texture baking",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:72",
      "text": "。这个 gutter 有助于避免 ST seams 周围的 sampling artifacts。",
      "ascii_letters": 30,
      "cjk_chars": 10
    },
    {
      "item_id": "8c7ae5e5f3:73",
      "text": "mipmapping",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:75",
      "text": "mipmap 模式（Mipmap Pattern）",
      "ascii_letters": 19,
      "cjk_chars": 2
    },
    {
      "item_id": "8c7ae5e5f3:76",
      "text": "-pattern <p>",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:79",
      "text": "texture file 中只存储一张 texture image。这实际上会禁用 mipmapping，并且对大多数应用来说会导致非常差的 texturing performance。",
      "ascii_letters": 53,
      "cjk_chars": 30
    },
    {
      "item_id": "8c7ae5e5f3:80",
      "text": "diagonal",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:83",
      "text": "texture file 中存储完整的一组 texture images（即 ripmap）。这会让 texture file 约为原始 texture image 的四倍大小。",
      "ascii_letters": 53,
      "cjk_chars": 21
    },
    {
      "item_id": "8c7ae5e5f3:84",
      "text": "默认值为 'diagonal'。",
      "ascii_letters": 8,
      "cjk_chars": 4
    },
    {
      "item_id": "8c7ae5e5f3:85",
      "text": "mipmap 来源（Mipmap Source）",
      "ascii_letters": 18,
      "cjk_chars": 2
    },
    {
      "item_id": "8c7ae5e5f3:86",
      "text": "-mipfrom <s/n>",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:89",
      "text": "previous",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:92",
      "text": "从 source image 创建所有 mipmaps。",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:94",
      "text": "指定显式的 mipmap level。",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:96",
      "text": "用户 mipmap（User Mipmaps）",
      "ascii_letters": 17,
      "cjk_chars": 2
    },
    {
      "item_id": "8c7ae5e5f3:97",
      "text": "-usermipmap <picnames>",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:99",
      "text": "第一张图像决定要写入 texture 的 transformation matrix。",
      "ascii_letters": 27,
      "cjk_chars": 11
    },
    {
      "item_id": "8c7ae5e5f3:100",
      "text": "第一张图像决定 texture 的 dimensions。",
      "ascii_letters": 17,
      "cjk_chars": 8
    },
    {
      "item_id": "8c7ae5e5f3:106",
      "text": "mipmap 滤镜（Mipmap Filter）",
      "ascii_letters": 18,
      "cjk_chars": 2
    },
    {
      "item_id": "8c7ae5e5f3:107",
      "text": "-mipfilter <f>",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:111",
      "text": "triangle",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:113",
      "text": "gaussian",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:114",
      "text": "gaussian-soft",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:115",
      "text": "catmull-rom",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:116",
      "text": "mitchell",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:120",
      "text": "blackman-harris",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:122",
      "text": "环境贴图设置（Environment Map）",
      "ascii_letters": 14,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:123",
      "text": "经纬度贴图（Lat-Long Map）",
      "ascii_letters": 10,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:125",
      "text": "创建经纬度环境贴图（lat-long environment map）。",
      "ascii_letters": 21,
      "cjk_chars": 9
    },
    {
      "item_id": "8c7ae5e5f3:126",
      "text": "漫反射卷积（Diffuse Convolution）",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:127",
      "text": "-diffconv <brdf,res,mip>",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:128",
      "text": "txmake 可以生成 side-band data，用于 Monte Carlo integration 的 control variates method。side-bands 是 diffuse BRDF 与 environment map 的 convolution。仅支持 lat-long maps。支持 OpenEXR 和 TIFF 文件。",
      "ascii_letters": 127,
      "cjk_chars": 18
    },
    {
      "item_id": "8c7ae5e5f3:130",
      "text": "是 {Lambert, KajiyaKay} 之一。此项为必需。",
      "ascii_letters": 16,
      "cjk_chars": 8
    },
    {
      "item_id": "8c7ae5e5f3:133",
      "text": "\"mip\" 是可选的 literal。如果添加，convolution image 会生成 mip-map；否则不会生成（其他 mip levels 将包含 black）。",
      "ascii_letters": 46,
      "cjk_chars": 22
    },
    {
      "item_id": "8c7ae5e5f3:136",
      "text": "从 6 张图像创建 cube environment map，例如：",
      "ascii_letters": 18,
      "cjk_chars": 8
    },
    {
      "item_id": "8c7ae5e5f3:137",
      "text": "Environment cube maps 会使用特定格式的 layout 创建：tiff、pixar、openexr。",
      "ascii_letters": 41,
      "cjk_chars": 10
    },
    {
      "item_id": "8c7ae5e5f3:138",
      "text": "视场角设置（Filed of View）",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:140",
      "text": "<f> 是以度为单位的 cube map field-of-view。",
      "ascii_letters": 19,
      "cjk_chars": 7
    },
    {
      "item_id": "8c7ae5e5f3:141",
      "text": "Ptex 立方体贴图（Ptex Cube Map）",
      "ascii_letters": 15,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:142",
      "text": "-penvcube",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:143",
      "text": "从 6 张图像创建 ptex cube environment map。",
      "ascii_letters": 22,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:144",
      "text": "球谐带数（Spherical Harmonic Bands）",
      "ascii_letters": 22,
      "cjk_chars": 4
    },
    {
      "item_id": "8c7ae5e5f3:145",
      "text": "-shbands <n>",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:146",
      "text": "嵌入 <n> 个 spherical harmonic bands。",
      "ascii_letters": 23,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:148",
      "text": "图像文件格式（Image Format）",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:150",
      "text": "<f> 对应底层 texture image format（对于生成的大型 >4GB 图像，必须使用 openexr）：",
      "ascii_letters": 28,
      "cjk_chars": 17
    },
    {
      "item_id": "8c7ae5e5f3:154",
      "text": "默认 tiff 是在 rendermn.ini 中作为 configuration option 指定的。",
      "ascii_letters": 34,
      "cjk_chars": 10
    },
    {
      "item_id": "8c7ae5e5f3:155",
      "text": "数据压缩方式（Data Compression）",
      "ascii_letters": 15,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:156",
      "text": "-compression <c>",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:157",
      "text": "对于 Pixar format，<c> 为：",
      "ascii_letters": 12,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:159",
      "text": "lossless",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:161",
      "text": "对于 OpenEXR format，<c> 为：",
      "ascii_letters": 14,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:169",
      "text": "TIFF format 始终使用 LZW compression。Pixar format 默认使用 'lossless' compression，而 OpenEXR 默认使用 'zip'。",
      "ascii_letters": 64,
      "cjk_chars": 13
    },
    {
      "item_id": "8c7ae5e5f3:171",
      "text": "-byte / -short / -half / -float",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:172",
      "text": "控制文件格式的数据类型（file format datatype）。",
      "ascii_letters": 18,
      "cjk_chars": 11
    },
    {
      "item_id": "8c7ae5e5f3:174",
      "text": "输出无符号 8-bit 数据（unsigned 8-bit data）",
      "ascii_letters": 18,
      "cjk_chars": 7
    },
    {
      "item_id": "8c7ae5e5f3:176",
      "text": "输出有符号 16-bit 数据（signed 16-bit data）",
      "ascii_letters": 16,
      "cjk_chars": 7
    },
    {
      "item_id": "8c7ae5e5f3:178",
      "text": "输出 half-float data（OpenEXR/penv）",
      "ascii_letters": 24,
      "cjk_chars": 2
    },
    {
      "item_id": "8c7ae5e5f3:180",
      "text": "输出 float data",
      "ascii_letters": 9,
      "cjk_chars": 2
    },
    {
      "item_id": "8c7ae5e5f3:183",
      "text": "默认情况下，texture file 中 channels 的数量和顺序直接取决于 image file 中的 channel 集合。RGBA picture 会生成四通道 texture，RGB picture 会生成三通道 texture，R picture 会生成单通道 texture。-ch option 可用于选择并重新排序 image file 的 channels。channel #'s 用于选择 image file 的 channels。Channels indexing 从 0 开始。对于 RGB，`-ch 1` 只会选择 image file 的 green channel，并将其放入 texture file 的 channel 0。可以使用数字列表选择多个 channels，例如 `-ch 0,1,2` 和 `-ch 0:2` 会选择 image file 的 RGB channels，而 `-ch 2,1,0` 会选择相同 channels，但顺序为 blue、red、green。",
      "ascii_letters": 249,
      "cjk_chars": 100
    },
    {
      "item_id": "8c7ae5e5f3:184",
      "text": "显示窗口设置（Display Window）",
      "ascii_letters": 13,
      "cjk_chars": 6
    },
    {
      "item_id": "8c7ae5e5f3:185",
      "text": "-extraargs displaywindow",
      "ascii_letters": 22,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:186",
      "text": "displaywindow 仅用于 exr input。",
      "ascii_letters": 21,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:187",
      "text": "Bump To Roughness（凹凸转 Roughness）",
      "ascii_letters": 24,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:188",
      "text": "Bump to roughness 要求所有 bump maps 或 normal maps 都转换为 *.b2r texture。",
      "ascii_letters": 42,
      "cjk_chars": 9
    },
    {
      "item_id": "8c7ae5e5f3:189",
      "text": "b2r textures 包含 5 个 channels，并且始终以 OpenEXR format 生成，因为它能为 half-float data 提供最佳 compression ratios。",
      "ascii_letters": 61,
      "cjk_chars": 19
    },
    {
      "item_id": "8c7ae5e5f3:190",
      "text": "-bumprough <f> <i> <n> <iu> <iv> <i>",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:191",
      "text": "<f>：roughness scaling factor",
      "ascii_letters": 23,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:193",
      "text": "<i>：invert bump signal（0|1）",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:195",
      "text": "<n>：interpret as normal map（0|1）",
      "ascii_letters": 21,
      "cjk_chars": 0
    },
    {
      "item_id": "8c7ae5e5f3:197",
      "text": "<iu>：在 U 方向 invert map（0|1）",
      "ascii_letters": 12,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:199",
      "text": "<iv>：在 V 方向 invert map（0|1）",
      "ascii_letters": 12,
      "cjk_chars": 3
    },
    {
      "item_id": "8c7ae5e5f3:201",
      "text": "<iv>：重新拟合 slope distribution，以获得更好的结果。",
      "ascii_letters": 19,
      "cjk_chars": 12
    },
    {
      "item_id": "8c7ae5e5f3:204",
      "text": "典型的 txmake bump map 调用如下：",
      "ascii_letters": 13,
      "cjk_chars": 7
    },
    {
      "item_id": "8c7ae5e5f3:205",
      "text": "normal map 的调用如下：",
      "ascii_letters": 9,
      "cjk_chars": 5
    },
    {
      "item_id": "8c7ae5e5f3:206",
      "text": "已弃用的阴影贴图（Shadow Map deprecated）",
      "ascii_letters": 19,
      "cjk_chars": 8
    },
    {
      "item_id": "8c7ae5e5f3:209",
      "text": "从 z-image 创建阴影贴图（shadow map）。",
      "ascii_letters": 15,
      "cjk_chars": 7
    },
    {
      "item_id": "8c7ae5e5f3:210",
      "text": "最小/最大阴影贴图（Min/Max Shadow Map）",
