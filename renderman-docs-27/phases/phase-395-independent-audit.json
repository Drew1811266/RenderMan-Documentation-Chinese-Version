    },
    {
      "item_id": "5761800d77:48",
      "translation": "“it”",
      "words": [
        "it"
      ]
    },
    {
      "item_id": "5761800d77:49",
      "translation": "，这是一个稳健的 framebuffer/render view window（帧缓冲/渲染视图窗口），提供完整的 floating point support（浮点支持）和强大灵活的 catalog（目录）。“it” 是快速强大的成像工具，具备通常只有高端独立产品才有的生产级图像处理和合成功能。得益于它与 plugin（插件）的集成以及全新的 Python 脚本接口，“it” 让用户能够把复杂的渲染后图像操作纳入自己的渲染管线。",
      "words": [
        "framebuffer",
        "render",
        "view",
        "window",
        "floating",
        "point",
        "support",
        "catalog",
        "it",
        "plugin",
        "Python",
        "it"
      ]
    },
    {
      "item_id": "5761800d77:50",
      "translation": "RenderMan Features（RenderMan 功能）",
      "words": [
        "RenderMan",
        "Features",
        "RenderMan"
      ]
    },
    {
      "item_id": "5761800d77:51",
      "translation": "Photo Realistic RenderMan (PRMan) 设计目标是在快速、易用的同时生成生产级渲染；global illumination（全局照明）开箱即用，live rendering（实时渲染）为艺术家提供快速迭代。RenderMan for Katana 通过标准节点和 PRMan 专用节点支持 PRMan 的各个方面。",
      "words": [
        "Photo",
        "Realistic",
        "RenderMan",
        "PRMan",
        "global",
