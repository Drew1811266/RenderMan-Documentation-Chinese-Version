  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "7f9487d36e:1",
      "text": "：Creating a French Bakery（创建法式面包店场景）",
      "ascii_letters": 21,
      "cjk_chars": 9
    },
    {
      "item_id": "7f9487d36e:2",
      "text": "Created & Written by（创作与撰写人员名单）",
      "ascii_letters": 16,
      "cjk_chars": 9
    },
    {
      "item_id": "7f9487d36e:3",
      "text": "：Marion Machelard、Emma Siret 和 Céline Soubrane",
      "ascii_letters": 37,
      "cjk_chars": 1
    },
    {
      "item_id": "7f9487d36e:5",
      "text": "Leif Pedersen（编辑：Leif Pedersen）",
      "ascii_letters": 24,
      "cjk_chars": 2
    },
    {
      "item_id": "7f9487d36e:6",
      "text": "现在是早上 7 点。黎明的 golden light 覆盖着 shop windows 和 pastry。温热面包的香气充满房间。第一批 croissants 刚从烤箱出炉……要开始美好的一天，当然没有比 French way 更好的方式了！走进这个 immersive scene，让 rustic charm 与传统 French craftsmanship 鲜活起来。",
      "ascii_letters": 91,
      "cjk_chars": 64
    },
    {
      "item_id": "7f9487d36e:8",
      "text": "由于 group work 是我们工作中不可或缺的一部分，共同完成这类 project 总是非常有刺激性；这也是我们希望以这种方式呈现 tutorial 的原因。Céline Soubrane 负责 modelling，Emma Siret 负责 texturing/shading，Marion Machelard 负责 lighting/compositing。",
      "ascii_letters": 105,
      "cjk_chars": 53
    },
    {
      "item_id": "7f9487d36e:16",
      "text": "About the Artist（艺术家介绍与创作背景）",
      "ascii_letters": 14,
      "cjk_chars": 10
    },
    {
      "item_id": "7f9487d36e:17",
      "text": "Céline Soubrane（艺术家姓名）",
      "ascii_letters": 13,
      "cjk_chars": 5
    },
    {
      "item_id": "7f9487d36e:18",
      "text": "在学习 animation 和 VFX 之后，Céline Soubrane 成为一名专注于 environments 的 CG artist。她目前在 Quantic Dream 担任 environment artist，参与 Star Wars Eclipse。",
      "ascii_letters": 89,
      "cjk_chars": 22
    },
    {
      "item_id": "7f9487d36e:19",
      "text": "Emma Siret（艺术家姓名）",
      "ascii_letters": 9,
      "cjk_chars": 5
    },
    {
      "item_id": "7f9487d36e:20",
      "text": "Emma Siret 毕业于 ESMA，是一名 freelance CG artist，专注于 modeling 和 texturing。她热爱 visual creation，并一直在寻找新的 opportunities！",
      "ascii_letters": 74,
      "cjk_chars": 21
    },
    {
      "item_id": "7f9487d36e:21",
      "text": "Marion Machelard（艺术家姓名）",
      "ascii_letters": 15,
      "cjk_chars": 5
    },
    {
      "item_id": "7f9487d36e:22",
      "text": "Marion 于 2023 年毕业于 ESMA，随后加入 Red Parrot Studios，在一部长片中担任 lighting artist。她热爱 atmospheres 和 colors，也热爱 storytelling 所带来的各种可能性。",
      "ascii_letters": 69,
      "cjk_chars": 33
    },
    {
      "item_id": "7f9487d36e:23",
      "text": "这个 project 使用 Attribution-NonCommercial 4.0 International License 授权。只要 credit 原作者，你就可以出于 non-commercial purposes 分享和再分发。",
      "ascii_letters": 78,
      "cjk_chars": 23
    },
    {
      "item_id": "7f9487d36e:24",
      "text": "Attribution-NonCommercial 4.0 International (CC BY-NC 4.0)（署名-非商业性使用 4.0 国际许可协议）",
      "ascii_letters": 43,
      "cjk_chars": 14
    }
  ],
