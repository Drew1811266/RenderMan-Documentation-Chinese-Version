{"id": "1f546110ee77f5d8fca2d20ff80680a10e5b465434ee3de28d954eaa45e5007c", "item_id": "ca021c2040:0", "text": "PxrChecker"}
{"id": "7357922761aef07e27a44ab4a09c9da2b52aace8810349e9991bc90e6bf4f062", "item_id": "ca021c2040:1", "text": "computes a simple checkerboard pattern."}
{"id": "ffe55f5d0ee5a6b6eb8ecb1ae53b44136e2ef819f687e80a781c4e4ee39dea53", "item_id": "ca021c2040:3", "text": "Color A and Color B"}
{"id": "f89f706bb469bc91bed10e1fac29f91fb9fe4214ace1868ee90f095931aa9509", "item_id": "ca021c2040:4", "text": "The two colors of the checkerboard squares."}
{"id": "914182d5e25f69e140a41e919664e5d16d3a9f67414c8cb1494b8ead668cd906", "item_id": "ca021c2040:5", "text": "Dimensions"}
