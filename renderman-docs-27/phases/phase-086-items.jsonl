{"id": "b4ceaff3b9cf94e655994dafdf1ef23d69440d3a514a31b9d3be8aca65bdbb17", "item_id": "8edd130299:0", "text": "PxrBakeTexture"}
{"id": "4657d75c2fdf55d936ebdb594e33449b9b7fac3e93ec8cad7c48ac5535fa2a1a", "item_id": "8edd130299:1", "text": "can be used as a pass-through node for baking patterns networks to 2D textures as part of the"}
{"id": "56bbbb0a1a7c2cf2cf88ecbcf15f9bdcd8b07539097af7aa3b7a712219f9dd61", "item_id": "8edd130299:2", "text": "baking"}
{"id": "219924f7930f8dafc346f5e0f5df5ca949379b2e1f5577098f058f92287114aa", "item_id": "8edd130299:3", "text": "workflow."}
{"id": "35aea6f833e7d09d9722a54bdee4bc25b02fd25547d6613ee8d9457096af94fb", "item_id": "8edd130299:5", "text": "Input Color"}
{"id": "aa23632080fd8dc5518485238cf1fb0c478cc6ea30d0e22284f9a86cda626d49", "item_id": "8edd130299:6", "text": "This is the incoming result of the pattern network to be baked. This connection requires a color (RGB). This input takes precedence over"}
{"id": "fd5f9eb23f15d342a80302b5539c7c8052067341e9b462dbfa6c317490518be0", "item_id": "8edd130299:9", "text": "Input Float"}
{"id": "f1dd60665bfbc30ee27df0002e1aed0a56d48d235ac1b9450d42aa66f603775e", "item_id": "8edd130299:10", "text": "This is the incoming result of a pattern network where the output is a float or scalar value."}
{"id": "971b974235a86ca628dcc713d6e2e8d975206cc84c858720ce046c2dab72855a", "item_id": "8edd130299:11", "text": "Filename"}
{"id": "497a5115f2d4f256b00b0baaa2725ba592a2c9a01d8742b881df34930767d656", "item_id": "8edd130299:12", "text": "The input/output filename of the resulting baked texture."}
{"id": "bec9334c3960e949a9d4aa030e20a1394ed8a9bfab4919cbc299d6b57b897d46", "item_id": "8edd130299:13", "text": "This parameter is required."}
{"id": "e5e1e2b3b2ea6e5e3e3294eb36b6d7ff4a7cc8fb79e891e166361284569defa7", "item_id": "8edd130299:14", "text": "Atlas Style"}
{"id": "20d592380d117b35855eedb374cca58fe27403530f7f50ad1eef6dcca81460c0", "item_id": "8edd130299:15", "text": "Formatting style for atlas textures. When enabled, the filename must contain"}
{"id": "d4986077e9e4c8d5ea617a7959502874e9d00e37ab31cb63c2e865e56d4253a7", "item_id": "8edd130299:16", "text": "_MAPID_"}
{"id": "4b36c7dcaba7a94afe6c49dbfcff1ad1d751475fadeedd03c61c93cfa9431991", "item_id": "8edd130299:17", "text": "which will be substituted automatically according to the surface parameterization."}
{"id": "8e37953d23daca5ff01b8282c33f4e0a2152f1d1885f94c06418617e3ee1d24e", "item_id": "8edd130299:49", "text": "Value"}
{"id": "87c76a179c44762c2dc0523219068242b01db214fc84d2d49bc1a5a07ea82fff", "item_id": "8edd130299:19", "text": "Example (texture_MAPID_.tex)"}
{"id": "dc937b59892604f5a86ac96936cd7ff09e25f18ae6b758e8014a24c7fa039e91", "item_id": "8edd130299:20", "text": "None"}
{"id": "97650a25eb3799e2a69e888f875ff497dcf573482ad3588bdedc1931e8056d98", "item_id": "8edd130299:21", "text": "texture.tex"}
{"id": "e699ce878413ae01c93658d029a3144aa8968b743b8c97964f3f5057e518636b", "item_id": "8edd130299:22", "text": "UDIM (MARI)"}
{"id": "4333aa77e82a5b2fb8fd1fdea06cff82974893486f4ae5018ac2bfc558a6d226", "item_id": "8edd130299:23", "text": "texture1001.tex"}
{"id": "3fd9fa12c4e59043ab799b5a8939b960875f08684dd28e88755850acb1a9a2c8", "item_id": "8edd130299:24", "text": "UV Tile Base-1 (Mudbox)"}
{"id": "e5ab6551c65ae318bd6f106935789cdd18db370275d374075e17972acd72dcc5", "item_id": "8edd130299:25", "text": "texture_u1_v1.tex"}
{"id": "e0a64989813515caaff0da7d497e5df53efe949e226766974c008d060cbd1ccd", "item_id": "8edd130299:26", "text": "UV Tile Base-0 (Zbrush)"}
{"id": "179b91b90289a7f38e64d7a8084dedbe12d3fb1bd818cda5c7f89e3e8b032830", "item_id": "8edd130299:27", "text": "texture_u0_v0.tex"}
{"id": "5c7dd9c0610efaea4b29bc8a40428b824444e3db9b267ea7845d84db47bfd3b5", "item_id": "8edd130299:28", "text": "UDIM is only defined for textures with U values in range 0.0 to 10.0 and V values greater than 0.0. Users should avoid negative texture coordinates for all atlas texture workflows."}
{"id": "6986adeb8348b3aadc0cdbcb2da3df23a6a54567539426194875622183df3273", "item_id": "8edd130299:29", "text": "For example, if you want to bake out a PxrCurvature of an asset across all UDIMS, the file path would look like this"}
{"id": "2b25cb07118c2e410848a575e95fe720f984a85d9cfaaefbe7b6580eef2e27c4", "item_id": "8edd130299:30", "text": "outputpath/HouseOne_Curvature._MAPID_.tex"}
{"id": "638e249f4a15ebb84957da130701d138a6e06d88dceeaa2e6dcd91db70cc1381", "item_id": "8edd130299:31", "text": "Filter"}
{"id": "1985311184575188b6aa8e08143748bbd403b69088f11448f18ad28beea5bdd2", "item_id": "8edd130299:32", "text": "Selects different reconstruction filters that can be used during texture lookup. The available filters are:"}
{"id": "7e704c0b0be54024475e365195cef11f85e29b48fda2fcc964d5a1169162917d", "item_id": "8edd130299:33", "text": "Nearest"}
{"id": "512fd3c6042cd1d9150d46fa59b5911a1f97b8275d73eb0a841daa31e93bd349", "item_id": "8edd130299:34", "text": "Box"}
{"id": "d3bae110ad106af3f04c587b06e5a9830ffc530745b942bf1b0180a5379bbbd4", "item_id": "8edd130299:35", "text": "Bilinear"}
{"id": "01bf2e7d5928ec2cd598ba892c540493058a4c14d60f6f62693112044f8ffb88", "item_id": "8edd130299:36", "text": "Bspline"}
{"id": "ee9889f28a7c0ee34490de4bddb67bf916340f08558897fef432f8b3969e2a66", "item_id": "8edd130299:37", "text": "Gaussian"}
{"id": "807533b1ad1305a6676ab8aa83ed1984d1ffd9ab38c824c436764354f66ca08c", "item_id": "8edd130299:38", "text": "Lagrangian"}
{"id": "4809c0208c8ceeb9166a48f46aa04e6e4ca4298ddd7885afca7eeb986ab348da", "item_id": "8edd130299:39", "text": "Mip Interpolate"}
{"id": "091f31882dff956b58012c4af2498388190f874b9c3243495e1d86330903042c", "item_id": "8edd130299:40", "text": "Interpolate values between mipmap levels, resulting in smoother transitions between levels."}
{"id": "e3109eb112b8b5d6dd25efb433f70bf813e165da8c7f3800a0e999d7ee918b11", "item_id": "8edd130299:41", "text": "Invert T"}
{"id": "4e0018734890a067d79dc575809435999a917e1b401e0ccc75b41372e5744a25", "item_id": "8edd130299:42", "text": "Inverts the T parameter for the texture lookup."}
{"id": "8205c2948d1174986c32262849ca9c80f36a830916aa75b33e25914fb466dce9", "item_id": "8edd130299:43", "text": "Missing Color"}
{"id": "a790c6dc5950f360f28423a512dcae652b86815344973d70f050d9c127405265", "item_id": "8edd130299:44", "text": "Resulting color when there is an error opening the texture file."}
{"id": "c77d69d93d44e0adf53bed91c3500f1aeaad1cb0b8c1aaf5a2355ed98f7bafbe", "item_id": "8edd130299:45", "text": "Bake Mode"}
{"id": "ce71826bc78c45bff66bd430e0ebef1df4aa880e0fba071a5e33b8aca4b7999e", "item_id": "8edd130299:46", "text": "This mode enables or disables texture baking."}
{"id": "a5e9ad6b85b8b658c27578c759158ca1081bcba1570a3aff2428062bc497b1c9", "item_id": "8edd130299:47", "text": "Render Mode"}
{"id": "b840026576d165c8f12c20138dfdb433e42a1546dbd92907c929c3cf3d221fda", "item_id": "8edd130299:48", "text": "Control reading from input patterns or baked textures during regular renders."}
{"id": "526e0087cc3f254d9f86f6c7d8e23d954c4dfda2b312efc29194ae8a860106ba", "item_id": "8edd130299:50", "text": "Description"}
{"id": "d461a493a3753877c9486cffa3444265a33370af8a7fff242fb119b71750839c", "item_id": "8edd130299:51", "text": "Automatic"}
{"id": "cd4d47db3db48e9e2e2806bfe81d904fa829035e3b3044a55e599a8fa690fb82", "item_id": "8edd130299:52", "text": "Attempts to first read previously baked textures, else the input pattern."}
{"id": "36ecb4f8669133ce744c21982ba4abe2ecd7086e1dc2226ccd6f266f3a5005f8", "item_id": "8edd130299:53", "text": "Input"}
{"id": "41406a5a1fc7356c0d9f563593710bfb9eb0d3fcac065707aae0e9eea2dc2590", "item_id": "8edd130299:54", "text": "Always reads from the input pattern."}
{"id": "e28411a3404d21f9fc1679b4464b3dc497333f6140e580d745d52e2522d65c9f", "item_id": "8edd130299:55", "text": "Texture"}
{"id": "c58844960b8262d3e9c3049b62a614ef013c9a4370e24a7caf8498f0b925ccf7", "item_id": "8edd130299:56", "text": "Always reads from previously baked textures, else the missing color."}
{"id": "8456352791573730647909c9c4a24cd8c3d23bf4148cfb5f59c950e75171fafe", "item_id": "8edd130299:57", "text": "File Type"}
{"id": "8f1e3718154ecafa24920b87a9652180097302d1c3b7038d2f69621fc7ea92fa", "item_id": "8edd130299:58", "text": "Output file type display driver such as"}
{"id": "05c2e99691bf42c9eeed78284d47a03a83cb2cd85caf0757243cf1eacf4d22b0", "item_id": "8edd130299:66", "text": "txmake (.tex)"}
{"id": "9f41aaa5c7633e44981fcf0dffcda5648bef1135070e033d60201dfd3eb45dbf", "item_id": "8edd130299:60", "text": "OpenEXR (.exr)"}
{"id": "f410ca764ef6d55a4a03aa8a38ce836fe59f027a09ae9fde0181695948f51d34", "item_id": "8edd130299:62", "text": "TIFF (.tif)"}
{"id": "5ee49824c34ea5caf1b53e7245ddf4bbbd1bd4093bfd8203c89eef5803546b95", "item_id": "8edd130299:64", "text": "File Format"}
{"id": "eb54b2c00eea0013edde6e1cbe7902ac5d6076eca9a02494b0387c44647c5602", "item_id": "8edd130299:65", "text": "Underlying formats for the"}
{"id": "3002f532ae31ab657a3918a90b11b7f17ba7b291b3b3ff6788fc13fa456b2365", "item_id": "8edd130299:67", "text": "file type: OpenEXR or TIFF"}
{"id": "68cd154732021d9684d0dcad6276e99d675f962c9b08774f23f5de9398e19290", "item_id": "8edd130299:68", "text": "Data Type"}
{"id": "93be2cbcc82b5d720c66bc3f1b8b6a8be1ab612c1110adab19bbbe01ada192b9", "item_id": "8edd130299:73", "text": "OpenEXR"}
{"id": "0774067b392e1bba7e47ab16d1a934982ee93c7badc340a434bb87f85259b59f", "item_id": "8edd130299:70", "text": "data type: half or float."}
{"id": "278b1b2a9c84730f37f6d36630281494544a27e37168b4c6e45859667777f609", "item_id": "8edd130299:71", "text": "Compression"}
{"id": "bd1e23ddb8f8bebc7b6b21b8320018c895e650f2b45912ed3d353cf6f40593de", "item_id": "8edd130299:72", "text": "Compression for"}
{"id": "6bce2b82f777b971421ec7825822627176284a301531d35aa92d59a50d34007d", "item_id": "8edd130299:74", "text": "file format: None, RLE, ZIP, or PIZ"}
{"id": "9d6a0102adba75f7755ce0cd1fb662aba68b62542df0303f6c8adde38221142c", "item_id": "8edd130299:75", "text": "Resolution X and Resolution Y"}
{"id": "2e87c2e7cc4867a478e2255e2a1578624e5d17764151f74ccf921f83d54df6d0", "item_id": "8edd130299:76", "text": "The resolution of the baked texture. Higher numbers may preserve more details at the cost of memory usage. For best results, use a power of two."}
{"id": "f210f0d4068c1883d45fa8fb87638b7928a85ec6c9b2036fc514983a0b720d7e", "item_id": "8edd130299:77", "text": "PrimVar ST/S"}
{"id": "bb9a9ac8f33d889372aafa2680dc6b34fc778e4cecaf8f5a861b909a084be87e", "item_id": "8edd130299:78", "text": "This parameter chooses the 2D or 1D primvar that defines the texture manifold. For NURBS objects this should be"}
{"id": "e32dd9bb5ec7cb608d54a405f0795421b7b5cd2d8d0d236e25cc08d9f05d54c8", "item_id": "8edd130299:79", "text": "uvw"}
{"id": "ff6decb98de33f019292f6f4ff9f2e2afa4aac8f87a3fffd33365b3fcd630822", "item_id": "8edd130299:81", "text": "PrimVar T"}
{"id": "932bcb6c7195a15334e2ac8a7273111ee9163ae58896744e6c86a733a15c4d0a", "item_id": "8edd130299:82", "text": "This optional parameter chooses a second 1D primvar that defines the texture manifold."}
{"id": "7d8f587a0384506b4558622b910156ffcdc38d2494391973eaa7f5738bb6e34b", "item_id": "8edd130299:83", "text": "Active UDIM"}
{"id": "7ec17b417394e06fa68dc8a2b6c5b0036d6b4d75bc3c94f81cc0301d4ece3d2a", "item_id": "8edd130299:84", "text": "When set only bake active UDIM tiles."}
