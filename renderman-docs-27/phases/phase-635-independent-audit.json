      "cjk_chars": 3
    },
    {
      "item_id": "6eb1c46a4c:38",
      "text": "使用 PxrNormalMap node 加载你的 Normal map。",
      "ascii_letters": 25,
      "cjk_chars": 6
    },
    {
      "item_id": "6eb1c46a4c:39",
      "text": "将 PxrNormalMap node 中的",
      "ascii_letters": 16,
      "cjk_chars": 3
    },
    {
      "item_id": "6eb1c46a4c:41",
      "text": "从 PxrNormalMap 节点连接到 PxrSurface 的",
      "ascii_letters": 22,
      "cjk_chars": 7
    },
    {
      "item_id": "6eb1c46a4c:42",
      "text": "bumpNormal",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:43",
      "text": "PxrSurface 的输入。",
      "ascii_letters": 10,
      "cjk_chars": 3
    },
    {
