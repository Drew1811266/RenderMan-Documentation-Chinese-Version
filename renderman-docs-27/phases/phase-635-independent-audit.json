      "cjk_chars": 8
    },
    {
      "item_id": "6eb1c46a4c:35",
      "text": "连接到 PxrSurface 的",
      "ascii_letters": 10,
      "cjk_chars": 4
    },
    {
      "item_id": "6eb1c46a4c:36",
      "text": "specularRoughness",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:37",
      "text": "PxrSurface 的输入。",
