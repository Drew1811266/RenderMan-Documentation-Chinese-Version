    {
      "item_id": "6eb1c46a4c:1",
      "text": "PxrMetallicWorkflow",
      "ascii_letters": 19,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:2",
      "text": "，可以很容易地与 PBR maps 和 PxrSurface 一起使用。",
      "ascii_letters": 17,
      "cjk_chars": 12
    },
    {
      "item_id": "6eb1c46a4c:5",
      "text": "Greyscalegorilla",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:6",
      "text": "慷慨提供，所用示例是 Copper Corroded Heavy 01。",
      "ascii_letters": 19,
      "cjk_chars": 9
    },
    {
      "item_id": "6eb1c46a4c:7",
      "text": "由于 Eagle model 没有任何 UVs，我们采用 triplanar 方法，通过",
      "ascii_letters": 22,
      "cjk_chars": 14
    },
    {
      "item_id": "6eb1c46a4c:8",
      "text": "PxrMultiTexture",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:11",
      "text": "PxrTexture",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:12",
      "text": "节点，而不是 PxrMultiTexture 节点。",
      "ascii_letters": 15,
      "cjk_chars": 7
    },
    {
      "item_id": "6eb1c46a4c:14",
      "text": "创建一个 PxrSurface",
      "ascii_letters": 10,
      "cjk_chars": 4
    },
    {
      "item_id": "6eb1c46a4c:15",
      "text": "创建一个 PxrMetallicWorkflow node",
      "ascii_letters": 23,
      "cjk_chars": 4
    },
    {
      "item_id": "6eb1c46a4c:17",
      "text": "resultdiffuse",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:18",
      "text": "从 PxrMetallicWorkflow 连接到 PxrSurface 的",
      "ascii_letters": 29,
      "cjk_chars": 5
    },
    {
      "item_id": "6eb1c46a4c:19",
      "text": "diffusecolor",
      "ascii_letters": 12,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:20",
      "text": "为 diffuse map 使用 PxrTexture（或在本例中使用 PxrMultiTexture node）",
      "ascii_letters": 39,
      "cjk_chars": 10
    },
    {
      "item_id": "6eb1c46a4c:21",
      "text": "将 diffuse texture 连接到 PxrMetallicWorkflow node 的",
      "ascii_letters": 37,
      "cjk_chars": 5
    },
    {
      "item_id": "6eb1c46a4c:22",
      "text": "basecolor",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:23",
      "text": "PxrMetallicWorkflow 节点的输入。",
      "ascii_letters": 19,
      "cjk_chars": 5
    },
    {
      "item_id": "6eb1c46a4c:24",
      "text": "加载 Metallic texture map。",
      "ascii_letters": 18,
      "cjk_chars": 2
    },
    {
      "item_id": "6eb1c46a4c:25",
      "text": "将 metallic map 中的",
      "ascii_letters": 11,
      "cjk_chars": 3
    },
    {
      "item_id": "6eb1c46a4c:27",
      "text": "连接到 PxrMetallicWorkflow node 的",
      "ascii_letters": 23,
      "cjk_chars": 4
    },
    {
      "item_id": "6eb1c46a4c:28",
      "text": "metallic",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "6eb1c46a4c:29",
      "text": "PxrMetallicWorkflow 节点的输入。",
      "ascii_letters": 19,
      "cjk_chars": 5
    },
    {
      "item_id": "6eb1c46a4c:30",
      "text": "将 PxrMetallicWorkflow 的 resultSpecularEdgeRGB 连接到 PxrSurface 的 specularEdgeColor。",
      "ascii_letters": 67,
      "cjk_chars": 6
    },
    {
      "item_id": "6eb1c46a4c:31",
      "text": "将 PxrMetallicWorkflow 的 resultSpecularFaceRGB 连接到 PxrSurface 的 specularFaceColor。",
      "ascii_letters": 67,
      "cjk_chars": 6
    },
    {
      "item_id": "6eb1c46a4c:32",
      "text": "加载 Roughness map。",
      "ascii_letters": 12,
      "cjk_chars": 2
    },
    {
      "item_id": "6eb1c46a4c:33",
      "text": "将 roughness map（粗糙度贴图）中的",
