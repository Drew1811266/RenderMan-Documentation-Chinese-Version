      "cjk_chars": 3
    },
    {
      "item_id": "27d4faf293:66",
      "text": "在对话框中执行 'no'。关闭 task log pane 和 tracer pane。",
      "ascii_letters": 23,
      "cjk_chars": 10
    },
    {
      "item_id": "27d4faf293:69",
      "text": "切换所选 task 的 log view。",
      "ascii_letters": 11,
      "cjk_chars": 5
    },
    {
      "item_id": "27d4faf293:71",
      "text": "在 job graph 中选择下一个 active、blocked、done 或 errored task。",
