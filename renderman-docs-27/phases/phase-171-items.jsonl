{"id": "5812ad729debfa94b38ec4943ea5390d158b24654eee5538bded2341a832fef0", "item_id": "051b850fbf:0", "text": "PxrRampLightFilter uses a ramp to control the light. It may also be useful to artificially and artistically control light decay."}
{"id": "7a86cb44ad83716775e33f62b7994401d4d4d5e012bcac2bf7f2886c50e93222", "item_id": "051b850fbf:2", "text": "Ramp Direction"}
{"id": "2dd5a619817478d71f16efa703252215214afd117435750f9187a31aa3483611", "item_id": "051b850fbf:3", "text": "Ramp Type"}
{"id": "5313d557d21f5b91b4659718b9dcec00e320db1fd5893e27ade3384cba4c4e53", "item_id": "051b850fbf:4", "text": "Specify in which direction the ramp is applied."}
{"id": "0b912d31350503541b046cdd14f7477ae4af7c3e87775fb3c6e4655fd0759ba1", "item_id": "051b850fbf:5", "text": "distToLight(0) - distance to the light."}
{"id": "ea82711599f5758ece98c366194e3a4be6f0602e1c948b271e156c19fa410cae", "item_id": "051b850fbf:6", "text": "linear(1) - linear ramp."}
{"id": "662dd3e43eff6d32dc9a77f265afea5f8c968ff5a94384fa541e356eea84640a", "item_id": "051b850fbf:7", "text": "spherical(2) - spherical ramp."}
{"id": "3753759dfc7ff0f938a93626af39e9859faecbd1c78aa6afbf2a08e9636c4453", "item_id": "051b850fbf:8", "text": "radial(3) - radial ramp."}
{"id": "0b4bd1225070b6df7deebce85a1ea8f6f772e4bf1f48904cd504a4bdb03ac5f5", "item_id": "051b850fbf:9", "text": "Begin Distance"}
{"id": "4a90c22d29a7fbb180cc4608f51962edbca06ac6981e2241613b7219c1c01894", "item_id": "051b850fbf:10", "text": "Distance where the ramp starts."}
{"id": "bc97676adb3abd19d95c2124b791109d31ff0df8e102bfb20761dc634ef2002e", "item_id": "051b850fbf:11", "text": "End Distance"}
{"id": "81c14357a3df1550e1719ba1af962becc57bd3a2d0c0a05a1df26b9fb9215bda", "item_id": "051b850fbf:12", "text": "Distance where the ramp ends."}
{"id": "70a5ae4aa40dc35b121a19cb48dca9376246e48d0be16d4faa70c6553c6c9414", "item_id": "051b850fbf:14", "text": "Ramp"}
{"id": "fa16c0223ad733d70ccda3c9b76f7281d15aff4c5bcacd2e667f8b181e24ba57", "item_id": "051b850fbf:39", "text": "Define the number of knots."}
{"id": "d86c59cbba2d2c88b9ff7a3a3e3a1873782d612efed4f06405779dd8b8e10953", "item_id": "051b850fbf:16", "text": "Ramp Knots"}
{"id": "2251e36adad7b2bf98bc16cb2d3e7304d12221d4af31a67bbd09d3cd3159d63d", "item_id": "051b850fbf:41", "text": "An array of knot values."}
{"id": "c2a9d24ba6c59005b50e9467633e260be289fd394cc50bc3762338af42203ab2", "item_id": "051b850fbf:18", "text": "Ramp Floats"}
{"id": "b13b07279bf5bf797815a97e1dad28c88767b21222c20eea4f893dab8e18605c", "item_id": "051b850fbf:19", "text": "An array of float values."}
{"id": "583da43eacd4df6a0adc59a3382a88c99f38c209dc671f60c285b8b6aae095dc", "item_id": "051b850fbf:20", "text": "Ramp Interpolation"}
{"id": "a008f0336c7154a60ad446ab93c9e856ceb133a8bbefda6528cf8aa89047d411", "item_id": "051b850fbf:21", "text": "Type of ramp interpolation:"}
{"id": "7f2fe580edb35154041fa3d4b41dd6d3adaef0c85d2ff6309f1d4b520eeecda3", "item_id": "051b850fbf:46", "text": "linear"}
{"id": "68624f1c8c9cd9bb5876c96d649aec57a62da25d5f357673b50a8dd6ad4f09a8", "item_id": "051b850fbf:47", "text": "catmull-rom"}
{"id": "8cb274af41a3689a485853d5ca9527e8ed74632d0c0423528433c2653863ac2c", "item_id": "051b850fbf:48", "text": "bspline"}
{"id": "96f6549c6b97a641e4d1099e39ebf966e649de64f5bf8274d27afad33541e702", "item_id": "051b850fbf:49", "text": "constant"}
{"id": "88fb11573a6a01055cff4da5a1b81f5b20850faa77b8ca6826ef9d278b150d20", "item_id": "051b850fbf:26", "text": "Multiplier"}
{"id": "0777c49ce5c07ae7346cd77098d7b497cfb64de6d6e7ab594a914021c2ed32a2", "item_id": "051b850fbf:28", "text": "Controls the strength of the projected effect."}
{"id": "7e04f2ffb9334e3d19a15c949a73818d4b271b0e713dbfad612b29491b46bc1b", "item_id": "051b850fbf:29", "text": "Invert"}
{"id": "487bc2a4461a9599bcde4590fffe8f841d80eec0fc6a7b1ff86772a409505841", "item_id": "051b850fbf:30", "text": "Specify whether to invert the projected texture before it is applied."}
{"id": "a6d01dcff3bfd333edf90a50daac2104cefab98b85bdbba67c8209ab75eb6447", "item_id": "051b850fbf:31", "text": "Intensity"}
{"id": "5cd08106a6d5cd7094cd4c8e0cf55395b376a908189d33e41956f7f180c0cd8a", "item_id": "051b850fbf:32", "text": "Global Multiplier for both the diffuse and specular contribution below."}
{"id": "347fd578167c6bc809620bb574d4772c7a1dc176c7a932272a5b32e3c8b0d652", "item_id": "051b850fbf:33", "text": "Diffuse"}
{"id": "f4c83e125c3330bbcf3c5eaa76034a2343692912053f9c60ac5a1f218f36ae25", "item_id": "051b850fbf:34", "text": "Multiplier of this light filter result for the diffuse contribution."}
{"id": "2b23ae6b78b7d463bfe2504b11e8b8f11223c65278da7b3ae2ebf248cc2e10ae", "item_id": "051b850fbf:35", "text": "Specular"}
{"id": "465285c2c5063c925e2c64b5815d55fed372a17ed45421b859265d439c3df0aa", "item_id": "051b850fbf:36", "text": "Multiplier of this light filter result for the specular contribution."}
{"id": "9ab2a68cb038ca3e07b91dc42b16caf9604929101d3ac75b006b603144319e92", "item_id": "051b850fbf:38", "text": "Color Ramp"}
{"id": "6af214090666fba9be246124be19c6b4121c52321909b418981d704b4c326a73", "item_id": "051b850fbf:40", "text": "Color Ramp Knots"}
{"id": "232c18b194f8e80b083d905e65c5de3b542dbb8364a056bdedcae92137262b78", "item_id": "051b850fbf:42", "text": "Ramp Colors"}
{"id": "c7b9c9de5bddbc77b4a3cb07b8bdc1db0ff188b20f406b207df6e9f19ca81cc0", "item_id": "051b850fbf:43", "text": "An array of color values."}
{"id": "6c5a697bc1be7de0e36a912ca479c9f18f34d0ff0c5e5d0afddf65e1554f6062", "item_id": "051b850fbf:44", "text": "Color Ramp Interpolation"}
{"id": "3e657d434bc0da84fe0d698a44a35482097b0ed72c46f870b4babaa3d987cf32", "item_id": "051b850fbf:45", "text": "Type of color ramp interpolation:"}
{"id": "f1d391844bc65573f53c0c894750b2c4c7b5a63f81897dc2d03474e6c877f728", "item_id": "051b850fbf:50", "text": "Combine Mode"}
{"id": "9e87213b80319606bb35c98e2cc5fd6dd295e057d112641e13b95c90a400a199", "item_id": "051b850fbf:51", "text": "Combine mode for PxrRampLightFilter is always multiplied."}
