    {
      "item_id": "09e44a5a0a:0",
      "text": "RenderMan Art Challenge Help Guide（RenderMan Art Challenge 帮助指南）",
      "ascii_letters": 51,
      "cjk_chars": 4
    },
    {
      "item_id": "09e44a5a0a:1",
      "text": "RenderMan Art Challenge 是一个令人兴奋的年度机会，让世界各地的 creatives 使用 Pixar 的 RenderMan 展示才华，并有机会赢得很棒的 prizes！",
      "ascii_letters": 50,
      "cjk_chars": 34
    },
    {
      "item_id": "09e44a5a0a:5",
      "text": "Here’s a good place to start!（这里是一个很好的起点！）",
      "ascii_letters": 22,
      "cjk_chars": 10
    },
    {
      "item_id": "09e44a5a0a:6",
      "text": "Start with Words（从文字开始扩展创意）",
      "ascii_letters": 14,
      "cjk_chars": 9
    },
    {
      "item_id": "09e44a5a0a:9",
      "text": "如何鼓励 audience 对你的 image 产生 wonder，并主动提出 questions？",
      "ascii_letters": 28,
      "cjk_chars": 14
    },
    {
      "item_id": "09e44a5a0a:10",
      "text": "What makes a strong image?（强有力画面的构成要素）",
      "ascii_letters": 21,
      "cjk_chars": 10
    },
    {
      "item_id": "09e44a5a0a:11",
      "text": "来自 industry professionals 的一些想法，关于哪些 elements 能构成一张 strong image。",
      "ascii_letters": 40,
      "cjk_chars": 16
    },
    {
      "item_id": "09e44a5a0a:12",
      "text": "Mentoring Session Archive（过往指导课程与辅导资料库）",
      "ascii_letters": 23,
      "cjk_chars": 12
    },
    {
      "item_id": "09e44a5a0a:13",
      "text": "这里是 Thoughtful 3D 和 Ozone 过往 mentoring sessions 的实用 library resource。",
      "ascii_letters": 48,
      "cjk_chars": 9
    }
