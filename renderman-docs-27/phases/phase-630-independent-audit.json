  "actionable_ascii_heavy_residuals": [],
  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "aad6acdf2c:0",
      "text": "让我们在 Solaris 中扮演 cinematographer，并学习 Pixar 的 lighting toolset。",
      "ascii_letters": 42,
      "cjk_chars": 11
    },
    {
      "item_id": "aad6acdf2c:2",
      "text": "Light Basics（灯光基础）",
      "ascii_letters": 11,
      "cjk_chars": 4
    },
    {
      "item_id": "aad6acdf2c:3",
      "text": "Light Intensity（灯光强度）",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "aad6acdf2c:4",
      "text": "了解 Pixar-centric workflows 中关于 light intensity 和 exposure 的基础概念。",
      "ascii_letters": 43,
      "cjk_chars": 11
    },
    {
      "item_id": "aad6acdf2c:5",
      "text": "Light Temperature（灯光色温）",
      "ascii_letters": 16,
      "cjk_chars": 4
    },
    {
      "item_id": "aad6acdf2c:6",
      "text": "学习用于匹配 incandescent light color 的最基础 lighting attributes 之一。",
      "ascii_letters": 40,
      "cjk_chars": 12
    },
    {
      "item_id": "aad6acdf2c:7",
      "text": "Normalize Light（灯光归一化）",
      "ascii_letters": 14,
      "cjk_chars": 5
    },
    {
      "item_id": "aad6acdf2c:8",
      "text": "先把物理放一边！学习如何通过 light normalization 为 lighting 和 shadows 带来更多艺术控制。",
      "ascii_letters": 33,
      "cjk_chars": 23
    },
    {
      "item_id": "aad6acdf2c:9",
      "text": "Diffuse & Specular（漫反射与镜面反射）",
      "ascii_letters": 15,
      "cjk_chars": 8
    },
    {
      "item_id": "aad6acdf2c:10",
      "text": "通过分别控制 diffuse 和 specular light contributions，进一步打破物理限制。",
      "ascii_letters": 33,
      "cjk_chars": 16
    },
    {
      "item_id": "aad6acdf2c:11",
      "text": "Intensity Near Distance（近距离强度）",
      "ascii_letters": 21,
      "cjk_chars": 5
    },
    {
      "item_id": "aad6acdf2c:13",
      "text": "Light Types（灯光类型）",
      "ascii_letters": 10,
      "cjk_chars": 4
    },
    {
      "item_id": "aad6acdf2c:16",
      "text": "dome 或 environment light 是每个 photorealistic render 的基础，因此我们来看一下基本概念。",
      "ascii_letters": 40,
      "cjk_chars": 19
    },
    {
      "item_id": "aad6acdf2c:17",
      "text": "Rectangular Light（矩形灯）",
      "ascii_letters": 16,
      "cjk_chars": 3
    },
    {
      "item_id": "aad6acdf2c:18",
      "text": "了解 lighter 工具箱中最常用的工具：Pixar Rectangular Light。",
      "ascii_letters": 28,
      "cjk_chars": 12
    },
    {
      "item_id": "aad6acdf2c:19",
      "text": "Cylinder Light（圆柱灯基础课程）",
      "ascii_letters": 13,
      "cjk_chars": 7
    },
    {
      "item_id": "aad6acdf2c:20",
      "text": "Strip Lights 和 Lightsabers 有一个共同点：Cylinder Lights！",
      "ascii_letters": 36,
      "cjk_chars": 7
    },
    {
      "item_id": "aad6acdf2c:21",
      "text": "Sphere Lights（球形灯基础课程）",
      "ascii_letters": 12,
      "cjk_chars": 7
    },
    {
      "item_id": "aad6acdf2c:23",
      "text": "Light Filters Basics（灯光滤镜基础）",
      "ascii_letters": 18,
      "cjk_chars": 6
    },
    {
      "item_id": "aad6acdf2c:24",
      "text": "了解 Light Filters，也就是 Pixar 创意 lighting 的秘密成分！",
      "ascii_letters": 25,
      "cjk_chars": 12
    },
    {
      "item_id": "aad6acdf2c:25",
      "text": "Light Filter Basics（灯光滤镜基础）",
      "ascii_letters": 17,
      "cjk_chars": 6
    },
    {
      "item_id": "aad6acdf2c:26",
      "text": "Eugene Riecansky 在 Solaris 中介绍强大的 light filter toolset。",
      "ascii_letters": 40,
      "cjk_chars": 7
    },
    {
      "item_id": "aad6acdf2c:27",
      "text": "Next Steps（下一步）",
      "ascii_letters": 9,
      "cjk_chars": 3
    }
  ],
