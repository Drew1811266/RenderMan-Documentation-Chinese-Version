  "actionable_ascii_heavy_residuals": [],
  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "5314035cd6:0",
      "text": "使用自己的 OCIO config",
      "ascii_letters": 10,
      "cjk_chars": 5
    },
    {
      "item_id": "5314035cd6:1",
      "text": "OCIO Roles（OCIO 角色）",
      "ascii_letters": 13,
      "cjk_chars": 2
    },
    {
      "item_id": "5314035cd6:2",
      "text": "RenderMan 依赖几个 OpenColorIO roles，需要在你的",
      "ascii_letters": 25,
      "cjk_chars": 9
    },
    {
      "item_id": "5314035cd6:3",
      "text": "config.ocio",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:5",
      "text": "rendering",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:7",
      "text": "MANDATORY（必需）",
      "ascii_letters": 9,
      "cjk_chars": 2
    },
    {
      "item_id": "5314035cd6:11",
      "text": "STANDARD（标准）",
      "ascii_letters": 8,
      "cjk_chars": 2
    },
    {
      "item_id": "5314035cd6:12",
      "text": "这类 input 不需要转换，因为它提供的是 numerical data（normal map、bump map、roughness map 等）。",
      "ascii_letters": 46,
      "cjk_chars": 15
    },
    {
      "item_id": "5314035cd6:13",
      "text": "srgb_linear",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:15",
      "text": "MANDATORY（必需）",
      "ascii_letters": 9,
      "cjk_chars": 2
    },
    {
      "item_id": "5314035cd6:16",
      "text": "线性 sRGB/Rec.709 图像，例如 HDRI environment map。",
      "ascii_letters": 25,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:17",
      "text": "srgb_texture",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:20",
      "text": "这个 role 已添加到我们的 basic linear configuration 和 Filmic-Blender configuration 中。",
      "ascii_letters": 54,
      "cjk_chars": 11
    },
    {
      "item_id": "5314035cd6:22",
      "text": "Utility - sRGB - Texture",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:25",
      "text": "JSON Configuration file（JSON 配置文件）",
      "ascii_letters": 25,
      "cjk_chars": 4
    },
    {
      "item_id": "5314035cd6:27",
      "text": "为了提供集中配置点，RenderMan 需要一个 JSON configuration file 来提供：",
      "ascii_letters": 30,
      "cjk_chars": 16
    },
    {
      "item_id": "5314035cd6:28",
      "text": "UI controls 中可用的 Roles/ColorSpaces 列表。",
      "ascii_letters": 26,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:29",
      "text": "将插入到 texture names 中、用于消除歧义的 aliases（shortened forms）列表。",
      "ascii_letters": 33,
      "cjk_chars": 14
    },
    {
      "item_id": "5314035cd6:30",
      "text": "可显示在 UI controls 中的 help strings 列表。",
      "ascii_letters": 21,
      "cjk_chars": 8
    },
    {
      "item_id": "5314035cd6:31",
      "text": "一组供 Texture Manager 分配初始 txmake settings 的 rules。",
      "ascii_letters": 33,
      "cjk_chars": 8
    },
    {
      "item_id": "5314035cd6:32",
      "text": "配置 JSON 文件名（File name）",
      "ascii_letters": 12,
      "cjk_chars": 5
    },
    {
      "item_id": "5314035cd6:35",
      "text": "配置文件位置（File location）",
      "ascii_letters": 12,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:39",
      "text": "environment variable，则所有匹配",
      "ascii_letters": 19,
      "cjk_chars": 5
    },
    {
      "item_id": "5314035cd6:40",
      "text": "pattern、位于该目录中的文件都会被加载。这个机制可用于覆盖 stock configurations，或为 custom OpenColorIO configuration 添加支持。",
      "ascii_letters": 56,
      "cjk_chars": 29
    },
    {
      "item_id": "5314035cd6:41",
      "text": "配置示例文件（Sample file）",
      "ascii_letters": 10,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:42",
      "text": "rman_color_config_ACES-1.2.json",
      "ascii_letters": 23,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:44",
      "text": "Rules 允许 Texture Manager 为新引用的 images 设置合理的 conversion defaults。如果设置得当，它可以完全自动化 texture conversion。",
      "ascii_letters": 60,
      "cjk_chars": 26
    },
    {
      "item_id": "5314035cd6:45",
      "text": "Rules 由 node types 定义：pattern、light、lightfilter 和 imageplane。这样可以专门化 conversion，而无需依赖一套复杂 rules。",
      "ascii_letters": 62,
      "cjk_chars": 20
    },
    {
      "item_id": "5314035cd6:47",
      "text": "这是一个 txmake flags 及其 values 的 dictionary，用来定义可由 rules 修改的 baseline。",
      "ascii_letters": 40,
      "cjk_chars": 16
    },
    {
      "item_id": "5314035cd6:51",
      "text": "texture_type",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:52",
      "text": "\"regular\" 用于通用 textures，\"envlatl\" 用于 environment light textures。",
      "ascii_letters": 46,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:53",
      "text": "texture_format",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:54",
      "text": "texture 的 file format：\"pixar\"、\"tiff\"、\"openexr\"",
      "ascii_letters": 33,
      "cjk_chars": 1
    },
    {
      "item_id": "5314035cd6:56",
      "text": "使用给定 mode 将图像 resize 到 2 的幂：\"none\"、\"up\"、\"up-\"、\"down\"、\"down-\"、\"round\"、\"round-\"。",
      "ascii_letters": 36,
      "cjk_chars": 10
    },
    {
      "item_id": "5314035cd6:57",
      "text": "texture_filter",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:58",
      "text": "用于 resize 的 Filter：\"point\"、\"box\"、\"triangle\"、\"sinc\"、\"gaussian\"、\"gaussian-soft\"、\"catmull-rom\"、\"mitchell\"、\"cubic\"、\"lanczos\"、\"bessel\"、\"blackman-harris\"",
      "ascii_letters": 102,
      "cjk_chars": 3
    },
    {
      "item_id": "5314035cd6:60",
      "text": "s 方向上的 repeat mode：\"black\"、\"clamp\"、\"periodic\"",
      "ascii_letters": 29,
      "cjk_chars": 4
    },
    {
      "item_id": "5314035cd6:62",
      "text": "t 方向上的 repeat mode：\"black\"、\"clamp\"、\"periodic\"",
      "ascii_letters": 29,
      "cjk_chars": 4
    },
    {
      "item_id": "5314035cd6:63",
      "text": "data_type",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:64",
      "text": "\"float\"（float 32）、\"half\"（float 16）、\"byte\"（int 8）、\"short\"（int 16）",
      "ascii_letters": 34,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:65",
      "text": "compression",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:66",
      "text": "用于 texture tiles 的 Compression，可节省磁盘空间。它依赖 texture format；请参阅 txmake help。",
      "ascii_letters": 46,
      "cjk_chars": 16
    },
    {
      "item_id": "5314035cd6:67",
      "text": "compression_level",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:68",
      "text": "支持该参数的 compressors 使用的 Compression level；请参阅 txmake help。",
      "ascii_letters": 37,
      "cjk_chars": 12
    },
    {
      "item_id": "5314035cd6:69",
      "text": "ociocolorspace",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:70",
      "text": "destination colorspace 是目标颜色空间，也就是 texture 的 colorspace。",
      "ascii_letters": 38,
      "cjk_chars": 11
    },
    {
      "item_id": "5314035cd6:71",
      "text": "ocioconvert",
      "ascii_letters": 11,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:72",
      "text": "source colorspace 是源颜色空间，也就是 image 的 colorspace。",
      "ascii_letters": 31,
      "cjk_chars": 10
    },
    {
      "item_id": "5314035cd6:73",
      "text": "ociodither",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:74",
      "text": "输出到 non-float texture format 时，可选地对 pixel values 执行 dither。不推荐。",
      "ascii_letters": 38,
      "cjk_chars": 13
    },
    {
      "item_id": "5314035cd6:75",
      "text": "bumprough",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:76",
      "text": "这个参数是一个 dict，包含 bump to roughness conversion values：\"factor\"、\"normalmap\"、\"invert\"、\"invertU\"、\"invertV\"、\"refit\"",
      "ascii_letters": 75,
      "cjk_chars": 9
    },
    {
      "item_id": "5314035cd6:77",
      "text": "mipfilter",
      "ascii_letters": 9,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:78",
      "text": "用于创建 MIP levels 的 resizing filter。与 texture_filter 相同。",
      "ascii_letters": 36,
      "cjk_chars": 8
    },
    {
      "item_id": "5314035cd6:80",
      "text": "Rules 是应当 evaluate 为 True 或 False 的 Python strings。",
      "ascii_letters": 35,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:83",
      "text": "entry，以便在 rule 为 True 时跳过后续 rules。",
      "ascii_letters": 18,
      "cjk_chars": 9
    },
    {
      "item_id": "5314035cd6:84",
      "text": "它们可以包含以下 substitution tokens：",
      "ascii_letters": 18,
      "cjk_chars": 8
    },
    {
      "item_id": "5314035cd6:85",
      "text": "node_type",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:86",
      "text": "PxrTexture、PxrDomeLight 等",
      "ascii_letters": 22,
      "cjk_chars": 1
    },
    {
      "item_id": "5314035cd6:87",
      "text": "classification",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:88",
      "text": "bxdf、pattern、light、lightfilter 等",
      "ascii_letters": 27,
      "cjk_chars": 1
    },
    {
      "item_id": "5314035cd6:90",
      "text": "不含 extension 的图像名称（image name）",
      "ascii_letters": 18,
      "cjk_chars": 7
    },
    {
      "item_id": "5314035cd6:92",
      "text": "image 的 extension（图像扩展名）",
      "ascii_letters": 14,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:93",
      "text": "img_atlas",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:94",
      "text": "如果是 texture atlas，则为 True",
      "ascii_letters": 16,
      "cjk_chars": 5
    },
    {
      "item_id": "5314035cd6:96",
      "text": "'int' 或 'float'",
      "ascii_letters": 8,
      "cjk_chars": 1
    },
    {
      "item_id": "5314035cd6:97",
      "text": "img_depth",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:99",
      "text": "img_nchan",
      "ascii_letters": 8,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:100",
      "text": "image 中包含的 channels 数量",
      "ascii_letters": 13,
      "cjk_chars": 6
    },
    {
      "item_id": "5314035cd6:101",
      "text": "ocioconfig",
      "ascii_letters": 10,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:102",
      "text": "OCIO config 的 full path",
      "ascii_letters": 18,
      "cjk_chars": 1
    },
    {
      "item_id": "5314035cd6:103",
      "text": "ocioconfig_name",
      "ascii_letters": 14,
      "cjk_chars": 0
    },
    {
      "item_id": "5314035cd6:104",
      "text": "OCIO config 的 name：'basic'、'ACES-1.2' 等",
      "ascii_letters": 23,
      "cjk_chars": 2
    },
    {
      "item_id": "5314035cd6:105",
      "text": "要让 ACES colorspace 正确应用到 lights，你的 rendering role 必须命名为（或 alias 为）\"ACES - ACEScg\" 或 \"ACEScg\"。此外，RenderMan 依赖 OCIO configs 中定义的 luma coefficients。这些系数在 OCIO v2 中已 deprecated，并且在 default ACES config 中可能不正确。",
      "ascii_letters": 122,
      "cjk_chars": 41
    }
  ],
