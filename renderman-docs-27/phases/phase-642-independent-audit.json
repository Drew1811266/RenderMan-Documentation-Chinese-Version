    {
      "item_id": "21a8ca8aca:0",
      "text": "每个人都知道 Black 和 White colors 在 rendering 中意味着什么，对吧？",
      "ascii_letters": 25,
      "cjk_chars": 16
    },
    {
      "item_id": "21a8ca8aca:2",
      "text": "嗯……以防万一，这里有一份快速指南，说明 RenderMan 在 Roughness、Metallic 和 Bump 中如何处理 Black 与 White values。",
      "ascii_letters": 46,
      "cjk_chars": 24
    },
    {
      "item_id": "21a8ca8aca:3",
      "text": "材质粗糙度（Material Roughness）",
      "ascii_letters": 17,
      "cjk_chars": 5
    },
    {
      "item_id": "21a8ca8aca:4",
      "text": "黑色（Black）= 光亮表面（Shiny）",
      "ascii_letters": 10,
      "cjk_chars": 6
    },
    {
      "item_id": "21a8ca8aca:5",
      "text": "Roughness Value（粗糙度值）：1",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:6",
      "text": "白色（White）= 粗糙表面（Rough）",
      "ascii_letters": 10,
      "cjk_chars": 6
    },
    {
      "item_id": "21a8ca8aca:7",
      "text": "Roughness Value（粗糙度值）：0",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:8",
      "text": "材质 Metallic 工作流（Material Metallic Workflow）",
      "ascii_letters": 32,
      "cjk_chars": 5
    },
    {
      "item_id": "21a8ca8aca:9",
      "text": "黑色（Black）= 非金属（Non-Metal）",
      "ascii_letters": 13,
      "cjk_chars": 5
    },
    {
      "item_id": "21a8ca8aca:10",
      "text": "Roughness Value（粗糙度值）：1",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:11",
      "text": "白色（White）= 金属（Metal）",
      "ascii_letters": 10,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:12",
      "text": "Roughness Value（粗糙度值）：0",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:13",
      "text": "Bump Maps（凹凸贴图）",
      "ascii_letters": 8,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:14",
      "text": "黑色（Black）= 向内凹凸（Bump In）",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "21a8ca8aca:15",
      "text": "白色（White）= 向外凹凸（Bump Out）",
      "ascii_letters": 12,
      "cjk_chars": 6
    },
    {
      "item_id": "21a8ca8aca:16",
      "text": "Displacement Maps（置换贴图）",
      "ascii_letters": 16,
      "cjk_chars": 4
    },
    {
      "item_id": "21a8ca8aca:17",
      "text": "黑色（Black）= 向内置换（Displace Inwards）",
      "ascii_letters": 20,
      "cjk_chars": 6
    },
    {
      "item_id": "21a8ca8aca:18",
      "text": "白色（White）= 向外置换（Displace Outwards）",
      "ascii_letters": 21,
      "cjk_chars": 6
    },
    {
