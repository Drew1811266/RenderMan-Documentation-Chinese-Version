  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "84388dd877:1",
      "text": "：RenderMan Digital Studio",
      "ascii_letters": 22,
      "cjk_chars": 0
    },
    {
      "item_id": "84388dd877:2",
      "text": "Created by Pixar Artist（由 Pixar 艺术家创建）",
      "ascii_letters": 25,
      "cjk_chars": 6
    },
    {
      "item_id": "84388dd877:4",
      "text": "Eugene Riecansky",
      "ascii_letters": 15,
      "cjk_chars": 0
    },
    {
      "item_id": "84388dd877:6",
      "text": "：ACES、USD、PxrSurface",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "84388dd877:7",
      "text": "这个 scene 附带多种 studio coves。Plus（另外），它还包含一个完整的 asset library，内有大量 studio-inspired assets 和 kits，由 RenderMan 内部 rental company Point Reyes Electric 友情提供，并包含多种 model 和 shading variants。",
      "ascii_letters": 116,
      "cjk_chars": 35
    },
    {
      "item_id": "84388dd877:11",
      "text": "asset pack 位于 Maya 的 Content Browser 中。",
      "ascii_letters": 27,
      "cjk_chars": 4
    },
    {
      "item_id": "84388dd877:12",
      "text": "要安装 assets，请打开 Content Browser，选择 Favourites tab，点击 Add New，并选择 Maya download 中的 Assets folder。所有 Studio assets 随后都会加载到 content browser 中。",
      "ascii_letters": 89,
      "cjk_chars": 25
    },
    {
      "item_id": "84388dd877:13",
      "text": "从这里，你可以把 assets 直接 drag and drop 到 scene 中。",
      "ascii_letters": 22,
      "cjk_chars": 11
    },
    {
      "item_id": "84388dd877:15",
      "text": "Solaris / USD / Katana（Solaris、USD 与 Katana 使用方式）",
      "ascii_letters": 32,
      "cjk_chars": 5
    },
    {
      "item_id": "84388dd877:16",
      "text": "要在 Solaris 中使用，请把 downloads 中的 Assets folder 添加到 Asset gallery，然后通过 layout node 使用它们。或者，也可以使用 file 或 assetreference node 单独加载。",
      "ascii_letters": 72,
      "cjk_chars": 32
    },
    {
      "item_id": "84388dd877:17",
      "text": "如果你想在 Katana 中使用这些 assets，可以通过 USDIN node 加载它们，并创建你的 studio setups。",
      "ascii_letters": 33,
      "cjk_chars": 23
    },
    {
      "item_id": "84388dd877:18",
      "text": "Blender（Blender 中的资源安装）",
      "ascii_letters": 14,
      "cjk_chars": 6
    },
    {
      "item_id": "84388dd877:19",
      "text": "要在 Blender 中使用，只需把 Assets folder 添加到 Blender Preferences 中的 file path structure，随后就可以在 Asset Library panel 中看到所有 props。",
      "ascii_letters": 76,
      "cjk_chars": 24
    }
  ],
