  "actionable_ascii_heavy_residuals": [],
  "accepted_ascii_heavy_residuals": [
    {
      "item_id": "1de86a712d:2",
      "text": "subdivision surfaces",
      "ascii_letters": 19,
      "cjk_chars": 0
    },
    {
      "item_id": "1de86a712d:4",
      "text": "细分曲面类型（Subdivision surfaces）",
      "ascii_letters": 19,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:7",
      "text": "可以通过 creases 和 corners 获得 sharp 或 semi-sharp features。",
      "ascii_letters": 36,
      "cjk_chars": 8
    },
    {
      "item_id": "1de86a712d:9",
      "text": "displacement cracks 更少，拓扑更封闭（watertight）",
      "ascii_letters": 28,
      "cjk_chars": 7
    },
    {
      "item_id": "1de86a712d:11",
      "text": "需要不同的 modeling techniques/skills",
      "ascii_letters": 24,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:12",
      "text": "需要标记 sharp edges 和 vertices",
      "ascii_letters": 18,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:13",
      "text": "存在一些 topological constraints（quads 或 tris，不能有 non-manifold geometry）",
      "ascii_letters": 50,
      "cjk_chars": 8
    },
    {
      "item_id": "1de86a712d:14",
      "text": "Polygon meshes（多边形网格）",
      "ascii_letters": 13,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:16",
      "text": "非常适合 3D scanned mesh 这类 heavy geometry",
      "ascii_letters": 25,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:17",
      "text": "最适合会被 fractured / simmed 的 geometry。",
      "ascii_letters": 23,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:18",
      "text": "适合只有 sharp edges 且不需要 displacement 的 models",
      "ascii_letters": 28,
      "cjk_chars": 9
    },
    {
      "item_id": "1de86a712d:19",
      "text": "如果没有 displaced，就不会生成 micropolygons。",
      "ascii_letters": 22,
      "cjk_chars": 9
    },
    {
      "item_id": "1de86a712d:21",
      "text": "heavy models 会使用大量 memory，即使它们在 image 中很小。",
      "ascii_letters": 22,
      "cjk_chars": 13
    },
    {
      "item_id": "1de86a712d:22",
      "text": "在低 resolution 的 smoothed objects 上，shadow terminator 可能可见",
      "ascii_letters": 41,
      "cjk_chars": 8
    },
    {
      "item_id": "1de86a712d:23",
      "text": "可能出现 displacement cracks 裂缝",
      "ascii_letters": 18,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:24",
      "text": "Subdivision Modeling Tips（细分建模提示）",
      "ascii_letters": 23,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:27",
      "text": "PxrVisualizer",
      "ascii_letters": 13,
      "cjk_chars": 0
    },
    {
      "item_id": "1de86a712d:29",
      "text": "你甚至可以在实时 PxrVisualizer render 中进行 model！",
      "ascii_letters": 24,
      "cjk_chars": 11
    },
    {
      "item_id": "1de86a712d:30",
      "text": "使用 creases 创建 sharp 或 semi-sharp edges，而不必添加额外 edge loops。",
      "ascii_letters": 35,
      "cjk_chars": 12
    },
    {
      "item_id": "1de86a712d:31",
      "text": "SubDiv Crease Demo（细分折痕演示）",
      "ascii_letters": 16,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:32",
      "text": "我们选择了一个 isocahedron 的所有 edges，并把它们的 crease value 从 0.0 动画到 5.0。",
      "ascii_letters": 27,
      "cjk_chars": 19
    },
    {
      "item_id": "1de86a712d:34",
      "text": "SubDiv Corner Demo（细分角点演示）",
      "ascii_letters": 16,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:35",
      "text": "在这个 animation 中，triangular face 的三条 edges 都有 5.0 的 crease value。",
      "ascii_letters": 39,
      "cjk_chars": 10
    },
    {
      "item_id": "1de86a712d:36",
      "text": "我们把 triangle 的 vertex values 从 0 增加到 5.0。",
      "ascii_letters": 20,
      "cjk_chars": 8
    },
    {
      "item_id": "1de86a712d:38",
      "text": "SubDiv Types Demo（细分类型演示）",
      "ascii_letters": 15,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:39",
      "text": "subdivision surfaces 有三种类型。",
      "ascii_letters": 19,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:40",
      "text": "Catmull-Clark 是 subdivision schemes 中最灵活、最流行的一种。",
      "ascii_letters": 30,
      "cjk_chars": 11
    },
    {
      "item_id": "1de86a712d:41",
      "text": "Loop 是基于 triangle 的 subdivision surface。没有 creases 或 corners。适用于 cloth simulations",
      "ascii_letters": 60,
      "cjk_chars": 10
    },
    {
      "item_id": "1de86a712d:42",
      "text": "Bilinear 类似于所有 edges 都带有无限 hard creases 的 Catmull-Clark",
      "ascii_letters": 36,
      "cjk_chars": 11
    },
    {
      "item_id": "1de86a712d:43",
      "text": "细分镶嵌（Tesselation）控制",
      "ascii_letters": 11,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:45",
      "text": "surface tesselation 是自动处理的",
      "ascii_letters": 18,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:49",
      "text": "micropolygon length",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "1de86a712d:51",
      "text": "默认情况下，它以 pixels 表示；micropolygon length 为 1（默认值）意味着每个 micropolygon 大约 1 pixel 宽。",
      "ascii_letters": 41,
      "cjk_chars": 21
    },
    {
      "item_id": "1de86a712d:52",
      "text": "如果不希望 tesselation 动态变化，可以在 object 或 world space 中设置它，或定义 dicing camera。",
      "ascii_letters": 39,
      "cjk_chars": 20
    },
    {
      "item_id": "1de86a712d:53",
      "text": "除非你看到一些 artefacts，否则我们建议禁用“raster-oriented dicing”。",
      "ascii_letters": 29,
      "cjk_chars": 15
    },
    {
      "item_id": "1de86a712d:54",
      "text": "SubDiv vs Poligon Dicing Demo（SubDiv 与 Poligon Dicing 演示）",
      "ascii_letters": 44,
      "cjk_chars": 3
    },
    {
      "item_id": "1de86a712d:55",
      "text": "我们比较了一个带 crease、带 displacement 的 Catmull-Clark subdivision surface 与等效的 polygon mesh。",
      "ascii_letters": 59,
      "cjk_chars": 14
    },
    {
      "item_id": "1de86a712d:56",
      "text": "提高 micropolygon length 等同于让 object 在 image 中的尺寸变小。",
      "ascii_letters": 29,
      "cjk_chars": 13
    },
    {
      "item_id": "1de86a712d:57",
      "text": "当 object 很大时，它会被精细 tessellated 成数百万个 micropolygons，从而显示细致的 displacement detail。",
      "ascii_letters": 48,
      "cjk_chars": 21
    },
    {
      "item_id": "1de86a712d:58",
      "text": "当 object 变得小于一个 pixel 时，只剩下 base mesh。",
      "ascii_letters": 19,
      "cjk_chars": 11
    },
    {
      "item_id": "1de86a712d:59",
      "text": "Micropolygon Length",
      "ascii_letters": 18,
      "cjk_chars": 0
    },
    {
      "item_id": "1de86a712d:60",
      "text": "有点像“automatic level of detail”。当 object 在屏幕上小到不需要完整细节表示时，它会节省 memory。",
      "ascii_letters": 34,
      "cjk_chars": 24
    },
    {
      "item_id": "1de86a712d:61",
      "text": "注意 subdiv 会降到更少的 faces，从而节省 memory 并加快 raytracing。",
      "ascii_letters": 27,
      "cjk_chars": 15
    },
    {
      "item_id": "1de86a712d:63",
      "text": "Data Amplification",
      "ascii_letters": 17,
      "cjk_chars": 0
    },
    {
      "item_id": "1de86a712d:64",
      "text": "：一种紧凑的 geometric representation，可在需要时增强以创建更多 detail。",
      "ascii_letters": 29,
      "cjk_chars": 17
    },
    {
      "item_id": "1de86a712d:65",
      "text": "Model detailing（模型细节）",
      "ascii_letters": 14,
      "cjk_chars": 4
    },
    {
      "item_id": "1de86a712d:66",
      "text": "通常，更好的做法是依靠 displacement 和 bump mapping 来添加 details。",
      "ascii_letters": 30,
      "cjk_chars": 14
    },
    {
      "item_id": "1de86a712d:67",
      "text": "Displacement 允许你添加较大的 geometric features，这些特征会影响 object 的 outline 和 shadowing。",
      "ascii_letters": 51,
      "cjk_chars": 17
    },
    {
      "item_id": "1de86a712d:68",
      "text": "Displacement 会影响 time to first pixel（micropolygon generation），但不会拖慢 shading。",
      "ascii_letters": 57,
      "cjk_chars": 8
    },
    {
      "item_id": "1de86a712d:69",
      "text": "Bump 或 normal maps 会添加小尺度 details。",
      "ascii_letters": 21,
      "cjk_chars": 7
    },
    {
      "item_id": "1de86a712d:70",
      "text": "Bump mapping 会在 shading 期间增加少量 cost（每次 ray hit 都重新计算）。",
      "ascii_letters": 28,
      "cjk_chars": 15
    },
    {
      "item_id": "1de86a712d:71",
      "text": "注意，如果 incoming ray 过于“blurry”，我们的 bump-mapping nodes 不会计算 bump，因此没有 bump 也不会被注意到。",
      "ascii_letters": 41,
      "cjk_chars": 24
    },
    {
      "item_id": "1de86a712d:73",
      "text": "retopologizing 以创建轻量 model",
      "ascii_letters": 19,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:74",
      "text": "从 high-resolution mesh 中提取 displacement map 贴图。",
      "ascii_letters": 33,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:75",
      "text": "我们的 displacement nodes 有一个“model displacement” input，可连接提取出的 displacement map。",
      "ascii_letters": 54,
      "cjk_chars": 13
    },
    {
      "item_id": "1de86a712d:76",
      "text": "Memory usage and performance（内存使用与性能）",
      "ascii_letters": 25,
      "cjk_chars": 7
    },
    {
      "item_id": "1de86a712d:77",
      "text": "Polygon meshes（多边形网格）",
      "ascii_letters": 13,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:79",
      "text": "time to first pixel",
      "ascii_letters": 16,
      "cjk_chars": 0
    },
    {
      "item_id": "1de86a712d:80",
      "text": "（TTFP），前提是没有 displacement。",
      "ascii_letters": 16,
      "cjk_chars": 5
    },
    {
      "item_id": "1de86a712d:81",
      "text": "当 displaced 时，mesh 会被 diced，并生成 micropolygons。",
      "ascii_letters": 31,
      "cjk_chars": 7
    },
    {
      "item_id": "1de86a712d:82",
      "text": "未 displacement 的 heavy meshes 会使用相同数量的 RAM，无论它们是 full-screen 还是只有 2 pixels 高。",
      "ascii_letters": 42,
      "cjk_chars": 20
    },
    {
      "item_id": "1de86a712d:83",
      "text": "细分曲面类型（Subdivision surfaces）",
      "ascii_letters": 19,
      "cjk_chars": 6
    },
    {
      "item_id": "1de86a712d:84",
      "text": "TTFP 稍长，但 dicing 是 multi-threaded 且高效的。",
      "ascii_letters": 23,
      "cjk_chars": 8
    },
    {
      "item_id": "1de86a712d:85",
      "text": "在相同 vertices 数量下，比 meshes 多使用一点 memory。",
      "ascii_letters": 20,
      "cjk_chars": 12
    },
    {
      "item_id": "1de86a712d:86",
      "text": "稀疏 modeled 的 subdiv 在 2 pixels 高时只包含 base mesh faces。",
      "ascii_letters": 32,
      "cjk_chars": 9
    },
    {
      "item_id": "1de86a712d:87",
      "text": "这种 adaptivity 会降低 memory usage，并加快 raytracing。",
      "ascii_letters": 31,
      "cjk_chars": 8
    }
  ],
