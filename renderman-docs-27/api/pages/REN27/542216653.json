height=\"384\" data-width=\"384\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542216680\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"rman_pxrsurf_glowColor1.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542216653\" data-linked-resource-container-version=\"1\" data-media-id=\"9e9c9b01-f388-4f1d-8d98-3329638125bb\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542216653/rman_pxrsurf_glowColor1.jpg?version=1&amp;modificationDate=1754330511105&amp;cacheVersion=1&amp;api=v2&amp;width=384&amp;height=384 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542216653/rman_pxrsurf_glowColor1.jpg?version=1&amp;modificationDate=1754330511105&amp;cacheVersion=1&amp;api=v2&amp;width=384&amp;height=384 1x\"></span></div>\n</div>\n</div>\n<div class=\"columnLayout fixed-width\" data-layout=\"fixed-width\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<hr/><span class=\"confluence-embedded-file-wrapper image-left-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-left\" width=\"64\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542216653/RenderManFundamentals_logo.png?version=1&amp;modificationDate=1754330511359&amp;cacheVersion=1&amp;api=v2&amp;width=64&amp;height=64\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542216653/RenderManFundamentals_logo.png?version=1&amp;modificationDate=1754330511359&amp;cacheVersion=1&amp;api=v2\" data-height=\"64\" data-width=\"64\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542216689\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"RenderManFundamentals_logo.png\" data-base-url=\"https://renderman