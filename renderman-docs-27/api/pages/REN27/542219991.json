=v2&amp;width=264&amp;height=264\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542219991/Lama_Iridescence_hue22.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2\" data-height=\"800\" data-width=\"800\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542220015\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Lama_Iridescence_hue22.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542219991\" data-linked-resource-container-version=\"1\" data-media-id=\"5a12b8c4-71ff-4eea-a730-c62a76d96d08\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue22.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2&amp;width=528&amp;height=528 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue22.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264 1x\"></span></td><td class=\"confluenceTd\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"Lama_Iridescence_hue23.jpg\" width=\"264\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue23.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542219991/Lama_Iridescence_hue23.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2\" data-height=\"800\" data-width=\"800\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542220012\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Lama_Iridescence_hue23.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542219991\" data-linked-resource-container-version=\"1\" data-media-id=\"fbaa3cba-7b9b-48fa-937f-249283677f6f\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue23.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2&amp;width=528&amp;height=528 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue23.jpg?version=1&amp;modificationDate=1754330556578&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264 1x\"></span></td><td class=\"confluenceTd\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"Lama_Iridescence_hue24.jpg\" width=\"264\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue24.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542219991/Lama_Iridescence_hue24.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2\" data-height=\"800\" data-width=\"800\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542220009\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Lama_Iridescence_hue24.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542219991\" data-linked-resource-container-version=\"1\" data-media-id=\"8c83fd85-7b44-4b65-b896-7385e7826ada\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue24.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2&amp;width=528&amp;height=528 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue24.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264 1x\"></span></td><td class=\"confluenceTd\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"Lama_Iridescence_hue25.jpg\" width=\"264\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue25.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542219991/Lama_Iridescence_hue25.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2\" data-height=\"800\" data-width=\"800\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542220006\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Lama_Iridescence_hue25.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542219991\" data-linked-resource-container-version=\"1\" data-media-id=\"798e492a-08f2-44d7-b8c7-d1c874108f7e\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue25.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2&amp;width=528&amp;height=528 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542219991/Lama_Iridescence_hue25.jpg?version=1&amp;modificationDate=1754330556307&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264 1x\"></span></td></tr></tbody></table></div><hr/><h3 id=\"LamaIridescence-AngleMapping\">Angle Mapping</h3><p><br/><strong>Incident Angle</strong><br/>Remaps the incident angles before evaluating the iridescence. <br/>Can be used to control the view-dependent colors, e.g. to shift the colors or modify the frequency of the color changes. Should be used with caution as this has an effect on the whole reflectivity and not just the color hues.<br/><br/></p><p><strong>Roughness</strong><br/>Micro-facet distribution roughness.</p><p><br/><strong>Color Preservation</strong><br/>Can be used to preserve the iridescence colors when high roughness values are set. <br/>This can lead to non-physical material responses, especially at a grazing angle.  Values between 0 and 0.5 will gradually increase color preservation at the incident angle while still remaining physically accurate at the grazing angle.<br/><br/>Values between 0.5 and 1 will gradually increase color preservation at the grazing angle while keeping full-color preservation at the incident angle.<br/><br/><br/></p><hr/><h3 id=\"LamaIridescence-Tail\">Tail</h3><p><strong>Mix</strong><br/>Indicates how pronounced the tail effect should be, ranging linearly from none at all to full tail roughness.</p><p><br/></p><p><strong>Tail Length</strong><br/>Defines how rough the tail effect should appear, ranging from no roughness change at all to a roughness of 1 (or to 0 with a negative value).</p><p><br/></p><hr/><h3 id=\"LamaIridescence-Anisotropy\">Anisotropy</h3><p><br/><strong>Anisotropy</strong><br/>Defines the amount of anisotropy, changing the co-tangent axis roughness from the original value toward 1 (or toward 0 with a negative anisotropy value).</p><p><br/><strong>Anisotropy Direction</strong><br/>Overrides the surface tangent as the anisotropy direction.</p><p><br/></p><hr/><h3 id=\"LamaIridescence-ThinFilm\">Thin Film</h3><p><br/><strong>Relative Film Thickness</strong><br/>Relative thin film thickness in the range from 0 to 1 will be scaled to the minimum and maximum thickness, respectively.</p><p><br/></p><p><strong>Min Film Thickness</strong><br/>Minimum thin film thickness in nanometers, driving the iridescent effect.</p><p><br/><strong>Max Film Thickness</strong><br/>Maximum thin film thickness in nanometers, driving the iridescent effect.</p><p><br/><strong>Film IOR</strong><br/>Thin film index of refraction, driving the iridescent effect.</p><p><br/></p><hr/><h3 id=\"LamaIridescence-Advanced\">Advanced</h3><p><br/><strong>Pass Iridescence</strong><br/>The iridescence node has two modes of operation.</p><p>By default, it works independently and trades physical accuracy for usability by ignoring the material it is layered on. <br/>This option can be turned on if a more physically accurate behavior is desired. In this case, the iridescence computation will be passed to the underlying material, if supported. <br/>Supported materials include dielectrics and conductors. For unsupported materials, the default behavior applies.</p><p><br/><strong>Override Exterior IOR</strong><br/>When enabled, the IOR and refracted rays from layers above will be ignored, and the exterior IOR will be set manually.<br/><br/><strong>Exterior IOR</strong><br/>Defines what the IOR of the exterior medium is (can be either the outside medium, eg. air or water, or in the case of a layered material, the top layer medium, like plexiglass or varnish).</p><p><br/><strong>Energy Compensation</strong><br/>Indicates how much energy should be added to the lobes, to compensate for the loss inherent to micro-facet models, ranging from no compensation at all to the expected energy from multiple scattering between the micro-facets. <br/>This prevents overly dark results when roughness is high.</p><p><br/><strong>Surface Mollification</strong><br/>Defines by how much the roughness can be increased based on local surface curvature. This can help prevent fireflies.</p><p><br/><strong>Motion Mollification</strong><br/>Defines by how much the roughness can be increased based on motion blur. This can help prevent fireflies.</p><p><br/><strong>Lobe Name</strong><br/>Defines the name that can be used in LPE AOVs for these lobes.</p><p><br/><strong>Matte</strong><br/>Defines the name that can be used by the matte system, to output the weight of this lobe in the final material as an AOV.</p><p><br/><br/><br/><br/><br/><br/><br/></p><p><br/></p><p><br/><br/><br/><br/></p><p><br/></p>"
