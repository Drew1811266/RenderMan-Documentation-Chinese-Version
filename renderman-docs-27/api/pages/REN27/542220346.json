e-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Trans_roughness.0004.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542220346\" data-linked-resource-container-version=\"1\" data-media-id=\"1e1fa708-61af-4312-955a-446a5ec9434e\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0004.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=528&amp;height=528 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0004.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=264&amp;height=264 1x\"></span></td><td class=\"confluenceTd\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"Trans_roughness.0005.jpg\" width=\"217\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0005.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=217&amp;height=217\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542220346/Trans_roughness.0005.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2\" data-height=\"800\" data-width=\"800\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542220361\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Trans_roughness.0005.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542220346\" data-linked-resource-container-version=\"1\" data-media-id=\"dd1a1760-0af5-4c52-91a5-5c396c8a9c4d\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0005.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=434&amp;height=434 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0005.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=217&amp;height=217 1x\"></span></td><td class=\"confluenceTd\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"Trans_roughness.0006.jpg\" width=\"217\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0006.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=217&amp;height=217\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542220346/Trans_roughness.0006.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2\" data-height=\"800\" data-width=\"800\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542220358\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"Trans_roughness.0006.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542220346\" data-linked-resource-container-version=\"1\" data-media-id=\"5d8e7708-5926-45d2-8fec-54126723f1db\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0006.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=434&amp;height=434 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542220346/Trans_roughness.0006.jpg?version=1&amp;modificationDate=1754330561780&amp;cacheVersion=1&amp;api=v2&amp;width=217&amp;height=217 1x\"></span></td></tr></tbody></table></div><p><span class=\"legacy-color-text-blue3\">Roughness examples : 0.0 / 0.2 / 0.8 / 0.6 / 0.8 / 1.0</span></p><p><br/></p><p><strong>Normal/Bump</strong></p><p><span class=\"legacy-color-text-default\">Here is where you supply a signal, either a texture or procedural pattern, to create a bump to the surface to &quot;fake&quot; surface details like small bumps or scratches. This means an artist doesn't have to model these tedious and often repetitious parts of a model.</span></p><p><br/></p>"
