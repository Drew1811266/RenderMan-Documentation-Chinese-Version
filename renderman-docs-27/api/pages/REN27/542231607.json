4330716047&amp;cacheVersion=1&amp;api=v2&amp;width=666&amp;height=374\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542231607/PxrCamera_LensDisrt_radial3_1_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2\" data-height=\"720\" data-width=\"1280\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542231643\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"PxrCamera_LensDisrt_radial3_1_.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542231607\" data-linked-resource-container-version=\"1\" data-media-id=\"1998ddae-9191-40ca-8fdf-25c1c98f19d9\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_radial3_1_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=1280&amp;height=720 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_radial3_1_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=666&amp;height=374 1x\"></span></div>\n</div>\n</div>\n<div class=\"columnLayout fixed-width\" data-layout=\"fixed-width\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<p /><p /><p><strong>Asymmetric Distortion X</strong><br/>Distortion applied only in the X direction. Horizontal lines will remain straight. Positive values produce pincushion-like distortion. Negative values produce barrel-like distortion.</p><p /></div>\n</div>\n</div>\n<div class=\"columnLayout two-equal\" data-layout=\"two-equal\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"PxrCamera_LensDisrt_X_pos_.jpg\" width=\"666\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_X_pos_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=666&amp;height=374\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542231607/PxrCamera_LensDisrt_X_pos_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2\" data-height=\"720\" data-width=\"1280\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542231640\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"PxrCamera_LensDisrt_X_pos_.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542231607\" data-linked-resource-container-version=\"1\" data-media-id=\"59cbe47b-b100-4bb6-b152-3101beeff138\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_X_pos_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=1280&amp;height=720 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_X_pos_.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=666&amp;height=374 1x\"></span></div>\n</div>\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"PxrCamera_LensDisrt_X_minus.jpg\" width=\"666\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_X_minus.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=666&amp;height=374\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/542231607/PxrCamera_LensDisrt_X_minus.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2\" data-height=\"720\" data-width=\"1280\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"542231637\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"PxrCamera_LensDisrt_X_minus.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"542231607\" data-linked-resource-container-version=\"1\" data-media-id=\"dc2675aa-3e77-4e81-835e-bd54acf6b325\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_X_minus.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=1280&amp;height=720 2x, https://renderman.atlassian.net/wiki/download/thumbnails/542231607/PxrCamera_LensDisrt_X_minus.jpg?version=1&amp;modificationDate=1754330716047&amp;cacheVersion=1&amp;api=v2&amp;width=666&amp;height=374 1x\"></span></div>\n</div>\n</div>\n<div class=\"columnLayout fixed-width\" data-layout=\"fixed-width\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<p /><p /><p><strong>Asymmetric Distortion Y</strong><br/>Distortion applied only in the Y direction. Vertical lines will remain straight. Positive values produce pincushion-like distortion. Negative values produce barrel-like distortion.</p><p /></div>\n</div>\n</div>\n<div class=\"columnLayout two-equal\" data-layout=\"two-equal\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"PxrCamera_LensDisrt_Y_plus.jpg\" width=\"666\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/