-type=\"image/png\" data-linked-resource-container-id=\"609157121\" data-linked-resource-container-version=\"5\" data-media-id=\"b6590dfe-4e2c-45e3-881c-1d687d866b88\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/609157121/by-nc.png?version=1&amp;modificationDate=1758356145678&amp;cacheVersion=1&amp;api=v2&amp;width=358&amp;height=124 2x, https://renderman.atlassian.net/wiki/download/thumbnails/609157121/by-nc.png?version=1&amp;modificationDate=1758356145678&amp;cacheVersion=1&amp;api=v2&amp;width=179&amp;height=62 1x\" /></span><p /><hr /><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"RenderManUniversity_logo_Small.png\" width=\"100\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/609157121/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758356144724&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/609157121/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758356144724&amp;cacheVersion=1&amp;api=v2\" data-height=\"100\" data-width=\"100\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"609157137\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"RenderManUniversity_logo_Small.png\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"609157121\" data-linked-resource-container-version=\"5\" data-media-id=\"60193e7a-2cac-442c-a7da-24782104b874\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/609157121/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758356144724&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100 2x, https://r