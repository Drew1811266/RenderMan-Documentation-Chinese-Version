.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"604438600\" data-linked-resource-container-version=\"5\" data-media-id=\"be7172f6-b160-4cbf-8a74-e0cd9a2b7c3f\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/604438600/stirling_uvs_thumb.jpg?version=1&amp;modificationDate=1762589071974&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255 2x, https://renderman.atlassian.net/wiki/download/thumbnails/604438600/stirling_uvs_thumb.jpg?version=1&amp;modificationDate=1762589071974&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255 1x\" /></span></a></div>\n</div>\n<div class=\"cell aside\" data-type=\"aside\">\n<div class=\"innerCell\">\n<h1 id=\"StirlingVFX-Texturing\"><span data-colorid=\"o3l026tbjy\">Texturing</span></h1><p /></div>\n</div>\n</div>\n<div class=\"columnLayout two-right-sidebar\" data-layout=\"two-right-sidebar\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<a href=\"/wiki/spaces/RU/pages/657424403/Stirling+Rendering\" data-linked-resource-id=\"657424403\" data-linked-resource-version=\"1\" data-linked-resource-type=\"page\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"stirling_rendering_thumb.jpg\" width=\"586\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/604438600/stirling_rendering_thumb.jpg?version=1&amp;modificationDate=1762589122004&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/604438600/stirling_rendering_thumb.jpg?version=1&amp;modificationDate=1762589122004&amp;cacheVersion=1&amp;api=v2\" data-height=\"255\" data-width=\"586\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"657162278\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"stirling_rendering_thumb.jpg\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"604438600\" data-linked-resource-container-version=\"5\" data-media-id=\"12ae93d7-88ae-4a02-ae69-53cfed335a30\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/604438600/stirling_rendering_thumb.jpg?version=1&amp;modificationDate=1762589122004&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255 2x, https://renderman.atlassian.net/wiki/download/thumbnails/604438600/stirling_rendering_thumb.jpg?version=1&amp;modificationDate=1762589122004&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255 1x\" /></span></a></div>\n</div>\n<div class=\"cell aside\" data-type=\"aside\">\n<div class=\"innerCell\">\n<h1 id=\"StirlingVFX-Rendering\"><span data-colorid=\"xkgpfi7hb2\">Rendering</span></h1><p /></div>\n</div>\n</div>\n<div class=\"columnLayout two-right-sidebar\" data-layout=\"two-right-sidebar\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<a href=\"/wiki/spaces/RU/pages/657162271/Stirling+Compositing\" data-linked-resource-id=\"657162271\" data-linked-resource-version=\"1\" data-linked-resource-type=\"page\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"stirling_comp_thumb.jpg\" width=\"586\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/604438600/stirling_comp_thumb.jpg?version=1&amp;modificationDate=1762589176408&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/604438600/stirling_comp_thumb.jpg?version=1&amp;modificationDate=1762589176408&amp;cacheVersion=1&amp;api=v2\" data-height=\"255\" data-width=\"586\" data-unresolved-comment-