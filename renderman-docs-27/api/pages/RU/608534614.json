erman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"608534614\" data-linked-resource-container-version=\"2\" data-media-id=\"ed88bd8f-7bcf-435b-805d-fe0eef298a3b\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608534614/by-nc.png?version=1&amp;modificationDate=1758285172113&amp;cacheVersion=1&amp;api=v2&amp;width=358&amp;height=124 2x, https://renderman.atlassian.net/wiki/download/thumbnails/608534614/by-nc.png?version=1&amp;modificationDate=1758285172113&amp;cacheVersion=1&amp;api=v2&amp;width=179&amp;height=62 1x\" /></span><p /><hr /><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"RenderManUniversity_logo_Small.png\" width=\"100\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/608534614/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285172759&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/608534614/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285172759&amp;cacheVersion=1&amp;api=v2\" data-height=\"100\" data-width=\"100\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"608534663\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"RenderManUniversity_logo_Small.png\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"608534614\" data-linked-resource-container-version=\"2\" data-media-id=\"14e1b384-4b4c-4478-ae49-74be682096a1\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608534614/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285172759&amp;cacheVersion=