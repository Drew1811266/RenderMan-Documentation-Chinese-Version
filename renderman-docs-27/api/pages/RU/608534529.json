ta-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"608534529\" data-linked-resource-container-version=\"1\" data-media-id=\"3a0f91aa-2878-4bea-861e-2c4934d6030c\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608534529/by-nc.png?version=1&amp;modificationDate=1758285024196&amp;cacheVersion=1&amp;api=v2&amp;width=358&amp;height=124 2x, https://renderman.atlassian.net/wiki/download/thumbnails/608534529/by-nc.png?version=1&amp;modificationDate=1758285024196&amp;cacheVersion=1&amp;api=v2&amp;width=179&amp;height=62 1x\" /></span><p /><hr /><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"RenderManUniversity_logo_Small.png\" width=\"100\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/608534529/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285023445&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/608534529/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285023445&amp;cacheVersion=1&amp;api=v2\" data-height=\"100\" data-width=\"100\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"608534545\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"RenderManUniversity_logo_Small.png\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"608534529\" data-linked-resource-container-version=\"1\" data-media-id=\"099c7b15-54dc-4bc6-bd6d-5f9b8b4b76d6\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608534529/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=17582