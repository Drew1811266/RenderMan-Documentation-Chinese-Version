\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/jpeg\" data-linked-resource-container-id=\"600113185\" data-linked-resource-container-version=\"14\" data-media-id=\"2f2c2b2a-8377-40ea-9e82-afeefe6f11e2\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/600113185/scenes_banner.jpg?version=1&amp;modificationDate=1758278420494&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255 2x, https://renderman.atlassian.net/wiki/download/thumbnails/600113185/scenes_banner.jpg?version=1&amp;modificationDate=1758278420494&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255 1x\" /></span></a></div>\n</div>\n<div class=\"cell aside\" data-type=\"aside\">\n<div class=\"innerCell\">\n<h1 id=\"Resources-OfficialExampleScenes\"><span data-colorid=\"aotikeeedy\">Official Example Scenes</span></h1><p>A set of official RenderMan Example Scenes in all DCCs</p></div>\n</div>\n</div>\n<div class=\"columnLayout two-right-sidebar\" data-layout=\"two-right-sidebar\">\n<div class=\"cell normal\" data-type=\"normal\">\n<div class=\"innerCell\">\n<a href=\"/wiki/spaces/RU/pages/597491715/Guest+Scenes\" data-linked-resource-id=\"597491715\" data-linked-resource-version=\"37\" data-linked-resource-type=\"page\"><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"guestscenes.jpg\" width=\"586\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/600113185/guestscenes.jpg?version=1&amp;modificationDate=1758278784290&amp;cacheVersion=1&amp;api=v2&amp;width=586&amp;height=255\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/600113185/guestscenes.jpg?version=1&amp;modificationDate=1758278784290&amp;cacheVersion=1&amp;api=v2\" data-height=\"255\" data-width=\"586\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"608010364\" 