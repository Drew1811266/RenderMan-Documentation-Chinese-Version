8436284\" data-linked-resource-container-version=\"3\" data-media-id=\"90667df9-d7cc-400c-bcec-268ab6d37de3\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608436284/by-nc.png?version=1&amp;modificationDate=1758284865961&amp;cacheVersion=1&amp;api=v2&amp;width=358&amp;height=124 2x, https://renderman.atlassian.net/wiki/download/thumbnails/608436284/by-nc.png?version=1&amp;modificationDate=1758284865961&amp;cacheVersion=1&amp;api=v2&amp;width=179&amp;height=62 1x\" /></span><p /><hr /><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"RenderManUniversity_logo_Small.png\" width=\"100\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/608436284/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758284865214&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/608436284/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758284865214&amp;cacheVersion=1&amp;api=v2\" data-height=\"100\" data-width=\"100\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"608436300\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"RenderManUniversity_logo_Small.png\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"608436284\" data-linked-resource-container-version=\"3\" data-media-id=\"6b215f32-58f4-4124-a90d-00665d29803f\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608436284/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758284865214&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100 2x, https://renderman.atlassian.net/wiki/download/thumbnails/608436284/