source-content-type=\"image/png\" data-linked-resource-container-id=\"608567297\" data-linked-resource-container-version=\"1\" data-media-id=\"ec08043b-44d4-42d2-918a-1e8f9bb072b5\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608567297/by-nc.png?version=1&amp;modificationDate=1758285408729&amp;cacheVersion=1&amp;api=v2&amp;width=358&amp;height=124 2x, https://renderman.atlassian.net/wiki/download/thumbnails/608567297/by-nc.png?version=1&amp;modificationDate=1758285408729&amp;cacheVersion=1&amp;api=v2&amp;width=179&amp;height=62 1x\" /></span><p /><hr /><span class=\"confluence-embedded-file-wrapper image-center-wrapper confluence-embedded-manual-size\"><img class=\"confluence-embedded-image image-center\" alt=\"RenderManUniversity_logo_Small.png\" width=\"100\" loading=\"lazy\" src=\"https://renderman.atlassian.net/wiki/download/thumbnails/608567297/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285409378&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100\" data-image-src=\"https://renderman.atlassian.net/wiki/download/attachments/608567297/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285409378&amp;cacheVersion=1&amp;api=v2\" data-height=\"100\" data-width=\"100\" data-unresolved-comment-count=\"0\" data-linked-resource-id=\"608567348\" data-linked-resource-version=\"1\" data-linked-resource-type=\"attachment\" data-linked-resource-default-alias=\"RenderManUniversity_logo_Small.png\" data-base-url=\"https://renderman.atlassian.net/wiki\" data-linked-resource-content-type=\"image/png\" data-linked-resource-container-id=\"608567297\" data-linked-resource-container-version=\"1\" data-media-id=\"1db30ac1-1b1a-45f4-8929-845b65b84417\" data-media-type=\"file\" srcset=\"https://renderman.atlassian.net/wiki/download/thumbnails/608567297/RenderManUniversity_logo_Small.png?version=1&amp;modificationDate=1758285409378&amp;cacheVersion=1&amp;api=v2&amp;width=100&amp;height=100